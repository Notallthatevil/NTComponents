@namespace NTComponents
@using NTComponents.Core
@inherits NTButtonBase

<button @attributes="AdditionalAttributes"
        class="@ElementClass"
        style="@ElementStyle"
        type="@Type.ToHtmlAttribute()"
        name="@ElementName"
        disabled="@EffectiveDisabled"
        autofocus="@AutoFocus"
        title="@ElementTitle"
        id="@ElementId"
        aria-label="@AriaLabel"
        aria-pressed="@AriaPressed"
        @onclick="HandleClickAsync"
        @onclick:stopPropagation="StopPropagation"
        @ref="Element">
    @if (Tooltip is not null) {
        <NTTooltip>
            @Tooltip
        </NTTooltip>
    }

    @if (EnableRipple) {
        @NTRipple.Render()
    }

    <span class="nt-icon-button-icon" aria-hidden="true">
        @Icon.Render()
    </span>

    @ButtonProgressIndicator
</button>
<script>
    (function (script) {
        window.NTComponents?.startButtonInteraction?.(script);
    })(document.currentScript);
</script>
