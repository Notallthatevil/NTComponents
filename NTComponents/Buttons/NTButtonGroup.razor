@namespace NTComponents
@inherits TnTComponentBase
@using Microsoft.AspNetCore.Components.Web
@using NTComponents.Core
@typeparam TObjectType

<CascadingValue Value="this" IsFixed="true">
	@ChildContent
	<DeferRendering>
		<div @attributes="AdditionalAttributes"
			 class="@ElementClass"
			 style="@ElementStyle"
			 id="@ElementId"
			 role="group"
			 aria-label="@AriaLabel">

			@for (var itemIndex = 0; itemIndex < _items.Count; itemIndex++) {
				var item = _items[itemIndex];
				var state = GetItemRenderState(item, itemIndex);
				<button class="@state.ButtonClass"
						@key="item.Key"
						type="button"
						disabled="@state.IsDisabled"
						aria-label="@state.AriaLabel"
						aria-pressed="@state.AriaPressed"
						@onclick="@(() => HandleItemClickAsync(item))"
						@onclick:stopPropagation="StopPropagation">
					@if (IsRippleEnabled) {
						@ButtonRipple
					}
					@if (item.Icon is not null) {
						<span class="@state.IconClass" aria-hidden="true">
							@item.Icon.Render()
						</span>
					}
					@if (!state.IsIconOnly) {
						<span class="nt-button-label">@state.Label</span>
					}
				</button>
			}
		</div>
		@if (!IsRippleEnabled) {
			@ButtonInteractionScript
		}
		@if (EditContext is not null) {
			@if (!string.IsNullOrWhiteSpace(_name)) {
				@if (IsMultiSelect) {
					@foreach (var selectedKey in SelectedKeys) {
						<input type="hidden" name="@_name" value="@FormatFormValue(selectedKey)" />
					}
				}
				else if (SelectedKey is not null) {
					<input type="hidden" name="@_name" value="@FormatFormValue(SelectedKey)" />
				}
			}
			<div class="tnt-supporting-text">
				<ValidationMessage class="tnt-supporting-text tnt-validation-message" For="SelectedKeyExpression" style="@CssStyleBuilder.Create().AddForegroundColor(ErrorColor).Build()"/>
			</div>
		}
	</DeferRendering>
</CascadingValue>
