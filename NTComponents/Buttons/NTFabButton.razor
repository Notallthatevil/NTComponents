@namespace NTComponents
@using NTComponents.Core
@inherits TnTComponentBase

<button @attributes="AdditionalAttributes"
		class="@ElementClass"
		style="@ElementStyle"
		type="@Type.ToHtmlAttribute()"
		name="@ElementName"
		disabled="@Disabled"
		autofocus="@AutoFocus"
		title="@ElementTitle"
		id="@ElementId"
		aria-label="@EffectiveAriaLabel"
		@onclick="HandleClickAsync"
		@onclick:stopPropagation="StopPropagation"
		@ref="Element">
	@if (Tooltip is not null) {
		<TnTTooltip>
			@Tooltip
		</TnTTooltip>
	}

	@if (EnableRipple) {
		@NTRipple.Render()
	}

	<span class="nt-fab-button-icon" aria-hidden="true">
		@Icon.Render()
	</span>

	@if (HasLabel) {
		<span class="nt-fab-button-label">@Label</span>
	}
</button>
