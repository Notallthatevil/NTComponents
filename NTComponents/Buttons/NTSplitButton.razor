@namespace NTComponents
@using Microsoft.AspNetCore.Components.Web
@using NTComponents.Core
@inherits TnTPageScriptComponent<NTSplitButton>

<DeferRendering>
    <nt-split-button @attributes="AdditionalAttributes"
                     class="@ElementClass"
                     style="@ElementStyle"
                     @ref="Element">
        <div class="nt-split-button-boundary">
            <button class="@ActionButtonClass"
                    type="@Type.ToHtmlAttribute()"
                    name="@ElementName"
                    disabled="@Disabled"
                    autofocus="@AutoFocus"
                    title="@ElementTitle"
                    aria-label="@ActionButtonAriaLabel"
                    id="@ElementId"
                    @onclick="HandleActionClickAsync"
                    @onclick:stopPropagation="StopPropagation">
                @if (EnableRipple) {
                    @ButtonRipple
                }
                @if (LeadingIcon is not null) {
                    <span class="nt-split-button-leading-icon" aria-hidden="true">
                        @LeadingIcon.Render()
                    </span>
                }
                @if (HasVisibleLabel) {
                    <span class="nt-split-button-label">@Label</span>
                }
            </button>

            <button class="@MenuButtonClass"
                    id="@MenuButtonId"
                    style="@MenuButtonStyle"
                    type="button"
                    disabled="@IsMenuButtonDisabled"
                    aria-label="@EffectiveMenuAriaLabel"
                    aria-haspopup="menu"
                    aria-expanded="@ExpandedAttribute"
                    aria-controls="@MenuId"
                    popovertarget="@MenuPopoverTarget"
                    popovertargetaction="toggle"
                    @onclick:stopPropagation="StopPropagation">
                @if (EnableRipple) {
                    @ButtonRipple
                }
                <span class="nt-split-button-trailing-icon" aria-hidden="true">
                    @MenuIcon.Render()
                </span>
            </button>

            <NTMenu ElementId="@MenuId"
                    @ref="_menu"
                    class="nt-split-button-menu-panel"
                    AnchorName="@MenuAnchorName"
                    AnchorSelector="@MenuAnchorSelector"
                    AriaLabel="@EffectiveMenuAriaLabel"
                    CloseOnContentClick="@CloseOnMenuContentClick"
                    ContainerColor="@MenuBackgroundColor"
                    TextColor="@MenuTextColor"
                    SelectedContainerColor="@MenuSelectedBackgroundColor"
                    SelectedTextColor="@MenuSelectedTextColor">
                @ChildContent
            </NTMenu>
        </div>
    </nt-split-button>
    @PageScript
</DeferRendering>
