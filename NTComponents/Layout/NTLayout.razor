@namespace NTComponents
@using NTComponents.Layout
@inherits NTLayoutComponentBase

@switch (ResolvedTag) {
    case NTLayoutTag.Div:
        <div @attributes="ElementAttributes" @ref="Element">
            <CascadingValue Value="this" IsFixed="true">@ChildContent</CascadingValue>
        </div>
        break;
    case NTLayoutTag.Article:
        <article @attributes="ElementAttributes" @ref="Element">
            <CascadingValue Value="this" IsFixed="true">@ChildContent</CascadingValue>
        </article>
        break;
    case NTLayoutTag.Aside:
        <aside @attributes="ElementAttributes" @ref="Element">
            <CascadingValue Value="this" IsFixed="true">@ChildContent</CascadingValue>
        </aside>
        break;
    case NTLayoutTag.Footer:
        <footer @attributes="ElementAttributes" @ref="Element">
            <CascadingValue Value="this" IsFixed="true">@ChildContent</CascadingValue>
        </footer>
        break;
    case NTLayoutTag.Header:
        <header @attributes="ElementAttributes" @ref="Element">
            <CascadingValue Value="this" IsFixed="true">@ChildContent</CascadingValue>
        </header>
        break;
    case NTLayoutTag.Main:
        <main @attributes="ElementAttributes" @ref="Element">
            <CascadingValue Value="this" IsFixed="true">@ChildContent</CascadingValue>
        </main>
        break;
    case NTLayoutTag.Section:
        <section @attributes="ElementAttributes" @ref="Element">
            <CascadingValue Value="this" IsFixed="true">@ChildContent</CascadingValue>
        </section>
        break;
    default:
        <div @attributes="ElementAttributes" @ref="Element">
            <CascadingValue Value="this" IsFixed="true">@ChildContent</CascadingValue>
        </div>
        break;
}
