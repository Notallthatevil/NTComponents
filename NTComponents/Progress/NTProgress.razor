@namespace NTComponents
@using NTComponents.Core
@inherits TnTDisposableComponentBase

@if (Show) {
    <div @attributes="@AdditionalAttributes"
         class="@ElementClass"
         style="@ElementStyle"
         id="@ElementId"
         lang="@ElementLang"
         title="@ElementTitle"
         role="@EffectiveRole"
         aria-label="@EffectiveAriaLabel"
         aria-labelledby="@EffectiveAriaLabelledBy"
         aria-valuemin="@EffectiveAriaValueMin"
         aria-valuemax="@EffectiveAriaValueMax"
         aria-valuenow="@EffectiveAriaValueNow"
         autofocus="@(AutoFocus == true ? "autofocus" : null)"
         @ref="Element">
        @if (IsLinearVariant) {
            @if (IsSineWaveAppearance) {
                <div class="nt-progress-track" aria-hidden="true">
                    <span class="nt-progress-track-segment"></span>
                    <span class="nt-progress-active-track nt-progress-sine-wave-track">
                        <svg class="nt-progress-sine-wave-svg"
                             viewBox="@LinearSineWaveViewBox"
                             width="@LinearSineWavePathWidth"
                             height="@LinearSineWaveViewBoxHeight"
                             preserveAspectRatio="none"
                             focusable="false">
                            <path class="nt-progress-sine-wave-path"
                                  d="@LinearSineWavePathData" />
                        </svg>
                    </span>
                    @if (ShouldRenderStop) {
                        <span class="nt-progress-stop"></span>
                    }
                </div>
            }
            else {
                <div class="nt-progress-track" aria-hidden="true">
                    <span class="nt-progress-track-segment"></span>
                    <span class="nt-progress-active-track"></span>
                    @if (ShouldRenderStop) {
                        <span class="nt-progress-stop"></span>
                    }
                </div>
            }
        }
        else {
            <svg class="nt-progress-track"
                 aria-hidden="true"
                 viewBox="0 0 100 100"
                 focusable="false">
                <circle class="nt-progress-track-segment nt-progress-track-segment-main"
                        cx="50"
                        cy="50"
                        r="45"
                        pathLength="100" />
                @if (IsIndeterminate) {
                    <circle class="nt-progress-track-segment nt-progress-track-segment-wrap"
                            cx="50"
                            cy="50"
                            r="45"
                            pathLength="100" />
                }
                @if (IsSineWaveAppearance) {
                    @foreach (var frame in RingSineWavePathFrames) {
                        <path class="nt-progress-active-track nt-progress-active-track-main nt-progress-sine-wave-path"
                              style="--nt-progress-ring-wave-frame-index:@frame.Index"
                              d="@frame.PathData" />
                    }
                }
                else {
                    <circle class="nt-progress-active-track nt-progress-active-track-main"
                            cx="50"
                            cy="50"
                            r="45"
                            pathLength="100" />
                    @if (IsIndeterminate) {
                        <circle class="nt-progress-active-track nt-progress-active-track-wrap"
                                cx="50"
                                cy="50"
                                r="45"
                                pathLength="100" />
                    }
                }
            </svg>
        }
    </div>
}
