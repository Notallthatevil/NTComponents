@namespace NTComponents

<section id="@Popover.ElementId"
         class="@ElementClass"
         style="@ElementStyle"
         role="dialog"
         aria-modal="false"
         aria-labelledby="@_titleElementId"
         aria-describedby="@DescriptionElementId"
         tabindex="-1"
         data-nt-popover-window="true"
         @ref="_windowElement"
         @onpointerdown="OnPointerDownAsync"
         @onkeydown="OnWindowKeyDownAsync">
    <div class="nt-popover__header"
         data-nt-popover-drag-handle="true"
         tabindex="0"
         aria-label="Window title bar. Use arrow keys to move the window."
         @onpointerdown="OnPointerDownAsync"
         @onkeydown="OnHeaderKeyDownAsync">
        <div class="nt-popover__heading">
            <span class="nt-popover__drag-indicator" aria-hidden="true">@MaterialIcon.DragIndicator.Render()</span>

            <div class="nt-popover__titles">
                <h2 class="nt-popover__title" id="@_titleElementId">@DisplayTitle</h2>

                @if (!string.IsNullOrWhiteSpace(Popover.Options.Description)) {
                    <p class="nt-popover__description" id="@_descriptionElementId">@Popover.Options.Description</p>
                }
            </div>
        </div>

        <div class="nt-popover__actions" role="toolbar" aria-label="@($"{DisplayTitle} window actions")">
            @if (Popover.Options.ShowHideButton) {
                <button class="nt-popover__action-button"
                        type="button"
                        aria-label="@($"Hide {DisplayTitle}")"
                        disabled="@(!RendererInfo.IsInteractive || IsDismissPending)"
                        @onclick="HideAsync">
                    @MaterialIcon.VisibilityOff.Render()
                </button>
            }

            @if (Popover.Options.ShowCloseButton) {
                <button class="nt-popover__action-button"
                        type="button"
                        aria-label="@($"Close {DisplayTitle}")"
                        disabled="@(!RendererInfo.IsInteractive || IsDismissPending)"
                        @onclick="CloseAsync">
                    @MaterialIcon.Close.Render()
                </button>
            }
        </div>
    </div>

    <div class="nt-popover__body">
        <CascadingValue Value="Popover" IsFixed="true">
            @RenderContent()
        </CascadingValue>
    </div>
</section>
