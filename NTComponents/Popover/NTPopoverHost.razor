@namespace NTComponents
@implements IDisposable

@if (_visiblePopovers.Count > 0 || _hiddenPopovers.Count > 0) {
    <div class="nt-popover-host">
        @foreach (var popover in _visiblePopovers) {
            <NTPopoverWindow Popover="@popover"
                              AnimateFromLauncher="@_restoringPopoverIds.Contains(popover.ElementId)"
                              OnLauncherEnterAnimationCompleted="OnLauncherEnterAnimationCompletedAsync"
                              @key="popover.ElementId" />
        }

        <div class="nt-popover-host__launchers"
             role="toolbar"
             aria-label="Hidden windows"
             data-nt-popover-launchers="true">
            @foreach (var popover in _hiddenPopovers) {
                var isRestoring = _restoringPopoverIds.Contains(popover.ElementId);

                <button class="@GetLauncherClass(isRestoring)"
                        type="button"
                        aria-label="@($"Restore {GetTitle(popover)}")"
                        disabled="@(!RendererInfo.IsInteractive || isRestoring)"
                        data-nt-popover-launcher-id="@popover.ElementId"
                        aria-hidden="@isRestoring"
                        @onclick="() => RestoreAsync(popover)">
                    <span class="nt-popover-host__launcher-icon" aria-hidden="true">@MaterialIcon.Dock.Render()</span>
                    <span class="nt-popover-host__launcher-text">@GetTitle(popover)</span>
                </button>
            }
        </div>
    </div>
}
