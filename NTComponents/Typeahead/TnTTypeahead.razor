@using Microsoft.AspNetCore.Components.Rendering
@using NTComponents
@using NTComponents.Core
@using NTComponents.Interfaces
@namespace NTComponents
@typeparam TItem
@inherits TnTPageScriptComponent<TnTTypeahead<TItem>>

<div @attributes="AdditionalAttributes"
	 class="@ElementClass"
	 style="@ElementStyle"
	 title="@ElementTitle"
	 lang="@ElementLang"
	 id="@ElementId"
	 name="@ElementName"
	 onkeypress="NTComponents.stopEnter(event)"
	 @ref="@Element">

	<span class="tnt-typeahead-box">
		<TnTInputText @bind-Value="Value"
					  Appearance="@Appearance"
					  Label="@Label"
					  Placeholder="@Placeholder"
					  BindOnInput="true"
					  BindAfter="SearchAsync"
					  Disabled="@Disabled"
					  BackgroundColor="BackgroundColor"
					  StartIcon="@MaterialIcon.Search"
					  Tooltip="@Tooltip"
					  TooltipIcon="@TooltipIcon"
					  role="combobox"
					  aria-autocomplete="list"
					  aria-expanded="@(IsDropdownVisible ? "true" : "false")"
					  aria-controls="@ListboxElementId"
					  aria-activedescendant="@FocusedOptionId"
					  @onkeyup="SelectOrShiftFocusAsync"
					  SupportingText="@SupportingText"
					  ErrorMessage="@_displayErrorMessage"
					  @ref="_inputBox" />
		<TnTProgressIndicator Show="@_searching" ProgressColor="ProgressColor" Size="Size.Small" />
	</span>
	@if (IsDropdownVisible) {
		<div class="tnt-typeahead-content">
			@if (_items.Any()) {
				<ul class="tnt-typeahead-list" id="@ListboxElementId" role="listbox">
					@foreach (var pair in _items.Select((item, index) => new { item, index })) {
						var item = pair.item;
						var index = pair.index;
						<li id="@($"{ComponentIdentifier}-option-{index}")"
							role="option"
							aria-selected="@(item!.Equals(_focusedItem) ? "true" : "false")"
							class="@($"tnt-typeahead-list-item{(item!.Equals(_focusedItem) ? " tnt-focused" : string.Empty)}")"
							tabindex="-1"
							@onclick="(() => ItemSelectedAsync(item))">
							@if (ResultTemplate is not null) {
								@ResultTemplate(item)
							}
							else {
								<span class="tnt-corner-radius-5 tnt-body-medium">
									@item
								</span>
							}
						</li>
					}
				</ul>
			}
			else if (!_items.Any() && !string.IsNullOrWhiteSpace(Value) && !_searching && !_itemSelected) {
				<div class="tnt-typeahead-no-results">
					No results found
				</div>
			}
		</div>
	}
</div>
@PageScript
