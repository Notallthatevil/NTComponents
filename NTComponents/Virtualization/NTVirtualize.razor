@namespace NTComponents
@using Microsoft.AspNetCore.Components.Rendering
@using Microsoft.AspNetCore.Components.Web.Virtualization
@using NTComponents.Core
@using System.Diagnostics
@typeparam TItem
@inherits TnTPageScriptComponent<NTVirtualize<TItem>>

@Render
@code {
	private void Render(RenderTreeBuilder builder) {
		if (_refreshException != null) {
			var oldRefreshException = _refreshException;
			_refreshException = null;

			throw oldRefreshException;
		}

		var beforeSpacerSize = Math.Max(0, _spacerBeforeSize);
		builder.OpenElement(0, SpacerElement);
		builder.AddAttribute(5, "class", "nt-virtualize-spacer");
		builder.AddAttribute(10, "style", GetBeforeSpacerStyle());
		builder.AddAttribute(20, "aria-hidden", "true");
		builder.AddElementReferenceCapture(3, elementReference => Element = elementReference);
		builder.AddContent(30, SpacerTemplate, new PlaceholderContext(_itemsBefore + 1, beforeSpacerSize));
		builder.CloseElement();

		var requestedLastItemIndex = _itemsBefore + _visibleItemCapacity;
		var lastItemIndex = _loading && _itemCount == 0 ? requestedLastItemIndex : Math.Min(requestedLastItemIndex, _itemCount);
		var preloadedPlaceholderCount = 0;
		if (!_loading && _itemCache.Count > 0) {
			preloadedPlaceholderCount = GetPreloadedPlaceholderCount(lastItemIndex);
		}

		var renderLastItemIndex = lastItemIndex + preloadedPlaceholderCount;

		_lastRenderedItemCount = 0;
		_lastRenderedPlaceholderCount = 0;

		if (!_loading && _itemCount == 0 && EmptyTemplate is not null) {
			builder.AddContent(40, EmptyTemplate);
		}
		else if (ItemTemplate is not null) {
			builder.OpenRegion(50);

			for (var renderIndex = _itemsBefore; renderIndex < renderLastItemIndex; renderIndex++) {
				if (_itemCache.TryGetValue(renderIndex, out var item)) {
					ItemTemplate(item)(builder);
					_lastRenderedItemCount++;
				}
				else {
					builder.AddContent(renderIndex, LoadingTemplate, new PlaceholderContext(renderIndex + 2, _itemSize));
					_lastRenderedPlaceholderCount++;
				}
			}

			builder.CloseRegion();
		}

		var afterSpacerSize = GetAdjustedSpacerAfterSize(preloadedPlaceholderCount);
		builder.OpenElement(70, SpacerElement);
		builder.AddAttribute(75, "class", "nt-virtualize-spacer");
		builder.AddAttribute(80, "aria-hidden", "true");
		builder.AddAttribute(90, "style", GetAfterSpacerStyle(preloadedPlaceholderCount));
		builder.AddContent(95, SpacerTemplate, new PlaceholderContext(renderLastItemIndex + 1, afterSpacerSize));
		builder.AddElementReferenceCapture(100, elementReference => _afterPlaceholder = elementReference);
		builder.CloseElement();
	}
}
