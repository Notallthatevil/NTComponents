@namespace NTComponents
@using NTComponents.Core
@inherits TnTPageScriptComponent<TnTMarkdownEditor>

<div class="@EditorContainerClass" style="@ElementStyle">
    <tnt-markdown-editor @attributes="AdditionalAttributes" @ref="Element">
        <textarea style="display:none;" />
        <div class="editor-value" style="display:none">@CurrentEditorValue</div>
    </tnt-markdown-editor>
    @if (ShowSupportingText) {
        <span class="tnt-supporting-text">
            @if (ValueExpression is not null) {
                <ValidationMessage For="@ValueExpression" class="tnt-components tnt-validation-message" />
            }
            @if (RenderedHtmlExpression is not null) {
                <ValidationMessage For="@RenderedHtmlExpression" class="tnt-components tnt-validation-message" />
            }
            @SupportingText
        </span>
    }
</div>

@PageScript
