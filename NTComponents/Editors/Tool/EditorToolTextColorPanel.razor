@namespace NTComponents
@using Microsoft.AspNetCore.Components

<div class="tnt-rich-text-editor-inline-tool tnt-rich-text-editor-text-color-editor"
     data-tool-command="textColor"
     data-role="text-color-editor"
     role="group"
     aria-label="Text color settings"
     hidden
     aria-hidden="true">
    <div class="tnt-rich-text-editor-inline-tool-fields">
        <NTInputColor Label="Text color"
                      @bind-Value="_textColor"
                      Appearance="NTFormAppearance.Outlined"
                      Density="NTFormDensity.Standard"
                      Disabled="@Disabled"
                      SubmitValue="false"
                      data-role="text-color-value" />
    </div>
    <div class="tnt-rich-text-editor-inline-tool-actions">
        <NTButton Label="Apply color"
                  ButtonSize="Size.Small"
                  Disabled="@Disabled"
                  Type="ButtonType.Button"
                  data-role="text-color-apply" />
        <NTButton Label="Cancel"
                  ButtonSize="Size.Small"
                  Disabled="@Disabled"
                  Type="ButtonType.Button"
                  Variant="NTButtonVariant.Text"
                  data-role="text-color-cancel" />
    </div>
</div>

@code {
    private string? _textColor;

    [Parameter]
    public bool Disabled { get; set; }
}
