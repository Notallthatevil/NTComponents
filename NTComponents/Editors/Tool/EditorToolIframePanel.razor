@namespace NTComponents
@using Microsoft.AspNetCore.Components

<div class="tnt-rich-text-editor-inline-tool tnt-rich-text-editor-iframe-editor"
     data-tool-command="iframe"
     data-role="iframe-editor"
     role="group"
     aria-label="Iframe settings"
     hidden
     aria-hidden="true">
    <div class="tnt-rich-text-editor-inline-tool-fields">
        <NTInputText Label="Iframe URL"
                     @bind-Value="_iframeUrl"
                     Appearance="NTFormAppearance.Outlined"
                     Density="NTFormDensity.Dense"
                     InputType="TextInputType.Url"
                     Placeholder="https://example.com/embed"
                     Disabled="@Disabled"
                     SubmitValue="false"
                     data-role="iframe-url" />
        <NTInputText Label="Title"
                     @bind-Value="_iframeTitle"
                     Appearance="NTFormAppearance.Outlined"
                     Density="NTFormDensity.Dense"
                     Placeholder="Embedded content"
                     Disabled="@Disabled"
                     SubmitValue="false"
                     data-role="iframe-title" />
        <NTInputText Label="Width"
                     @bind-Value="_iframeWidth"
                     Appearance="NTFormAppearance.Outlined"
                     Density="NTFormDensity.Dense"
                     Placeholder="100%"
                     Disabled="@Disabled"
                     SubmitValue="false"
                     data-role="iframe-width" />
        <NTInputText Label="Height"
                     @bind-Value="_iframeHeight"
                     Appearance="NTFormAppearance.Outlined"
                     Density="NTFormDensity.Dense"
                     Placeholder="315"
                     Disabled="@Disabled"
                     SubmitValue="false"
                     data-role="iframe-height" />
    </div>
    <div class="tnt-rich-text-editor-inline-tool-actions">
        <button type="button"
                class="tnt-rich-text-editor-toolbar-button"
                data-role="iframe-apply"
                disabled="@Disabled">
            Apply iframe
        </button>
        <button type="button"
                class="tnt-rich-text-editor-toolbar-button"
                data-role="iframe-cancel"
                disabled="@Disabled">
            Cancel
        </button>
    </div>
</div>

@code {
    private string? _iframeUrl;
    private string? _iframeTitle;
    private string? _iframeWidth;
    private string? _iframeHeight;

    [Parameter]
    public bool Disabled { get; set; }
}
