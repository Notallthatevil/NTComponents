@namespace NTComponents
@using Microsoft.AspNetCore.Components

<div class="tnt-rich-text-editor-inline-tool tnt-rich-text-editor-iframe-editor"
     data-tool-command="iframe"
     data-role="iframe-editor"
     role="group"
     aria-label="Iframe settings"
     hidden
     aria-hidden="true">
    <div class="tnt-rich-text-editor-inline-tool-fields">
        <label class="tnt-rich-text-editor-inline-tool-field">
            <span>Iframe URL</span>
            <input type="url"
                   data-role="iframe-url"
                   placeholder="https://example.com/embed"
                   disabled="@Disabled" />
        </label>
        <label class="tnt-rich-text-editor-inline-tool-field">
            <span>Title</span>
            <input type="text"
                   data-role="iframe-title"
                   placeholder="Embedded content"
                   disabled="@Disabled" />
        </label>
        <label class="tnt-rich-text-editor-inline-tool-field">
            <span>Width</span>
            <input type="text"
                   data-role="iframe-width"
                   placeholder="100%"
                   disabled="@Disabled" />
        </label>
        <label class="tnt-rich-text-editor-inline-tool-field">
            <span>Height</span>
            <input type="text"
                   data-role="iframe-height"
                   placeholder="315"
                   disabled="@Disabled" />
        </label>
    </div>
    <div class="tnt-rich-text-editor-inline-tool-actions">
        <button type="button"
                class="tnt-rich-text-editor-toolbar-button"
                data-role="iframe-apply"
                disabled="@Disabled">
            Apply iframe
        </button>
        <button type="button"
                class="tnt-rich-text-editor-toolbar-button"
                data-role="iframe-cancel"
                disabled="@Disabled">
            Cancel
        </button>
    </div>
</div>

@code {
    [Parameter]
    public bool Disabled { get; set; }
}
