@namespace NTComponents
@using Microsoft.AspNetCore.Components

<div class="tnt-rich-text-editor-inline-tool tnt-rich-text-editor-link-editor"
     data-tool-command="link"
     data-role="link-editor"
     role="group"
     aria-label="Link settings"
     hidden
     aria-hidden="true">
    <div class="tnt-rich-text-editor-inline-tool-fields">
        <NTInputText Label="Link URL"
                     @bind-Value="_linkUrl"
                     Appearance="NTFormAppearance.Outlined"
                     Density="NTFormDensity.Standard"
                     InputType="TextInputType.Url"
                     Placeholder="https://example.com"
                     Disabled="@Disabled"
                     SubmitValue="false"
                     data-role="link-url" />
        <NTInputText Label="Link text"
                     @bind-Value="_linkText"
                     Appearance="NTFormAppearance.Outlined"
                     Density="NTFormDensity.Standard"
                     Placeholder="Link text"
                     Disabled="@Disabled"
                     SubmitValue="false"
                     data-role="link-text" />
        <NTInputText Label="Accessible label"
                     @bind-Value="_linkAriaLabel"
                     Appearance="NTFormAppearance.Outlined"
                     Density="NTFormDensity.Standard"
                     Placeholder="Optional screen reader label"
                     Disabled="@Disabled"
                     SubmitValue="false"
                     data-role="link-aria-label" />
        <NTInputText Label="Title"
                     @bind-Value="_linkTitle"
                     Appearance="NTFormAppearance.Outlined"
                     Density="NTFormDensity.Standard"
                     Placeholder="Optional link title"
                     Disabled="@Disabled"
                     SubmitValue="false"
                     data-role="link-title" />
    </div>
    <div class="tnt-rich-text-editor-inline-tool-actions">
        <NTButton Label="Apply link"
                  ButtonSize="Size.Small"
                  Disabled="@Disabled"
                  Type="ButtonType.Button"
                  data-role="link-apply" />
        <NTButton Label="Cancel"
                  ButtonSize="Size.Small"
                  Disabled="@Disabled"
                  Type="ButtonType.Button"
                  Variant="NTButtonVariant.Text"
                  data-role="link-cancel" />
    </div>
</div>

@code {
    private string? _linkUrl;
    private string? _linkText;
    private string? _linkAriaLabel;
    private string? _linkTitle;

    [Parameter]
    public bool Disabled { get; set; }
}
