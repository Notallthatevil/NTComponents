@namespace NTComponents
@using Microsoft.AspNetCore.Components
@using Microsoft.AspNetCore.Components.Forms

<div class="tnt-rich-text-editor-inline-tool tnt-rich-text-editor-image-editor"
     data-tool-command="image"
     data-role="image-editor"
     role="group"
     aria-label="Image settings"
     hidden
     aria-hidden="true">
    <div class="tnt-rich-text-editor-inline-tool-fields">
        <NTInputText Label="Image URL"
                     @bind-Value="_imageUrl"
                     Appearance="NTFormAppearance.Outlined"
                     Density="NTFormDensity.Standard"
                     InputType="TextInputType.Url"
                     Placeholder="https://example.com/image.png"
                     Disabled="@Disabled"
                     SubmitValue="false"
                     data-role="image-url" />
        <NTFileUpload Label="Upload image"
                      Appearance="NTFormAppearance.Outlined"
                      Density="NTFormDensity.Standard"
                      @bind-Value="_imageFiles"
                      Accept="image/*"
                      EmptyText="No image selected"
                      ChooseButtonText="Choose image"
                      ShowUploadButton="false"
                      Disabled="@Disabled"
                      SubmitValue="false"
                      data-role="image-file" />
        <NTInputText Label="Alt text"
                     @bind-Value="_imageAlt"
                     Appearance="NTFormAppearance.Outlined"
                     Density="NTFormDensity.Standard"
                     Placeholder="Describe the image"
                     Disabled="@Disabled"
                     SubmitValue="false"
                     data-role="image-alt" />
        <NTInputText Label="Title"
                     @bind-Value="_imageTitle"
                     Appearance="NTFormAppearance.Outlined"
                     Density="NTFormDensity.Standard"
                     Placeholder="Optional image title"
                     Disabled="@Disabled"
                     SubmitValue="false"
                     data-role="image-title" />
        <NTInputNumeric TNumber="int"
                        Label="Width"
                        @bind-Value="_imageWidth"
                        Appearance="NTFormAppearance.Outlined"
                        Density="NTFormDensity.Standard"
                        Placeholder="Auto"
                        Disabled="@Disabled"
                        min="1"
                        step="1"
                        SubmitValue="false"
                        data-role="image-width" />
        <NTInputNumeric TNumber="int"
                        Label="Height"
                        @bind-Value="_imageHeight"
                        Appearance="NTFormAppearance.Outlined"
                        Density="NTFormDensity.Standard"
                        Placeholder="Auto"
                        Disabled="@Disabled"
                        min="1"
                        step="1"
                        SubmitValue="false"
                        data-role="image-height" />
    </div>
    <div class="tnt-rich-text-editor-inline-tool-actions">
        <NTButton Label="Insert image"
                  ButtonSize="Size.Small"
                  Disabled="@Disabled"
                  Type="ButtonType.Button"
                  data-role="image-apply" />
        <NTButton Label="Cancel"
                  ButtonSize="Size.Small"
                  Disabled="@Disabled"
                  Type="ButtonType.Button"
                  Variant="NTButtonVariant.Text"
                  data-role="image-cancel" />
    </div>
</div>

@code {
    private string? _imageUrl;
    private IReadOnlyList<IBrowserFile>? _imageFiles;
    private string? _imageAlt;
    private string? _imageTitle;
    private int? _imageWidth;
    private int? _imageHeight;

    [Parameter]
    public bool Disabled { get; set; }
}
