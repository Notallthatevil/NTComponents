@namespace NTComponents
@using Microsoft.AspNetCore.Components

<div class="tnt-rich-text-editor-inline-tool tnt-rich-text-editor-image-editor"
     data-tool-command="image"
     data-role="image-editor"
     hidden
     aria-hidden="true">
    <div class="tnt-rich-text-editor-inline-tool-fields">
        <label class="tnt-rich-text-editor-inline-tool-field">
            <span>Image URL</span>
            <input type="url"
                   data-role="image-url"
                   placeholder="https://example.com/image.png"
                   disabled="@Disabled" />
        </label>
        <label class="tnt-rich-text-editor-inline-tool-field">
            <span>Upload image</span>
            <input type="file"
                   data-role="image-file"
                   accept="image/*"
                   disabled="@Disabled" />
        </label>
        <label class="tnt-rich-text-editor-inline-tool-field">
            <span>Alt text</span>
            <input type="text"
                   data-role="image-alt"
                   placeholder="Describe the image"
                   disabled="@Disabled" />
        </label>
        <label class="tnt-rich-text-editor-inline-tool-field">
            <span>Width</span>
            <input type="number"
                   data-role="image-width"
                   min="1"
                   step="1"
                   placeholder="Auto"
                   disabled="@Disabled" />
        </label>
        <label class="tnt-rich-text-editor-inline-tool-field">
            <span>Height</span>
            <input type="number"
                   data-role="image-height"
                   min="1"
                   step="1"
                   placeholder="Auto"
                   disabled="@Disabled" />
        </label>
    </div>
    <div class="tnt-rich-text-editor-inline-tool-actions">
        <button type="button"
                class="tnt-rich-text-editor-toolbar-button"
                data-role="image-apply"
                disabled="@Disabled">
            Insert image
        </button>
        <button type="button"
                class="tnt-rich-text-editor-toolbar-button"
                data-role="image-cancel"
                disabled="@Disabled">
            Cancel
        </button>
    </div>
</div>

@code {
    [Parameter]
    public bool Disabled { get; set; }
}
