@namespace NTComponents
@using Microsoft.AspNetCore.Components

<div class="tnt-rich-text-editor-inline-tool tnt-rich-text-editor-table-editor"
     data-tool-command="table"
     data-role="table-editor"
     role="group"
     aria-label="Table settings"
     hidden
     aria-hidden="true">
    <div class="tnt-rich-text-editor-inline-tool-fields">
        <NTInputNumeric TNumber="int"
                        Label="Columns"
                        @bind-Value="_tableColumns"
                        Appearance="NTFormAppearance.Outlined"
                        Density="NTFormDensity.Dense"
                        Disabled="@Disabled"
                        min="1"
                        max="8"
                        step="1"
                        SubmitValue="false"
                        data-role="table-columns" />
        <NTInputNumeric TNumber="int"
                        Label="Rows"
                        @bind-Value="_tableRows"
                        Appearance="NTFormAppearance.Outlined"
                        Density="NTFormDensity.Dense"
                        Disabled="@Disabled"
                        min="1"
                        max="12"
                        step="1"
                        SubmitValue="false"
                        data-role="table-rows" />
        <NTInputColor Label="Border color"
                      @bind-Value="_tableBorderColor"
                      Appearance="NTFormAppearance.Outlined"
                      Density="NTFormDensity.Dense"
                      Disabled="@Disabled"
                      SubmitValue="false"
                      data-role="table-border-color" />
    </div>
    <div class="tnt-rich-text-editor-inline-tool-actions">
        <button type="button"
                class="tnt-rich-text-editor-toolbar-button"
                data-role="table-apply"
                disabled="@Disabled">
            Apply table
        </button>
        <button type="button"
                class="tnt-rich-text-editor-toolbar-button"
                data-role="table-cancel"
                disabled="@Disabled">
            Cancel
        </button>
    </div>
</div>

@code {
    private int? _tableColumns;
    private int? _tableRows;
    private string? _tableBorderColor;

    [Parameter]
    public bool Disabled { get; set; }
}
