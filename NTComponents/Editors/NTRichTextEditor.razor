@namespace NTComponents
@inherits TnTInputBase<string?>
@implements NTComponents.Interfaces.ITnTPageScriptComponent<NTRichTextEditor>

<div class="tnt-input-container" style="@ElementStyle">
	<nt-rich-text-editor @attributes="EditorAttributes"
	                     class="@ElementClass"
	                     data-bind-on-input="@(BindOnInput.ToString().ToLowerInvariant())"
	                     data-editable="@((!FieldDisabled && !FieldReadonly).ToString().ToLowerInvariant())"
	                     title="@ElementTitle"
	                     lang="@ElementLang"
	                     id="@ElementId"
	                     @ref="Element">
		@if (StartIcon is not null) {
			@StartIcon.Render("tnt-start-icon")
		}

		<div class="tnt-rich-text-editor-shell">
			<input type="hidden"
			       class="tnt-rich-text-editor-hidden-input"
			       name="@ElementName"
			       value="@CurrentValueAsString" />

			<div class="tnt-rich-text-editor-value" hidden>@CurrentValueAsString</div>

			<div class="tnt-rich-text-editor-toolbar" role="toolbar" aria-label="Text formatting">
				<button type="button"
				        class="tnt-rich-text-editor-toolbar-button"
				        data-command="undo"
				        aria-label="Undo"
				        title="Undo (Ctrl+Z)"
				        aria-pressed="false"
				        disabled="@(FieldDisabled || FieldReadonly)">
					↶
				</button>
				<button type="button"
				        class="tnt-rich-text-editor-toolbar-button"
				        data-command="redo"
				        aria-label="Redo"
				        title="Redo (Ctrl+Y)"
				        aria-pressed="false"
				        disabled="@(FieldDisabled || FieldReadonly)">
					↷
				</button>
				<span class="tnt-rich-text-editor-toolbar-divider" aria-hidden="true"></span>
				<button type="button"
				        class="tnt-rich-text-editor-toolbar-button"
				        data-command="paragraph"
				        aria-label="Paragraph"
				        title="Paragraph (Ctrl+Alt+0)"
				        aria-pressed="false"
				        disabled="@(FieldDisabled || FieldReadonly)">
					¶
				</button>
				<button type="button"
				        class="tnt-rich-text-editor-toolbar-button"
				        data-command="heading"
				        data-value="1"
				        aria-label="Heading 1"
				        title="Heading 1 (Ctrl+Alt+1)"
				        aria-pressed="false"
				        disabled="@(FieldDisabled || FieldReadonly)">
					H1
				</button>
				<button type="button"
				        class="tnt-rich-text-editor-toolbar-button"
				        data-command="heading"
				        data-value="2"
				        aria-label="Heading 2"
				        title="Heading 2 (Ctrl+Alt+2)"
				        aria-pressed="false"
				        disabled="@(FieldDisabled || FieldReadonly)">
					H2
				</button>
				<button type="button"
				        class="tnt-rich-text-editor-toolbar-button"
				        data-command="heading"
				        data-value="3"
				        aria-label="Heading 3"
				        title="Heading 3 (Ctrl+Alt+3)"
				        aria-pressed="false"
				        disabled="@(FieldDisabled || FieldReadonly)">
					H3
				</button>
				<button type="button"
				        class="tnt-rich-text-editor-toolbar-button"
				        data-command="heading"
				        data-value="4"
				        aria-label="Heading 4"
				        title="Heading 4 (Ctrl+Alt+4)"
				        aria-pressed="false"
				        disabled="@(FieldDisabled || FieldReadonly)">
					H4
				</button>
				<button type="button"
				        class="tnt-rich-text-editor-toolbar-button"
				        data-command="heading"
				        data-value="5"
				        aria-label="Heading 5"
				        title="Heading 5 (Ctrl+Alt+5)"
				        aria-pressed="false"
				        disabled="@(FieldDisabled || FieldReadonly)">
					H5
				</button>
				<button type="button"
				        class="tnt-rich-text-editor-toolbar-button"
				        data-command="heading"
				        data-value="6"
				        aria-label="Heading 6"
				        title="Heading 6 (Ctrl+Alt+6)"
				        aria-pressed="false"
				        disabled="@(FieldDisabled || FieldReadonly)">
					H6
				</button>
				<span class="tnt-rich-text-editor-toolbar-divider" aria-hidden="true"></span>
				<button type="button"
				        class="tnt-rich-text-editor-toolbar-button"
				        data-command="alignLeft"
				        aria-label="Align left"
				        title="Align Left (Ctrl+Shift+L)"
				        aria-pressed="false"
				        disabled="@(FieldDisabled || FieldReadonly)">
					≡←
				</button>
				<button type="button"
				        class="tnt-rich-text-editor-toolbar-button"
				        data-command="alignCenter"
				        aria-label="Align center"
				        title="Align Center (Ctrl+Shift+E)"
				        aria-pressed="false"
				        disabled="@(FieldDisabled || FieldReadonly)">
					≡↔
				</button>
				<button type="button"
				        class="tnt-rich-text-editor-toolbar-button"
				        data-command="alignRight"
				        aria-label="Align right"
				        title="Align Right (Ctrl+Shift+R)"
				        aria-pressed="false"
				        disabled="@(FieldDisabled || FieldReadonly)">
					→≡
				</button>
				<button type="button"
				        class="tnt-rich-text-editor-toolbar-button"
				        data-command="alignJustify"
				        aria-label="Justify"
				        title="Justify (Ctrl+Shift+J)"
				        aria-pressed="false"
				        disabled="@(FieldDisabled || FieldReadonly)">
					≣
				</button>
				<span class="tnt-rich-text-editor-toolbar-divider" aria-hidden="true"></span>
				<button type="button"
				        class="tnt-rich-text-editor-toolbar-button"
				        data-command="unorderedList"
				        aria-label="Bulleted list"
				        title="Bulleted List (Ctrl+Alt+7)"
				        aria-pressed="false"
				        disabled="@(FieldDisabled || FieldReadonly)">
					•
				</button>
				<button type="button"
				        class="tnt-rich-text-editor-toolbar-button"
				        data-command="orderedList"
				        aria-label="Numbered list"
				        title="Numbered List (Ctrl+Alt+8)"
				        aria-pressed="false"
				        disabled="@(FieldDisabled || FieldReadonly)">
					1.
				</button>
				<button type="button"
				        class="tnt-rich-text-editor-toolbar-button"
				        data-command="blockquote"
				        aria-label="Quote block"
				        title="Quote Block (Ctrl+Alt+Q)"
				        aria-pressed="false"
				        disabled="@(FieldDisabled || FieldReadonly)">
					❝
				</button>
				<button type="button"
				        class="tnt-rich-text-editor-toolbar-button"
				        data-command="codeBlock"
				        aria-label="Code block"
				        title="Code Block (Ctrl+Alt+C)"
				        aria-pressed="false"
				        disabled="@(FieldDisabled || FieldReadonly)">
					&lt;/&gt;
				</button>
				<button type="button"
				        class="tnt-rich-text-editor-toolbar-button"
				        data-command="table"
				        aria-label="Insert table"
				        title="Insert Table (Ctrl+Alt+T)"
				        aria-pressed="false"
				        disabled="@(FieldDisabled || FieldReadonly)">
					▦
				</button>
				<span class="tnt-rich-text-editor-toolbar-divider" aria-hidden="true"></span>
				<button type="button"
				        class="tnt-rich-text-editor-toolbar-button"
				        data-command="bold"
				        aria-label="Bold"
				        title="Bold (Ctrl+B)"
				        aria-pressed="false"
				        disabled="@(FieldDisabled || FieldReadonly)">
					<strong>B</strong>
				</button>
				<button type="button"
				        class="tnt-rich-text-editor-toolbar-button"
				        data-command="italic"
				        aria-label="Italic"
				        title="Italic (Ctrl+I)"
				        aria-pressed="false"
				        disabled="@(FieldDisabled || FieldReadonly)">
					<em>I</em>
				</button>
				<button type="button"
				        class="tnt-rich-text-editor-toolbar-button"
				        data-command="underline"
				        aria-label="Underline"
				        title="Underline (Ctrl+U)"
				        aria-pressed="false"
				        disabled="@(FieldDisabled || FieldReadonly)">
					<u>U</u>
				</button>
				<button type="button"
				        class="tnt-rich-text-editor-toolbar-button"
				        data-command="strikeThrough"
				        aria-label="Strikethrough"
				        title="Strikethrough (Ctrl+Shift+S)"
				        aria-pressed="false"
				        disabled="@(FieldDisabled || FieldReadonly)">
					<s>S</s>
				</button>
				<button type="button"
				        class="tnt-rich-text-editor-toolbar-button"
				        data-command="textColor"
				        aria-label="Text color"
				        title="Text Color (Ctrl+Alt+X)"
				        aria-pressed="false"
				        disabled="@(FieldDisabled || FieldReadonly)">
					A
				</button>
				<button type="button"
				        class="tnt-rich-text-editor-toolbar-button"
				        data-command="link"
				        aria-label="Insert link"
				        title="Insert Link (Ctrl+K)"
				        aria-pressed="false"
				        disabled="@(FieldDisabled || FieldReadonly)">
					LINK
				</button>
				<span class="tnt-rich-text-editor-toolbar-divider" aria-hidden="true"></span>
				<button type="button"
				        class="tnt-rich-text-editor-toolbar-button"
				        data-command="image"
				        aria-label="Insert image"
				        title="Insert Image (Ctrl+Alt+M)"
				        aria-pressed="false"
				        disabled="@(FieldDisabled || FieldReadonly)">
					IMG
				</button>
				<button type="button"
				        class="tnt-rich-text-editor-toolbar-button"
				        data-command="iframe"
				        aria-label="Insert iframe"
				        title="Insert Iframe (Ctrl+Alt+F)"
				        aria-pressed="false"
				        disabled="@(FieldDisabled || FieldReadonly)">
					⧉
				</button>
			</div>

			<div class="tnt-rich-text-editor-surface"
			     data-role="surface"
			     data-placeholder="@(string.IsNullOrWhiteSpace(Placeholder) ? "Start typing" : Placeholder)"
			     data-empty="@EditorEmptyAttribute"
			     data-maxlength="@GetMaxLength()"
			     contenteditable="@ContentEditableAttribute"
			     tabindex="@(FieldDisabled ? "-1" : "0")"
			     role="textbox"
			     aria-multiline="true"
			     aria-label="@AriaLabel"
			     spellcheck="true"
			     onkeydown="NTComponents.stopEnterPropagation(event)">
				@((MarkupString)_renderedHtml)
			</div>
		</div>

		@if (!string.IsNullOrWhiteSpace(Label)) {
			<span class="tnt-label">
				@Label
			</span>
		}

		@if (EndIcon is not null) {
			@EndIcon.Render("tnt-end-icon")
		}
	</nt-rich-text-editor>

	@if (Tooltip is not null) {
		@TooltipIcon.Render()
	}

	@if (!string.IsNullOrWhiteSpace(SupportingText) || !string.IsNullOrWhiteSpace(ErrorMessage) || (EditContext is not null && !DisableValidationMessage && ValueExpression is not null)) {
		<span class="tnt-supporting-text">
			@if (!string.IsNullOrWhiteSpace(ErrorMessage)) {
				<div class="tnt-components tnt-validation-message">@ErrorMessage</div>
			}
			else if (EditContext is not null && !DisableValidationMessage && ValueExpression is not null) {
				<ValidationMessage TValue="@(string)" For="@ValueExpression" class="tnt-components tnt-validation-message" />
			}
			@SupportingText
		</span>
	}

	@if (GetMaxLength() > 0 && ShowInputLength) {
		<span class="tnt-input-length">@EditorLengthText</span>
	}
</div>

@PageScript
