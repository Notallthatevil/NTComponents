@namespace NTComponents
@using NTComponents.Interfaces
@inherits NTInputBase<string?>
@implements NTComponents.Interfaces.INTPageScriptComponent<NTRichTextEditor>

@{
    var errorText = CurrentErrorText;
    var hasErrorText = !string.IsNullOrWhiteSpace(errorText);
    var supportingText = hasErrorText ? null : CurrentSupportingText;
    var hasSupportingText = !string.IsNullOrWhiteSpace(supportingText);
    var describedBy = BuildDescribedBy(hasErrorText, !hasErrorText && hasSupportingText);
}

<div class="@GetRootClass(hasErrorText)" style="@ElementStyle">
    <div class="nt-input-container-overflow">
	    <nt-rich-text-editor @attributes="ControlAttributes"
	                         class="nt-input-container"
	                         data-bind-on-input="@(BindOnInput.ToString().ToLowerInvariant())"
	                         data-editable="@((!FieldDisabled && !FieldReadOnly).ToString().ToLowerInvariant())"
	                         title="@ElementTitle"
	                         lang="@ElementLang"
	                         @ref="_editorElement">
            <span class="nt-input-background" aria-hidden="true"></span>
            <span class="nt-input-state-layer" aria-hidden="true"></span>

            @if (EffectiveAppearance == NTFormAppearance.Filled) {
                <span class="nt-input-active-indicator" aria-hidden="true"></span>
            }

            @if (EffectiveAppearance == NTFormAppearance.Outlined) {
                <span class="nt-input-outline" aria-hidden="true">
                    <span class="nt-input-outline-start"></span>
                    <span class="nt-input-outline-notch">
                        @if (HasLabel) {
                            <span class="nt-input-outline-label">@Label</span>
                        }
                    </span>
                    <span class="nt-input-outline-end"></span>
                </span>
            }

            <span class="nt-input-field">
                @if (LeadingIcon is not null) {
                    <span class="nt-input-leading" aria-hidden="true">
                        @LeadingIcon.Render()
                    </span>
                }

                @if (!string.IsNullOrWhiteSpace(PrefixText)) {
                    <span class="nt-input-prefix" id="@PrefixId">@PrefixText</span>
                }

                <span class="nt-input-control-container">
                    <span class="tnt-rich-text-editor-shell">
			            @if (ShouldRenderFormPostValue) {
                            <input type="hidden"
			                       id="@FormPostInputId"
			                       class="tnt-rich-text-editor-hidden-input"
			                       name="@ElementName"
			                       value="@FormPostValue" />
                        }

			            <span class="tnt-rich-text-editor-value" hidden>@CurrentValueAsString</span>

			            <span class="tnt-rich-text-editor-toolbar" role="toolbar" aria-label="Text formatting">
				            @foreach (var toolbarButton in ToolbarButtons ?? NTRichTextEditor.DefaultToolbarButtons) {
					            if (toolbarButton.IsDivider) {
						            <span class="@GetToolbarDividerClass(toolbarButton)" aria-hidden="true"></span>
					            }
					            else {
						            <button type="button"
						                    class="@GetToolbarButtonClass(toolbarButton)"
						                    data-command="@toolbarButton.Action"
						                    data-value="@toolbarButton.Value"
						                    aria-label="@GetToolbarButtonAriaLabel(toolbarButton)"
						                    aria-keyshortcuts="@GetToolbarButtonAriaKeyShortcuts(toolbarButton)"
						                    title="@GetToolbarButtonTitle(toolbarButton)"
						                    aria-pressed="false"
						                    disabled="@(FieldDisabled || FieldReadOnly)">
							            @if (toolbarButton.Icon is not null) {
								            @toolbarButton.Icon.Render("tnt-rich-text-editor-toolbar-icon", suppressTitle: true)
							            }
							            @if (!string.IsNullOrWhiteSpace(toolbarButton.Text)) {
								            <span class="tnt-rich-text-editor-toolbar-button-text">@toolbarButton.Text</span>
							            }
						            </button>
					            }
				            }
			            </span>

			            @foreach (var tool in _activeToolsToRender) {
				            if (tool.PanelTemplate is not null) {
					            @tool.PanelTemplate(FieldDisabled || FieldReadOnly)
				            }
			            }

			            <span id="@InputId"
			                  class="tnt-rich-text-editor-surface nt-input-control"
			                  data-role="surface"
			                  data-placeholder="@RichTextPlaceholder"
			                  data-empty="@string.IsNullOrWhiteSpace(CurrentValueAsString).ToString().ToLowerInvariant()"
			                  data-maxlength="@MaxLength"
			                  contenteditable="@((!FieldDisabled && !FieldReadOnly).ToString().ToLowerInvariant())"
			                  tabindex="@(FieldDisabled ? "-1" : "0")"
			                  role="textbox"
			                  aria-multiline="true"
			                  aria-label="@(!HasLabel ? RichTextAriaLabel : null)"
			                  aria-labelledby="@(HasLabel ? LabelId : null)"
			                  aria-describedby="@describedBy"
			                  aria-invalid="@(hasErrorText ? "true" : "false")"
			                  aria-errormessage="@(hasErrorText ? ErrorTextId : null)"
			                  spellcheck="true"
			                  onkeydown="NTComponents.stopEnterPropagation(event)"
			                  @ref="Element"></span>
                    </span>

                    @if (HasLabel) {
                        <span class="nt-input-label" id="@LabelId">@Label</span>
                    }
                </span>

                @if (!string.IsNullOrWhiteSpace(SuffixText)) {
                    <span class="nt-input-suffix" id="@SuffixId">@SuffixText</span>
                }

                @{
                    var trailingAdornment = CreateTrailingAdornmentState(hasErrorText);
                }

                @if (trailingAdornment.Icon is not null) {
                    <span class="@trailingAdornment.Class" aria-label="@trailingAdornment.AriaLabel" aria-hidden="@trailingAdornment.AriaHidden">
                        @trailingAdornment.Icon.Render()
                    </span>
                }
            </span>
	    </nt-rich-text-editor>
    </div>

    @if (Tooltip is not null) {
        @TooltipIcon.Render("tnt-tooltip-icon")
    }

    @if (hasErrorText || hasSupportingText || HasSupportingRowContent) {
        <div class="nt-input-supporting-row">
            @if (hasErrorText) {
                <span class="nt-input-supporting nt-input-error-text" id="@ErrorTextId" role="alert">
                    @errorText
                </span>
            }
            else if (hasSupportingText) {
                <span class="nt-input-supporting" id="@SupportingTextId">
                    @supportingText
                </span>
            }

            @if (ShowCounter) {
                <span class="nt-input-counter" id="@CounterId" aria-label="@CounterAriaLabel">
                    @CounterText
                </span>
            }
        </div>
    }
</div>

@PageScript
