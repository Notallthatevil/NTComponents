@namespace NTComponents
@using NTComponents.Core
@inherits NTPageScriptComponent<NTDialog>

<dialog @ref="Element"
        @attributes="AdditionalAttributes"
        id="@ResolvedElementId"
        class="@ElementClass"
        style="@ElementStyle"
        title="@ElementTitle"
        lang="@ElementLang"
        autofocus="@AutoFocus"
        aria-labelledby="@TitleId"
        aria-describedby="@SupportingTextId"
        data-nt-dialog="true"
        data-nt-dialog-close-on-backdrop="@CloseOnBackdropAttribute"
        data-nt-dialog-close-on-escape="@CloseOnEscapeAttribute"
        open="@OpenAttribute">
    @if (Icon is not null) {
        <div class="nt-dialog-icon" aria-hidden="true">
            @Icon
        </div>
    }

    @if (ShouldRenderTitle || ShowCloseButton) {
        <header class="nt-dialog-header">
            @if (ShouldRenderTitle) {
                <h2 id="@TitleId" class="nt-dialog-title">
                    @if (TitleContent is not null && ShouldRenderChildContent) {
                        @TitleContent(_dialogParameters)
                    }
                    else {
                        @Title
                    }
                </h2>
            }

            @if (ShowCloseButton) {
                <button type="button" class="nt-dialog-icon-button" command="request-close" commandfor="@ResolvedElementId" aria-label="@CloseButtonAriaLabel">
                    <span class="material-symbols-sharp" aria-hidden="true">close</span>
                </button>
            }
        </header>
    }

    @if (!string.IsNullOrWhiteSpace(SupportingText) || (ChildContent is not null && ShouldRenderChildContent)) {
        <div @key="_childContentRenderKey" class="nt-dialog-content">
            @if (!string.IsNullOrWhiteSpace(SupportingText)) {
                <p id="@SupportingTextId" class="nt-dialog-supporting-text">@SupportingText</p>
            }
            @if (ChildContent is not null && ShouldRenderChildContent) {
                @ChildContent(_dialogParameters)
            }
        </div>
    }

    <footer class="@ActionsClass">
        @if(Buttons is not null) {
            @Buttons(_dialogParameters)
        }
        else {
            @DefaultButtons
        }
    </footer>
</dialog>
@PageScript
