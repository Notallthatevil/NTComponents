@namespace NTComponents
@using NTComponents.Core
@inherits TnTComponentBase

<div @attributes="AdditionalAttributes"
     class="@ElementClass"
     style="@ElementStyle"
     title="@ElementTitle"
     lang="@ElementLang"
     role="separator"
     aria-orientation="@(Direction == LayoutDirection.Vertical ? "vertical" : "horizontal")"
     autofocus="@AutoFocus"
     id="@ElementId">
</div>
