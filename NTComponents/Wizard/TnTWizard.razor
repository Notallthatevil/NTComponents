@using Microsoft.AspNetCore.Components.Rendering
@using NTComponents.Core
@using NTComponents.Wizard
@namespace NTComponents
@inherits TnTComponentBase

<div @attributes="AdditionalAttributes" class="@ElementClass" style="@ElementStyle" id="@ElementId" title="@ElementTitle" @ref="Element">
	@if (!string.IsNullOrWhiteSpace(Title)) {
		<h1 class="tnt-wizard-title">
			@Title
		</h1>
	}
	<ol class="tnt-wizard-steps">
		@foreach (var (step, i) in _steps.Select((s, i) => new KeyValuePair<TnTWizardStepBase, int>(s, i))) {
			<li class="@($"tnt-wizard-step-indicator{(_stepIndex == i ? " current-step" : string.Empty)}{(_stepIndex != i && IsStepVisited(i) ? " completed-step" : string.Empty)}{(IsImmediateNextStep(i) ? " next-step" : string.Empty)}")" @onclick="@(() => NavigateToStepAsync(i))">
				<div class="tnt-wizard-step-title">
					<span class="tnt-wizard-step-index">
						@(i + 1)
					</span>
					@step.Icon?.Render()
					@(step.Title ?? $"Step {i + 1}")
				</div>
				@if (!string.IsNullOrWhiteSpace(step.SubTitle)) {
					<div class="tnt-wizard-step-subtitle">
						@step.SubTitle
					</div>
				}
			</li>
		}
	</ol>
	@if (HideStepsInsteadOfRemovingFromDom) {
		@foreach (var step in _steps) {
			var stepClass = step == _currentStep ? "tnt-wizard-current-step" : "tnt-wizard-hidden-step";
			var hiddenStyle = step == _currentStep ? string.Empty : "display:none;";
			<div @key="step" class="@stepClass" style="@hiddenStyle">
				@if (step is not null) {
					@step.Render()
				}
			</div>
		}
	}
	else {
		<div class="tnt-wizard-content" @onkeypress="HandleKeyPressAsync">
			@if (_currentStep is not null) {
				@_currentStep.Render()
			}
			else {
				<text>No step provided</text>
			}
		</div>
	}
	<div class="tnt-wizard-buttons">
		@if (_stepIndex > 0) {
			<TnTButton Appearance="ButtonAppearance.Outlined" TextColor="TnTColor.OnSurface" OnClickCallback="@PreviousStepAsync" Disabled="@PreviousButtonDisabled">
				<MaterialIcon Icon="@MaterialIcon.KeyboardArrowLeft" />
				Previous Step
			</TnTButton>
		}
		@if (_stepIndex + 1 == _steps.Count) {
			<TnTButton OnClickCallback="@SubmitClickedAsync" BackgroundColor="TnTColor.Success" TextColor="TnTColor.OnSuccess" TintColor="TnTColor.SuccessContainer" class="@ProgressButtonInvalidClass" Disabled="@EffectiveSubmitButtonDisabled">
				Submit
			</TnTButton>
		}
		else {
			<TnTButton OnClickCallback="@NextStepAsync" class="@ProgressButtonInvalidClass" Disabled="@EffectiveNextButtonDisabled">
				Next Step
				<MaterialIcon Icon="@MaterialIcon.KeyboardArrowRight" />
			</TnTButton>
		}
	</div>
	<CascadingValue Value="this" IsFixed="true">
		@ChildContent
	</CascadingValue>
</div>
