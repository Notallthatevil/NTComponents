@namespace NTComponents

<style class="nt-measurements">
:root{--tnt-header-height:@($"{HeaderHeight}px;");--tnt-footer-height:@($"{FooterHeight}px;");--tnt-side-nav-width:@($"{SideNavWidth}px;");}
</style>
<style class="nt-fonts">
body{padding:0;margin:0;}.nt-display-large,.tnt-display-large{font-family:Roboto;font-weight:400;font-size:57px;line-height:64px;letter-spacing:-0.25px;}.nt-display-medium,.tnt-display-medium{font-family:Roboto;font-weight:400;font-size:45px;line-height:52px;letter-spacing:0px;}.nt-display-small,.tnt-display-small{font-family:Roboto;font-weight:400;font-size:36px;line-height:44px;letter-spacing:0px;}.nt-headline-large,.tnt-headline-large{font-family:Roboto;font-weight:400;font-size:32px;line-height:40px;letter-spacing:0px;}.nt-headline-medium,.tnt-headline-medium{font-family:Roboto;font-weight:400;font-size:28px;line-height:36px;letter-spacing:0px;}.nt-headline-small,.tnt-headline-small{font-family:Roboto;font-weight:400;font-size:24px;line-height:32px;letter-spacing:0px;}.nt-body-large,.tnt-body-large{font-family:Roboto;font-weight:400;font-size:16px;line-height:24px;letter-spacing:0.50px;}.nt-body-medium,.tnt-body-medium{font-family:Roboto;font-weight:400;font-size:14px;line-height:20px;letter-spacing:0.25px;}.nt-body-small,.tnt-body-small{font-family:Roboto;font-weight:400;font-size:12px;line-height:16px;letter-spacing:0.40px;}.nt-label-large,.tnt-label-large{font-family:Roboto;font-weight:500;font-size:14px;line-height:20px;letter-spacing:0.10px;}.nt-label-medium,.tnt-label-medium{font-family:Roboto;font-weight:500;font-size:12px;line-height:16px;letter-spacing:0.50px;}.nt-label-small,.tnt-label-small{font-family:Roboto;font-weight:500;font-size:11px;line-height:16px;letter-spacing:0.50px;}.nt-title-large,.tnt-title-large{font-family:Roboto;font-weight:400;font-size:22px;line-height:28px;letter-spacing:0px;}.nt-title-medium,.tnt-title-medium{font-family:Roboto;font-weight:500;font-size:18px;line-height:24px;letter-spacing:0.15px;}.nt-title-small,.tnt-title-small{font-family:Roboto;font-weight:500;font-size:14px;line-height:20px;letter-spacing:0.10px;}
</style>
<style class="nt-elevations">
.nt-elevation-0{box-shadow:none;}.nt-elevation-1{box-shadow:0px 1px 2px var(--tnt-color-shadow);}.nt-elevation-2{box-shadow:0px 2px 3px var(--tnt-color-shadow);}.nt-elevation-3{box-shadow:0px 4px 8px 3px var(--tnt-color-shadow);}.nt-elevation-4{box-shadow:0px 6px 10px 4px var(--tnt-color-shadow);}.nt-elevation-5{box-shadow:0px 8px 12px 6px var(--tnt-color-shadow);}.nt-elevation-6{box-shadow:0px 12px 16px 6px var(--tnt-color-shadow);}.nt-elevation-7{box-shadow:0px 16px 20px 6px var(--tnt-color-shadow);}.nt-elevation-8{box-shadow:0px 20px 24px 6px var(--tnt-color-shadow);}.nt-elevation-9{box-shadow:0px 24px 28px 6px var(--tnt-color-shadow);}.nt-elevation-10{box-shadow:0px 28px 32px 6px var(--tnt-color-shadow);}
</style>
