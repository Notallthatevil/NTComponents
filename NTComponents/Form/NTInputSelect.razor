@namespace NTComponents
@using Microsoft.AspNetCore.Components.Rendering
@typeparam TInputType
@inherits TnTInputBase<TInputType>

<div class="tnt-input-container" style="@ElementStyle">
	<CascadingValue Value="this" IsFixed="true">
		<div class="tnt-input-select-search" onkeypress="NTComponents.stopEnter(event)" @ref="Element">
			@ChildContent

			<label class="@ElementClass" title="@ElementTitle" lang="@ElementLang" id="@ElementId">
				@if (StartIcon is not null) {
					@StartIcon.Render("tnt-start-icon")
				}

				<input type="text"
					   @attributes="SearchInputAttributes"
					   title="@FieldIdentifier.FieldName"
					   autofocus="@AutoFocus"
					   autocomplete="@AutoComplete"
					   readonly="@FieldReadonly"
					   placeholder="@(string.IsNullOrWhiteSpace(Placeholder) ? " " : Placeholder)"
					   disabled="@FieldDisabled"
					   required="@IsRequired()"
					   data-require-selection="@((IsRequired() && !AllowFreeform) ? "true" : "false")"
					   class="tnt-input-select-search-input"
					   value="@_searchText"
					   @oninput="OnInputChangedAsync"
					   @onfocus="OpenDropdownAsync"
					   @onkeyup="HandleKeyUpAsync"
					   @onblur="OnBlurAsync"
					   @ref="_searchInputElement" />

				<input type="hidden" name="@ElementName" value="@HiddenValue" />

				@if (!string.IsNullOrWhiteSpace(Label)) {
					<span class="tnt-label">
						@Label
					</span>
				}

				@if (EndIcon is not null) {
					@EndIcon.Render("tnt-end-icon")
				}
			</label>

			@if (_isOpen) {
				<div class="tnt-input-select-search-content">
					@if (_filteredOptions.Count > 0) {
						<ul class="tnt-input-select-search-list">
							@for (var index = 0; index < _filteredOptions.Count; index++) {
								var option = _filteredOptions[index];
								<li class="@(index == _focusedOptionIndex ? "tnt-input-select-search-list-item tnt-focused" : "tnt-input-select-search-list-item")"
									tabindex="-1"
									@onmousedown:preventDefault="true"
									@onclick="(() => SelectOptionAsync(option))">
									@if (option.ChildContent is not null) {
										@option.ChildContent
									}
									else {
										<span class="tnt-corner-radius-5 tnt-body-medium">
											@option.Text
										</span>
									}
								</li>
							}
						</ul>
					}
					else {
						<div class="tnt-input-select-search-no-results">
							@NoResultsText
						</div>
					}
				</div>
			}
		</div>
	</CascadingValue>

	@if (Tooltip is not null) {
		@TooltipIcon.Render()
	}

	@if (!string.IsNullOrWhiteSpace(SupportingText) || (EditContext is not null && !DisableValidationMessage && ValueExpression is not null)) {
		<span class="tnt-supporting-text">
			@if (EditContext is not null && !DisableValidationMessage && ValueExpression is not null) {
				<ValidationMessage TValue="@TInputType" For="@ValueExpression" class="tnt-components tnt-validation-message" />
			}
			@SupportingText
		</span>
	}
</div>

@PageScript
