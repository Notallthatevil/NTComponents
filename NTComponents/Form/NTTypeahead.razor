@namespace NTComponents
@using Microsoft.AspNetCore.Components.Rendering
@typeparam TItem
@inherits NTFieldBase<TItem?>

@{
    var errorText = CurrentErrorText;
    var hasErrorText = !string.IsNullOrWhiteSpace(errorText);
}

<div class="@GetRootClass()" style="@ElementStyle">
    @{
        var supportingText = hasErrorText ? null : CurrentSupportingText;
        var hasSupportingText = !string.IsNullOrWhiteSpace(supportingText);
        var listboxId = ListboxId;
    }

    <div class="nt-input-container-overflow">
        <label class="nt-input-container" for="@InputId" title="@ElementTitle" lang="@ElementLang">
            <span class="nt-input-background" aria-hidden="true"></span>
            <span class="nt-input-state-layer" aria-hidden="true"></span>

            @if (EffectiveAppearance == NTFormAppearance.Filled) {
                <span class="nt-input-active-indicator" aria-hidden="true"></span>
            }

            @if (EffectiveAppearance == NTFormAppearance.Outlined) {
                <span class="nt-input-outline" aria-hidden="true">
                    <span class="nt-input-outline-start"></span>
                    <span class="nt-input-outline-notch">
                        @if (HasLabel) {
                            <span class="nt-input-outline-label">@Label</span>
                        }
                    </span>
                    <span class="nt-input-outline-end"></span>
                </span>
            }

            <span class="nt-input-field">
                @if (LeadingIcon is not null) {
                    <span class="nt-input-leading" aria-hidden="true">
                        @LeadingIcon.Render()
                    </span>
                }

                @if (!string.IsNullOrWhiteSpace(PrefixText)) {
                    <span class="nt-input-prefix" id="@PrefixId">@PrefixText</span>
                }

                <span class="nt-input-control-container">
                    <input @attributes="ControlAttributes"
                           id="@InputId"
                           type="search"
                           title="@FieldIdentifier.FieldName"
                           autofocus="@AutoFocus"
                           autocomplete="@AutoComplete"
                           readonly="@FieldReadOnly"
                           disabled="@FieldDisabled"
                           required="@IsRequired"
                           placeholder="@EffectivePlaceholder"
                           aria-describedby="@BuildDescribedBy(hasErrorText, hasSupportingText)"
                           aria-invalid="@(hasErrorText ? "true" : "false")"
                           aria-errormessage="@(hasErrorText ? ErrorTextId : null)"
                           aria-autocomplete="list"
                           aria-controls="@listboxId"
                           aria-expanded="@(_isOpen ? "true" : "false")"
                           aria-haspopup="listbox"
                           aria-activedescendant="@ActiveDescendantId"
                           role="combobox"
                           class="@TypeaheadControlClass"
                           value="@_searchText"
                           data-nt-typeahead-input="true"
                           @oninput="OnInputAsync"
                           @onfocus="OnFocusAsync"
                           @onkeydown="OnKeyDownAsync"
                           @onblur="OnBlurAsync"
                           @ref="Element" />

                    @if (SubmitValue && ElementName is not null) {
                        <input type="hidden" name="@ElementName" value="@FormPostValue" />
                    }

                    @if (HasLabel) {
                        <span class="nt-input-label" id="@LabelId">@Label</span>
                    }
                </span>

                @if (!string.IsNullOrWhiteSpace(SuffixText)) {
                    <span class="nt-input-suffix" id="@SuffixId">@SuffixText</span>
                }

                @{
                    var trailingAdornment = CreateTrailingAdornmentState(hasErrorText);
                }

                @if (_searching) {
                    <span class="nt-input-trailing nt-typeahead-progress">
                        <NTProgress Variant="NTProgressVariant.Ring"
                                    Size="Size.Smallest"
                                    TrackVisible="false"
                                    AriaLabel="@LoadingText" />
                    </span>
                }
                else if (trailingAdornment.Icon is not null) {
                    <span class="@trailingAdornment.Class" aria-label="@trailingAdornment.AriaLabel" aria-hidden="@trailingAdornment.AriaHidden">
                        @trailingAdornment.Icon.Render()
                    </span>
                }
            </span>
        </label>

        @if (_isOpen) {
            <div class="nt-combobox-menu" data-nt-typeahead-menu="true">
                <ul class="nt-combobox-list" id="@listboxId" role="listbox" aria-label="@ListboxLabel">
                    @if (_items.Count > 0) {
                        @for (var index = 0; index < _items.Count; index++) {
                            var item = _items[index];
                            var optionId = GetOptionId(index);
                            var isActive = index == _activeIndex;
                            var isSelected = EqualityComparer<TItem?>.Default.Equals(CurrentValue, item);
                            var itemSupportingText = GetItemSupportingText(item);

                            <li class="nt-combobox-list-item" role="presentation">
                                <button type="button"
                                        id="@optionId"
                                        tabindex="-1"
                                        class="@GetOptionClass(isActive, isSelected)"
                                        role="option"
                                        aria-selected="@(isSelected ? "true" : "false")"
                                        @onpointerdown:preventDefault="true"
                                        @onpointerdown:stopPropagation="true"
                                        @onpointerdown="() => SelectItemAsync(item)">
                                    @if (ResultTemplate is not null) {
                                        @ResultTemplate(item)
                                    }
                                    else {
                                        <span class="nt-combobox-option-content">
                                            <span class="nt-combobox-option-label">@ItemTextSelector(item)</span>
                                            @if (!string.IsNullOrWhiteSpace(itemSupportingText)) {
                                                <span class="nt-combobox-option-supporting">@itemSupportingText</span>
                                            }
                                        </span>
                                    }
                                </button>
                            </li>
                        }
                    }
                </ul>

                @if (_items.Count == 0) {
                    <div class="nt-combobox-empty" role="status">
                        @(_searching ? LoadingText : EmptyText)
                    </div>
                }
            </div>
        }
    </div>

    @if (hasErrorText || hasSupportingText) {
        <div class="nt-input-supporting-row">
            @if (hasErrorText) {
                <span class="nt-input-supporting nt-input-error-text" id="@ErrorTextId" role="alert">
                    @errorText
                </span>
            }
            else if (hasSupportingText) {
                <span class="nt-input-supporting" id="@SupportingTextId">
                    @supportingText
                </span>
            }
        </div>
    }
</div>
