@namespace NTComponents
@using Microsoft.AspNetCore.Components.Forms

<div class="tnt-input-container nt-input-file-container" style="@ElementStyle">
	<label class="@ElementClass" title="@ElementTitle" lang="@ElementLang" id="@ElementId">
		@if (StartIcon is not null) {
			@StartIcon.Render("tnt-start-icon")
		}

		@if (RendererInfo.IsInteractive) {
			<span class="nt-input-element-container" @ref="_inputElementContainer">
				<InputFile @key="_inputFileKey" OnChange="OnFilesSelectedAsync" @attributes="InputAttributes" />
			</span>
		}
		else {
			<input type="file" @attributes="StaticInputAttributes" />
		}

		@if (!string.IsNullOrWhiteSpace(Label)) {
			<span class="tnt-label">@Label</span>
		}

		@if (ShowUploadButton && RendererInfo.IsInteractive) {
			<span class="nt-input-file-upload-button" @onclick:preventDefault="true" @onclick:stopPropagation="true">
				<TnTButton Appearance="@UploadButtonAppearance"
						   ButtonSize="@EffectiveUploadButtonSize"
						   Type="ButtonType.Button"
						   Disabled="@UploadButtonDisabled"
						   BackgroundColor="@EffectiveUploadButtonBackgroundColor"
						   TextColor="@EffectiveUploadButtonTextColor"
						   OnClickCallback="OnUploadButtonClickedAsync">
					<span>@UploadButtonText</span>
				</TnTButton>
			</span>
		}

		@if (EndIcon is not null) {
			@EndIcon.Render("tnt-end-icon")
		}

		@if (_fileProgressStates.Count > 0) {
			<span class="tnt-input-progress">
				<div class="nt-input-file-progress-list">
					@foreach (var file in _pendingFiles) {
						var fileState = _fileProgressStates.FirstOrDefault(x => x.BrowserFile == file);
						if (fileState is null) continue;
						var progressDetails = CreateProgressDetails(fileState);
						<div class="nt-input-file-progress-item">
							<div class="nt-input-file-progress-row">
								<div class="nt-input-file-progress-content">
									@if (ProgressTemplate is not null) {
										@ProgressTemplate(progressDetails)
									}
									else {
										<div class="nt-input-file-progress-title">@progressDetails.Name</div>
										<div class="nt-input-file-progress-subtitle">@progressDetails.Status</div>
									}
									</div>
									@if (ShowRemoveButton) {
										<span class="nt-input-file-progress-remove">
											<TnTImageButton Appearance="ButtonAppearance.Text"
															ButtonSize="Size.XS"
															Disabled="@(_isUploading || FieldDisabled || FieldReadonly)"
															Icon="@MaterialIcon.Close"
															TextColor="TnTColor.OnSurfaceVariant"
															TintColor="TnTColor.Primary"
															Type="ButtonType.Button"
															ElementTitle="Remove file"
															StopPropagation="true"
															OnClickCallback="async _ => await RemoveFileAsync(file)" />
										</span>
									}
								</div>
							@if (ShowProgressBar) {
								<TnTProgressIndicator Appearance="ProgressAppearance.Linear"
												      Value="@(progressDetails.IsIndeterminate ? null : progressDetails.Percentage)"
												      Max="100"
												      min="0" />
							}
						</div>
					}
				</div>
			</span>
		}
	</label>

	@if (Tooltip is not null) {
		@TooltipIcon.Render()
	}

	@if (!string.IsNullOrWhiteSpace(SupportingText)) {
		<span class="tnt-supporting-text">@SupportingText</span>
	}
</div>
