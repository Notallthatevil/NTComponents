@namespace NTComponents
@using Microsoft.AspNetCore.Components.Rendering
@inherits NTInputBase<string?>

@base.BuildRenderTree

@code {
    protected override void RenderInputElement(RenderTreeBuilder __builder) {
        var hasErrorText = !string.IsNullOrWhiteSpace(CurrentErrorText);

        <textarea @attributes="ControlAttributes"
                  id="@InputId"
                  title="@FieldIdentifier.FieldName"
                  autofocus="@AutoFocus"
                  autocomplete="@AutoComplete"
                  name="@InputElementName"
                  readonly="@FieldReadOnly"
                  disabled="@FieldDisabled"
                  required="@IsRequired"
                  placeholder="@EffectivePlaceholder"
                  aria-describedby="@BuildDescribedBy(hasErrorText, !hasErrorText && !string.IsNullOrWhiteSpace(CurrentSupportingText))"
                  aria-invalid="@(hasErrorText ? "true" : "false")"
                  aria-errormessage="@(hasErrorText ? ErrorTextId : null)"
                  class="@InputClass"
                  oninput="@InputNativeOnInputHandler"
                  @bind-value:get="@CurrentValueAsString"
                  @bind-value:set="OnInputAsync"
                  @bind-value:event="@(EffectiveBindOnInput ? "oninput" : "onchange")"
                  @onblur="@OnBlurAsync"
                  @ref="Element"></textarea>
        @if (ShouldAutoGrow) {
            <NTPageScript Src="@JsModulePath" />
        }

        @if (ShouldRenderFormPostValue) {
            <input type="hidden"
                   id="@FormPostInputId"
                   name="@ElementName"
                   value="@FormPostValue" />
        }
    }
}
