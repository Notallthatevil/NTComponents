@namespace NTComponents
@using NTComponents.Core
@inherits NTComponentBase

<CascadingValue Value="this">
    <div @attributes="AdditionalAttributes"
         class="@ElementClass"
         style="@ElementStyle"
         title="@ElementTitle"
         id="@ElementId"
         lang="@ElementLang"
         autofocus="@AutoFocus"
         @ref="Element">
        @ChildContent
    </div>
</CascadingValue>
