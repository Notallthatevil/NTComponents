{
  "compilerOptions": {
    "target": "ES2022",
    "module": "ES2022",
    "moduleResolution": "bundler",
    "lib": [
      "DOM",
      "DOM.Iterable",
      "ES2022"
    ],
    "strict": true,
    "noEmitOnError": true,
    "allowJs": false,
    "checkJs": false,
    "isolatedModules": true,
    "verbatimModuleSyntax": true,
    "skipLibCheck": true,
    "removeComments": true,
    "sourceMap": false,
    "newLine": "lf"
  },
  "include": [
    "NTComponents/**/*.ts"
  ],
  "exclude": [
    "node_modules"
  ]
}
