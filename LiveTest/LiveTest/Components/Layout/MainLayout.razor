@using NTComponents
@inherits LayoutComponentBase

<NTLayout>
	<NTNavigationRail AriaLabel="LiveTest primary navigation"
					  HideRailOnXSScreens="true"
					  MenuAriaLabel="Expand navigation rail"
					  MenuAriaLabelWhenExpanded="Collapse navigation rail"
					  ShowDivider="true"
					  OpenByDefault="true">
		<ChildContent>

			<NTNavigationRailSectionHeader Label="LiveTest" />
			<NTNavigationRailItem Label="Home" Href="/" Match="NavLinkMatch.All" Disabled="true" Icon="MaterialIcon.Home" />
			<NTNavigationRailItem Label="Accordion" Href="/accordion" Icon="MaterialIcon.MusicNote" />
			<NTNavigationRailItem Label="NTAnimation" Href="/nt-animation" Icon="MaterialIcon.Animation" />
			<NTNavigationRailGroup Icon="MaterialIcon.SmartButton" Label="Buttons" Expanded="true">
				<NTNavigationRailItem Label="Buttons" Href="/buttons" Icon="MaterialIcon.SmartButton" />
				<NTNavigationRailItem Label="FABs" Href="/fabbuttons" Icon="MaterialIcon.Link" />
				<NTNavigationRailItem Label="NT Menu" Href="/nt-menu" Icon="MaterialIcon.MenuOpen" />
				<NTNavigationRailItem Label="NT Context Menu" Href="/nt-context-menu" Icon="MaterialIcon.MoreHoriz" />
			</NTNavigationRailGroup>

			<NTNavigationRailItem Label="Carousel" Href="/carousel" Icon="MaterialIcon.CarCrash" />

			<NTNavigationRailGroup Icon="MaterialIcon.Addchart" Label="Graphs">
				<NTNavigationRailItem Label="Line Graph" Href="/line-graph" Icon="MaterialIcon.ShowChart" />
				<NTNavigationRailItem Label="Bar Graph" Href="/bar-graph" Icon="MaterialIcon.BarChart" />
				<NTNavigationRailItem Label="Pie Charts" Href="/pie-charts" Icon="MaterialIcon.InsertChart" />
				<NTNavigationRailItem Label="Tree Map" Href="/tree-map" Icon="MaterialIcon.AccountTree" />
				<NTNavigationRailItem Label="Bubble Physics" Href="/bubble-chart" Icon="MaterialIcon.BubbleChart" />
			</NTNavigationRailGroup>

			<NTNavigationRailItem Label="Chips" Href="/chips" Icon="MaterialIcon.BedroomChild" />
			<NTNavigationRailItem Label="Dialogs" Href="/dialog" Icon="MaterialIcon.Diamond" />
			<NTNavigationRailItem Label="Divider" Href="/divider" Icon="MaterialIcon.HorizontalRule" />
			<NTNavigationRailItem Label="Tags" Href="/tags" Icon="MaterialIcon.Tag" />

			<NTNavigationRailGroup Icon="MaterialIcon.EditNote" Label="Editors">
				<NTNavigationRailItem Label="Rich Text Editor" Href="/rich-text-editor" Icon="MaterialIcon.Edit" />
			</NTNavigationRailGroup>

			<NTNavigationRailItem Label="Validation Modes" Href="/validation-render-modes" Icon="MaterialIcon.FormatAlignCenter" />
			<NTNavigationRailItem Label="Generated Docs" Href="/documentation-model" Icon="MaterialIcon.Info" />
			<NTNavigationRailItem Label="Views" Href="/views" Icon="MaterialIcon.Dashboard" />

			<NTNavigationRailGroup Icon="MaterialIcon.Grid4X4" Label="Grids">
				<NTNavigationRailItem Label="Grid" Href="/datagrid" Icon="MaterialIcon.GridView" />
				<NTNavigationRailItem Label="Paginated Grid" Href="/paginated" Icon="MaterialIcon.GridOn" />
				<NTNavigationRailItem Label="Virtualized Grid" Href="/virtualizedGrid" Icon="MaterialIcon.GridGoldenratio" />
			</NTNavigationRailGroup>

			<NTNavigationRailItem Label="Nested Layout" Href="/nestedLayout" Icon="MaterialIcon.NestCamWiredStand" />
			<NTNavigationRailItem Label="Loader" Href="/loader" Icon="MaterialIcon.Pending" />
			<NTNavigationRailItem Label="Progress" Href="/progress" Icon="MaterialIcon.Propane" />

			<NTNavigationRailGroup Icon="MaterialIcon.Schedule" Label="Scheduler">
				<NTNavigationRailItem Label="Weekly Scheduler" Href="/scheduler" Icon="MaterialIcon.ViewWeek" />
			</NTNavigationRailGroup>

			<NTNavigationRailItem Label="Shapes" Href="/shapes" Icon="MaterialIcon.FormatShapes" />
			<NTNavigationRailItem Label="Skeleton" Href="/skeleton" Icon="MaterialIcon.ShoppingBasket" />
			<NTNavigationRailItem Label="TabView" Href="/tabview" Icon="MaterialIcon.Tab" />
			<NTNavigationRailItem Label="Toast" Href="/toast" Icon="MaterialIcon.Notifications" />
			<NTNavigationRailItem Label="Tooltip" Href="/tooltip" Icon="MaterialIcon.PanTool" />
			<NTNavigationRailItem Label="Typeahead" Href="/typeahead" Icon="MaterialIcon.Search" />
			<NTNavigationRailItem Label="Virtualize" Href="/InfiniteScroll" Icon="MaterialIcon.Info" />
		</ChildContent>
		<Footer>
			<NTThemeToggle />
		</Footer>
		<Header>
			Test Header
		</Header>
	</NTNavigationRail>

	<NTHeader BackgroundColor="TnTColor.PrimaryContainer" TextColor="TnTColor.OnPrimaryContainer">
		<NTThemeToggle />
		This is my header
	</NTHeader>

	<NTBody BackgroundColor="TnTColor.SecondaryContainer" TextColor="TnTColor.OnSecondaryContainer">
		@Body
	</NTBody>

	<NTFooter BackgroundColor="TnTColor.TertiaryContainer" TextColor="TnTColor.OnTertiaryContainer">
		Footer content
	</NTFooter>
</NTLayout>

<NTSnackbar />
<NTToast />
