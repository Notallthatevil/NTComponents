@page "/virtualizedGrid"
@using NTComponents
@rendermode InteractiveServer

<main style="display: grid; gap: 24px; padding: 16px;">
    <header>
        <h1>NTDataGrid virtualization</h1>
        <p>Provider-backed virtualized grid with cancellation-aware range requests.</p>
    </header>

    <label style="display: inline-flex; gap: 8px; align-items: center;">
        Delay in milliseconds
        <input type="number" min="0" step="100" @bind="_delay" @bind:event="oninput" />
    </label>

    <label style="display: inline-flex; gap: 8px; align-items: center;">
        <input type="checkbox" @bind="_empty" />
        Empty
    </label>

    <NTDataGrid TItem="DataGridItem"
                ItemsProvider="Provider"
                Caption="Virtualized provider source"
                Virtualize="true"
                VirtualizationInitialItemCount="18"
                Density="NTDataGridDensity.Compact"
                Appearance="NTDataGridAppearance.Striped"
                RowKey="item => item.Id">
        <NTPropertyColumn TItem="DataGridItem" TValue="int" Title="Id" Property="item => item.Id" Width="96px" TextAlign="TextAlign.Right" HeaderTextAlign="TextAlign.Right" InitialSortDirection="SortDirection.Ascending" />
        <NTPropertyColumn TItem="DataGridItem" TValue="string" Title="Customer" Property="item => item.Customer" MinWidth="220px" />
        <NTPropertyColumn TItem="DataGridItem" TValue="DateTime" Title="Created" Property="item => item.Created" Format="MMM d, yyyy" MinWidth="160px" />
        <NTPropertyColumn TItem="DataGridItem" TValue="decimal" Title="Amount" Property="item => item.Amount" Format="C" TextAlign="TextAlign.Right" HeaderTextAlign="TextAlign.Right" />
    </NTDataGrid>
</main>

@code {
    private readonly IQueryable<DataGridItem> Items = BuildItems().AsQueryable();
    private bool _empty;
    private int _delay = 1500;

    private async ValueTask<NTItemsProviderResult<DataGridItem>> Provider(NTDataGridItemsProviderRequest<DataGridItem> request) {
        await Task.Delay(Math.Max(0, _delay), request.CancellationToken);
        if (_empty) {
            return new NTItemsProviderResult<DataGridItem>([], 0);
        }

        var items = ApplyRequest(Items, request).ToArray();
        return new NTItemsProviderResult<DataGridItem>(items, Items.Count());
    }

    private static IEnumerable<DataGridItem> ApplyRequest(IEnumerable<DataGridItem> source, NTDataGridItemsProviderRequest<DataGridItem> request) {
        foreach (var sort in request.Sorts.Reverse()) {
            source = sort.PropertyName switch {
                nameof(DataGridItem.Id) => sort.Direction == SortDirection.Descending ? source.OrderByDescending(item => item.Id) : source.OrderBy(item => item.Id),
                nameof(DataGridItem.Customer) => sort.Direction == SortDirection.Descending ? source.OrderByDescending(item => item.Customer) : source.OrderBy(item => item.Customer),
                nameof(DataGridItem.Created) => sort.Direction == SortDirection.Descending ? source.OrderByDescending(item => item.Created) : source.OrderBy(item => item.Created),
                nameof(DataGridItem.Amount) => sort.Direction == SortDirection.Descending ? source.OrderByDescending(item => item.Amount) : source.OrderBy(item => item.Amount),
                _ => source
            };
        }

        return source.Skip(request.StartIndex).Take(request.Count ?? 20);
    }

    private static List<DataGridItem> BuildItems() =>
        Enumerable.Range(1, 10_000)
            .Select(index => new DataGridItem(index, $"Customer {index:00000}", DateTime.Today.AddDays(-index), index * 7.25m))
            .ToList();

    public sealed record DataGridItem(int Id, string Customer, DateTime Created, decimal Amount);
}
