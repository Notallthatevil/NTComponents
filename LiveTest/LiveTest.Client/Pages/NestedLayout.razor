@page "/nestedLayout"
@using NTComponents

<NTLayout Tag="NTLayoutTag.Section">
    <NTNavigationRail AriaLabel="Nested layout navigation"
                      MenuAriaLabel="Expand nested navigation rail"
                      MenuAriaLabelWhenExpanded="Collapse nested navigation rail"
                      ShowDivider="true">
        <NTNavigationRailSectionHeader Label="Nested Demo" />
        <NTNavigationRailItem Label="Home" Href="/" Match="NavLinkMatch.All" Disabled="true" Icon="MaterialIcon.Home" />
        <NTNavigationRailItem Label="Accordion" Href="/accordion" Icon="MaterialIcon.MusicNote" />
        <NTNavigationRailGroup Icon="MaterialIcon.SmartButton" Label="Buttons" Expanded="true">
            <NTNavigationRailItem Label="Buttons" Href="/buttons" Icon="MaterialIcon.SmartButton" />
            <NTNavigationRailItem Label="FABs" Href="/fabbuttons" Icon="MaterialIcon.Link" />
        </NTNavigationRailGroup>

        <NTNavigationRailItem Label="Chips" Href="/chips" Icon="MaterialIcon.BedroomChild" />
        <NTNavigationRailItem Label="Dialogs" Href="/dialog" Icon="MaterialIcon.Diamond" />

        <NTNavigationRailGroup Icon="MaterialIcon.EditNote" Label="Editors">
            <NTNavigationRailItem Label="Rich Text Editor" Href="/rich-text-editor" Icon="MaterialIcon.Edit" />
        </NTNavigationRailGroup>

        <NTNavigationRailItem Label="Grid" Href="/datagrid" Icon="MaterialIcon.Grid4X4" />
        <NTNavigationRailItem Label="Nested Layout" Href="/nestedLayout" Icon="MaterialIcon.NestCamWiredStand" />
        <NTNavigationRailItem Label="Loader" Href="/loader" Icon="MaterialIcon.Pending" />
        <NTNavigationRailItem Label="Progress" Href="/progress" Icon="MaterialIcon.Propane" />

        <NTNavigationRailGroup Icon="MaterialIcon.Schedule" Label="Scheduler">
            <NTNavigationRailItem Label="Weekly Scheduler" Href="/scheduler" Icon="MaterialIcon.ViewWeek" />
        </NTNavigationRailGroup>

        <NTNavigationRailItem Label="Skeleton" Href="/skeleton" Icon="MaterialIcon.ShoppingBasket" />
        <NTNavigationRailItem Label="TabView" Href="/tabview" Icon="MaterialIcon.Tab" />
        <NTNavigationRailItem Label="Toast" Href="/toast" Icon="MaterialIcon.Notifications" />
        <NTNavigationRailItem Label="Typeahead" Href="/typeahead" Icon="MaterialIcon.Search" />
        <NTNavigationRailItem Label="Virtualize" Href="/InfiniteScroll" Icon="MaterialIcon.Info" />
    </NTNavigationRail>

    <NTHeader Tag="NTLayoutTag.Div">
        Header Content
    </NTHeader>

    <NTBody Tag="NTLayoutTag.Section">
        Some body content
    </NTBody>
</NTLayout>
