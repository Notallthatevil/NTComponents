@page "/anchors"
@page "/anchors/1"
@using Microsoft.AspNetCore.Components.Routing
@using NTComponents
@rendermode InteractiveAuto

<section>
    <label>
        Variant
        <select @bind="Variant">
            @foreach (var variant in Enum.GetValues<NTNavLinkVariant>()) {
                <option value="@variant">@variant</option>
            }
        </select>
    </label>

    <label>
        Shape
        <select @bind="Shape">
            @foreach (var shape in Enum.GetValues<ButtonShape>()) {
                <option value="@shape">@shape</option>
            }
        </select>
    </label>

    <label>
        Match
        <select @bind="Match">
            @foreach (var match in Enum.GetValues<NavLinkMatch>()) {
                <option value="@match">@match</option>
            }
        </select>
    </label>

    <label>
        Href
        <select @bind="Href">
            <option value="/anchors">/anchors</option>
            <option value="/anchors/1">/anchors/1</option>
            <option value="#">#</option>
        </select>
    </label>

    <label>
        <input type="checkbox" @bind="Disabled" />
        Disabled
    </label>

    <label>
        <input type="checkbox" @bind="EnableRipple" />
        Ripple
    </label>

    <label>
        <input type="checkbox" @bind="ShowLeadingIcon" />
        Leading icon
    </label>
</section>

<TnTRow>
    <TnTColumn S="12">
        @foreach (var navLinkSize in DemoSizes) {
            <NTNavLink Variant="@Variant"
                       Shape="@Shape"
                       Disabled="@Disabled"
                       EnableRipple="@EnableRipple"
                       ButtonSize="@navLinkSize.Size"
                       Label="@navLinkSize.Label"
                       Match="@Match"
                       href="@Href"
                       LeadingIcon="@LeadingIcon" />
        }
    </TnTColumn>
</TnTRow>

<section>
    <h2>Text links</h2>

    <p>
        This paragraph includes a
        <NTNavLink Variant="NTNavLinkVariant.DefaultAnchor"
                   Label="default anchor"
                   Match="@Match"
                   href="@Href"
                   Disabled="@Disabled"
                   TextColor="TnTColor.Primary"
                   HoverTextColor="TnTColor.Secondary"
                   VisitedTextColor="TnTColor.Tertiary" />
        with underline and visited-state color customization.
    </p>

    <p>
        This paragraph includes an
        <NTNavLink Variant="NTNavLinkVariant.InlineText"
                   Label="inline text link"
                   Match="@Match"
                   href="@Href"
                   Disabled="@Disabled"
                   TextColor="TnTColor.Primary"
                   HoverTextColor="TnTColor.Secondary"
                   VisitedTextColor="TnTColor.Tertiary" />
        without underline.
    </p>
</section>

@code {
    private static readonly (Size Size, string Label)[] DemoSizes = [
        (Size.Smallest, "Extra Small"),
        (Size.Small, "Small"),
        (Size.Medium, "Medium"),
        (Size.Large, "Large"),
        (Size.Largest, "Extra Large")
    ];

    private NTNavLinkVariant Variant { get; set; } = NTNavLinkVariant.Filled;

    private ButtonShape Shape { get; set; } = ButtonShape.Round;

    private bool Disabled { get; set; }

    private bool EnableRipple { get; set; } = true;

    private NavLinkMatch Match { get; set; } = NavLinkMatch.Prefix;

    private string Href { get; set; } = "/anchors";

    private bool ShowLeadingIcon { get; set; }

    private TnTIcon? LeadingIcon => ShowLeadingIcon ? MaterialIcon.Home : null;
}
