@page "/animation"
@page "/nt-animation"
@using NTComponents

<PageTitle>NTAnimation</PageTitle>

<style>
    .animation-demo {
        display: grid;
        gap: 1.5rem;
        max-width: 72rem;
    }

    .animation-demo h1,
    .animation-demo h2,
    .animation-demo h3,
    .animation-demo p {
        margin: 0;
    }

    .animation-demo .header {
        display: grid;
        gap: .5rem;
    }

    .animation-demo .surface {
        display: grid;
        gap: 1.25rem;
        padding: 1.25rem;
        border: 1px solid var(--tnt-color-outline-variant);
        border-radius: .5rem;
        background: var(--tnt-color-surface);
        color: var(--tnt-color-on-surface);
    }

    .animation-demo .muted {
        color: var(--tnt-color-on-surface-variant);
    }

    .animation-demo .grid {
        display: grid;
        grid-template-columns: repeat(auto-fit, minmax(13rem, 1fr));
        gap: 1rem;
    }

    .animation-demo .sample {
        display: grid;
        gap: .5rem;
        min-block-size: 8rem;
        padding: 1rem;
        border: 1px solid var(--tnt-color-outline-variant);
        border-radius: .5rem;
        background: var(--tnt-color-surface-container-lowest);
    }

    .animation-demo .spacer {
        min-block-size: 50vh;
        border: 1px dashed var(--tnt-color-outline-variant);
        border-radius: .5rem;
        display: grid;
        place-items: center;
        color: var(--tnt-color-on-surface-variant);
    }
</style>

<div class="animation-demo">
    <div class="header">
        <h1>NTAnimation</h1>
        <p class="muted">Static-rendered viewport animations using Material 3 duration and easing tokens.</p>
    </div>

    <section class="surface" aria-labelledby="animation-enter-title">
        <h2 id="animation-enter-title">Enter Motion</h2>
        <div class="grid">
            @foreach (var sample in EnterSamples) {
                <NTAnimation @key="sample.Title" data-testid="@sample.TestId" Animation="@sample.Animation" EnterDuration="@sample.Duration" EnterEasing="@sample.Easing">
                    <div class="sample">
                        <h3>@sample.Title</h3>
                        <p class="muted">@sample.Description</p>
                    </div>
                </NTAnimation>
            }
        </div>
    </section>

    <div class="spacer">Scroll to trigger the next group</div>

    <section class="surface" aria-labelledby="animation-out-title">
        <h2 id="animation-out-title">Animate Out</h2>
        <div class="grid">
            @foreach (var sample in ExitSamples) {
                <NTAnimation @key="sample.Title"
                             data-testid="@sample.TestId"
                             Animation="@sample.Animation"
                             AnimateOut="true"
                             Once="false"
                             EnterDuration="NTMotionDuration.Ms400"
                             ExitDuration="NTMotionDuration.Ms200"
                             EnterEasing="NTMotionEasing.EmphasizedDecelerate"
                             ExitEasing="NTMotionEasing.EmphasizedAccelerate"
                             RootMargin="0px 0px -10% 0px">
                    <div class="sample">
                        <h3>@sample.Title</h3>
                        <p class="muted">@sample.Description</p>
                    </div>
                </NTAnimation>
            }
        </div>
    </section>
</div>

@code {
    private static readonly AnimationSample[] EnterSamples = [
        new("animation-fade-in", "Fade in", "Opacity-only reveal for top-level destination changes.", NTAnimationType.FadeIn, NTMotionDuration.Ms250, NTMotionEasing.StandardDecelerate),
        new("animation-from-bottom", "From bottom", "Common enter pattern for content appearing below the current focus.", NTAnimationType.SlideInFromBottom, NTMotionDuration.Ms400, NTMotionEasing.EmphasizedDecelerate),
        new("animation-from-left", "From left", "Directional reveal for lateral or previous-position content.", NTAnimationType.SlideInFromLeft, NTMotionDuration.Ms400, NTMotionEasing.EmphasizedDecelerate),
        new("animation-from-right", "From right", "Directional reveal for lateral or next-position content.", NTAnimationType.SlideInFromRight, NTMotionDuration.Ms400, NTMotionEasing.EmphasizedDecelerate),
        new("animation-from-top", "From top", "Useful for banners and content associated with the page chrome.", NTAnimationType.SlideInFromTop, NTMotionDuration.Ms300, NTMotionEasing.StandardDecelerate)
    ];

    private static readonly AnimationSample[] ExitSamples = [
        new("animation-fade-out", "Fade out", "Leaves the viewport with a short exit transition.", NTAnimationType.FadeIn, NTMotionDuration.Ms400, NTMotionEasing.EmphasizedDecelerate),
        new("animation-slide-out-down", "Slide out down", "Returns to its offset when it exits the viewport.", NTAnimationType.SlideInFromBottom, NTMotionDuration.Ms400, NTMotionEasing.EmphasizedDecelerate),
        new("animation-slide-out-right", "Slide out right", "Keeps a directional relationship while leaving.", NTAnimationType.SlideInFromRight, NTMotionDuration.Ms400, NTMotionEasing.EmphasizedDecelerate)
    ];

    private sealed record AnimationSample(string TestId, string Title, string Description, NTAnimationType Animation, NTMotionDuration Duration, NTMotionEasing Easing);
}
