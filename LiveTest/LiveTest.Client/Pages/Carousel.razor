        new("full-screen", "Full-screen", "Edge-to-edge portrait items scroll vertically with a 16px gap.", NTComponents.CarouselAppearance.FullScreen, 640, null, "--nt-carousel-fullscreen-height:640px")
    ];

    private string GetStatus(string id) => _statuses.GetValueOrDefault(id, "Settled item: 1");

    private IReadOnlyList<CarouselDemoItem> ItemsFor(CarouselExample example) => example.Id == "multi-browse" ? _multiBrowseItems : _items;

    private void SetActivation(string id, string title) {
        _statuses[id] = $"Activated: {title}";
    }

    private void SetStatus(string id, int index) {
        _statuses[id] = $"Settled item: {index + 1}";
    }

    private void ToggleShowAll(string id) {
        if (!_expandedExamples.Remove(id)) {
            _expandedExamples.Add(id);
        }
    }

    private sealed record CarouselDemoItem(string Title, string SupportingText, string ImageUrl, double AspectRatio);
    private sealed record CarouselExample(string Id, string Title, string Description, NTComponents.CarouselAppearance Appearance, int Height, double? AutoPlayInterval = null, string? Style = null);
}
