        new("hero", "Hero", "One dominant item and a small trailing preview advance one item at a time.", NTComponents.CarouselAppearance.Hero, 300),
        new("center-hero", "Center-aligned hero", "The active item is centered between leading and trailing preview keylines.", NTComponents.CarouselAppearance.CenterAlignedHero, 300),
