@page "/carousel"
@rendermode InteractiveAuto

<PageTitle>Material 3 Carousel</PageTitle>

<main class="carousel-demo">
    <header>
        <p class="eyebrow">NTCarousel</p>
        <h1>Material 3 carousel layouts</h1>
        <p>Drag with a mouse or pen, swipe on touch, focus an item and use arrow keys, or emulate reduced motion to inspect the stable-size fallback.</p>
    </header>

    @foreach (var example in _examples) {
        <section data-layout-example="@example.Id">
            <div class="section-heading">
                <div>
                    <h2>@example.Title</h2>
                    <p>@example.Description</p>
                </div>
                @if (example.Appearance != NTComponents.CarouselAppearance.FullScreen) {
                    <button type="button"
                            class="show-all"
                            aria-expanded="@(_expandedExamples.Contains(example.Id) ? "true" : "false")"
                            aria-controls="show-all-@example.Id"
                            @onclick="() => ToggleShowAll(example.Id)">
                        @(_expandedExamples.Contains(example.Id) ? "Hide all" : "Show all")
                    </button>
                }
            </div>

            <NTComponents.NTCarousel AriaLabel="@example.Title"
                                      Appearance="@example.Appearance"
                                      ItemHeight="@example.Height"
                                      AutoPlayInterval="@example.AutoPlayInterval"
                                      style="@example.Style"
                                      OnIndexChanged="@(index => SetStatus(example.Id, index))">
                @foreach (var item in ItemsFor(example)) {
                    <NTComponents.NTCarouselItem @key="@(example.Id + item.Title)"
                                                  AriaLabel="@item.Title"
                                                  AspectRatio="@(example.Appearance == NTComponents.CarouselAppearance.UncontainedMultiAspectRatio ? item.AspectRatio : null)"
                                                  OnClickCallback="@(() => SetActivation(example.Id, item.Title))">
                        <MediaContent>
                            <img src="@item.ImageUrl" alt="" loading="lazy" />
                        </MediaContent>
                        <ChildContent>
                            <div class="item-label">
                                <strong>@item.Title</strong>
                                <span>@item.SupportingText</span>
                            </div>
                        </ChildContent>
                    </NTComponents.NTCarouselItem>
                }
            </NTComponents.NTCarousel>
            <output class="status">@GetStatus(example.Id)</output>
            @if (_expandedExamples.Contains(example.Id)) {
                <ul id="show-all-@example.Id" class="show-all-list" aria-label="All @example.Title items">
                    @foreach (var item in ItemsFor(example)) {
                        <li>
                            <img src="@item.ImageUrl" alt="" loading="lazy" />
                            <div>
                                <strong>@item.Title</strong>
                                <span>@item.SupportingText</span>
                            </div>
                        </li>
                    }
                </ul>
            }
        </section>
    }
</main>

