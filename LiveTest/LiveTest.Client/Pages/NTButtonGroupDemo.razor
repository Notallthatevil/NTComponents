@page "/button-group"
@using System
@using NTComponents
@rendermode InteractiveAuto

<div class="nt-button-group-demo">
    <h1>NTButtonGroup</h1>
    <p>
        Explore the Material 3 button group that composes buttons and icon buttons with disconnected or connected behavior.
    </p>

    <TnTRow class="nt-button-group-demo__row">
        <TnTColumn S="12" M="6">
            <TnTCard class="nt-button-group-demo__panel">
                <div class="tnt-card-header">
                    <h2>Controls</h2>
                </div>
                <div class="nt-button-group-demo__controls">
                    <label>
                        Variant
                        <select @bind="DisplayType">
                            @foreach (var displayType in Enum.GetValues<NTButtonGroupDisplayType>()) {
                                <option value="@displayType">@displayType</option>
                            }
                        </select>
                    </label>
                    <label>
                        Button size
                        <select @bind="ButtonSize">
                            @foreach (var size in Enum.GetValues<Size>()) {
                                <option value="@size">@size</option>
                            }
                        </select>
                    </label>
                    <label>
                        Button variant
                        <select @bind="Variant">
                            @foreach (var variant in Enum.GetValues<NTButtonVariant>()) {
                                <option value="@variant">@variant</option>
                            }
                        </select>
                    </label>
                    <label>
                        Button shape
                        <select @bind="Shape">
                            @foreach (var shape in Enum.GetValues<ButtonShape>()) {
                                <option value="@shape">@shape</option>
                            }
                        </select>
                    </label>
                    <label>
                        Default selection
                        <select @bind="SelectedKey">
                            <option value="">None</option>
                            @foreach (var item in DisplayItems) {
                                <option value="@item.Key">@item.Label</option>
                            }
                        </select>
                    </label>
                    <label class="nt-button-group-demo__toggle">
                        <input type="checkbox" @bind="DisableRipple" />
                        Disable ripple
                    </label>
                    <label class="nt-button-group-demo__toggle">
                        <input type="checkbox" @bind="Disabled" />
                        Disable group
                    </label>
                    <label class="nt-button-group-demo__toggle">
                        <input type="checkbox" @bind="StopPropagation" />
                        Stop propagation
                    </label>
                    <label class="nt-button-group-demo__toggle">
                        <input type="checkbox" @bind="UseImages" />
                        Include icon-only actions
                    </label>
                    <label class="nt-button-group-demo__toggle">
                        <input type="checkbox" @bind="SelectionRequired" />
                        Selection required
                    </label>
                </div>
            </TnTCard>
        </TnTColumn>
        <TnTColumn S="12" M="6">
            <TnTCard class="nt-button-group-demo__panel">
                <div class="tnt-card-header">
                    <h2>State</h2>
                </div>
                <div class="nt-button-group-demo__state">
                    <p>Selected key: <strong>@(string.IsNullOrWhiteSpace(SelectedKey) ? "None" : SelectedKey)</strong></p>
                    <p>Display style: <strong>@DisplayType</strong></p>
                    <p>@SelectionMessage</p>
                </div>
            </TnTCard>
        </TnTColumn>
    </TnTRow>

    <TnTCard class="nt-button-group-demo__preview">
        <div class="nt-button-group-demo__description">
            <p>The preview below mirrors the current settings and shows how the button group responds.</p>
        </div>
        <NTButtonGroup
            TObjectType="string"
            DisplayType="DisplayType"
            ButtonSize="ButtonSize"
            Variant="Variant"
            Shape="Shape"
            SelectedKey="@SelectedKeyValue"
            SelectedKeyChanged="HandleSelectedKeyChanged"
            SelectionRequired="SelectionRequired"
            DisableRipple="DisableRipple"
            Disabled="Disabled"
            StopPropagation="StopPropagation"
            OnSelectionChanged="HandleSelectionChanged">
            @foreach (var item in DisplayItems) {
                <NTButtonGroupItem
                    Key="@item.Key"
                    Label="@item.Label"
                    AriaLabel="@item.AriaLabel"
                    StartIcon="@item.StartIcon"
                    Disabled="@item.Disabled"
                    IsDefaultSelected="@item.IsDefaultSelected" />
            }
        </NTButtonGroup>
    </TnTCard>
</div>
