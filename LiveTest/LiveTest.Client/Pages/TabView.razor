@page "/tabview"
@using NTComponents

<section style="display:grid;gap:24px;margin-block-end:32px;">
    <NTTabView Name="nt-primary-default-demo" AriaLabel="NTTabView primary default demo">
        <NTTab Label="Overview" Value="overview" Icon="@MaterialIcon.Info">
            <p>Primary default overview content.</p>
        </NTTab>
        <NTTab Label="Specifications" Value="specifications" Icon="@MaterialIcon.Rule">
            <p>Primary default specifications content.</p>
        </NTTab>
        <NTTab Label="Accessibility" Value="accessibility" Icon="@MaterialIcon.CheckCircle">
            <p>Primary default accessibility content.</p>
        </NTTab>
    </NTTabView>

    <NTTabView Name="nt-secondary-default-demo" Variant="NTTabViewVariant.Secondary" AriaLabel="NTTabView secondary default demo">
        <NTTab Label="Details" Value="details">
            Secondary default details content.
        </NTTab>
        <NTTab Label="Activity" Value="activity">
            Secondary default activity content.
        </NTTab>
        <NTTab Label="Disabled" Value="disabled" Disabled="true">
            Secondary default disabled content.
        </NTTab>
    </NTTabView>

    <NTTabView Name="nt-primary-compact-demo" Compact="true" TabGap="8px" AriaLabel="NTTabView primary compact demo">
        <NTTab Label="Overview" Value="overview" Icon="@MaterialIcon.Info">
            <p>Primary compact overview content.</p>
        </NTTab>
        <NTTab Label="Specifications" Value="specifications" Icon="@MaterialIcon.Rule">
            <p>Primary compact specifications content.</p>
        </NTTab>
        <NTTab Label="Accessibility" Value="accessibility" Icon="@MaterialIcon.CheckCircle">
            <p>Primary compact accessibility content.</p>
        </NTTab>
    </NTTabView>

    <NTTabView Name="nt-secondary-compact-demo" Variant="NTTabViewVariant.Secondary" Compact="true" TabGap="8px" AriaLabel="NTTabView secondary compact demo">
        <NTTab Label="Details" Value="details">
            Secondary compact details content.
        </NTTab>
        <NTTab Label="Activity" Value="activity">
            Secondary compact activity content.
        </NTTab>
        <NTTab Label="Disabled" Value="disabled" Disabled="true">
            Secondary compact disabled content.
        </NTTab>
    </NTTabView>
</section>
