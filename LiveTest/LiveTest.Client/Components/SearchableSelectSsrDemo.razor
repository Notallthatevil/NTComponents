@using System.ComponentModel.DataAnnotations
@using NTComponents

<TnTCard Appearance="CardAppearance.Outlined">
	<h3>Searchable Select (SSR)</h3>

	<TnTForm Model="_model" OnValidSubmit="HandleValidSubmit" FormName="SearchableSelectDemo" Appearance="FormAppearance.Outlined">
		<DataAnnotationsValidator />

		<TnTRow>
			<TnTColumn S="12" M="6">
				<NTInputSelect TInputType="Guid?"
							   @bind-Value="_model.SelectedId"
							   Label="State"
							   Placeholder="Type to narrow the list"
							   SupportingText="Contains match with starts-with ranked first.">
					@foreach (var option in _options) {
						<NTInputSelectOption TInputType="Guid?"
											 Value="@option.Value"
											 Label="@option.Label" />
					}
				</NTInputSelect>
			</TnTColumn>
		</TnTRow>

		<TnTButton Type="ButtonType.Submit">Submit</TnTButton>
	</TnTForm>

	<p>Selected: @_lastSubmittedLabel</p>
</TnTCard>

@code {
	private readonly DemoModel _model = new();
	private string _lastSubmittedLabel = "None";

	private readonly IReadOnlyList<DemoOption> _options = CreateOptions();

	private Task HandleValidSubmit() {
		_lastSubmittedLabel = _options.FirstOrDefault(option => option.Value == _model.SelectedId)?.Label ?? "None";
		return Task.CompletedTask;
	}

	private static IReadOnlyList<DemoOption> CreateOptions() {
		return Enumerable.Range(1, 250)
			.Select(index => new DemoOption(
				Guid.Parse($"00000000-0000-0000-0000-{index:000000000000}"),
				$"Demo option {index:000}"))
			.ToArray();
	}

	private sealed class DemoModel {
		[Required]
		public Guid? SelectedId { get; set; }
	}

	private sealed record DemoOption(Guid? Value, string Label);
}
