@using System.ComponentModel.DataAnnotations
@using Microsoft.AspNetCore.Components.Forms
@using NTComponents

<section style="display:grid;gap:16px;max-width:1180px;padding:16px;background:var(--tnt-color-surface);color:var(--tnt-color-on-surface);">
    <div style="position:sticky;top:0;z-index:10;display:grid;gap:12px;padding:12px;border:1px solid var(--tnt-color-outline-variant);background:var(--tnt-color-surface);">
        <div style="display:flex;align-items:center;justify-content:space-between;gap:12px;">
            <h3 style="margin:0;">NTForm Fields</h3>
            <button type="button" @onclick="ToggleControls">@(_showControls ? "Hide controls" : "Show controls")</button>
        </div>

        @if (_showControls) {
            <div style="display:grid;grid-template-columns:repeat(auto-fit,minmax(180px,1fr));gap:12px;align-items:end;">
            <label>
                Appearance
                <select @bind="_appearance">
                    @foreach (var appearance in Enum.GetValues<NTFormAppearance>()) {
                        <option value="@appearance">@appearance</option>
                    }
                </select>
            </label>

            <label>
                Density
                <select @bind="_density">
                    @foreach (var density in Enum.GetValues<NTFormDensity>()) {
                        <option value="@density">@density</option>
                    }
                </select>
            </label>

            <label>
                Checkbox variant
                <select @bind="_checkboxVariant">
                    @foreach (var variant in Enum.GetValues<NTInputCheckboxVariant>()) {
                        <option value="@variant">@variant</option>
                    }
                </select>
            </label>

            <label>
                Switch variant
                <select @bind="_switchVariant">
                    @foreach (var variant in Enum.GetValues<NTSwitchVariant>()) {
                        <option value="@variant">@variant</option>
                    }
                </select>
            </label>

            <label>
                Slider size
                <select @bind="_sliderSize">
                    @foreach (var size in Enum.GetValues<NTSliderSize>()) {
                        <option value="@size">@size</option>
                    }
                </select>
            </label>

            <label>
                Slider orientation
                <select @bind="_sliderOrientation">
                    @foreach (var orientation in Enum.GetValues<NTSliderOrientation>()) {
                        <option value="@orientation">@orientation</option>
                    }
                </select>
            </label>

            <label>
                Text type
                <select @bind="_textInputType">
                    @foreach (var inputType in Enum.GetValues<TextInputType>()) {
                        <option value="@inputType">@inputType</option>
                    }
                </select>
            </label>

            <label>
                Phone mask
                <select @bind="_phoneMask" disabled="@(_textInputType != TextInputType.Tel)">
                    @foreach (var mask in PhoneMaskOptions) {
                        <option value="@mask">@mask</option>
                    }
                </select>
            </label>

            <label>
                Date type
                <select @bind="_dateInputKind">
                    @foreach (var inputKind in Enum.GetValues<DateInputKind>()) {
                        <option value="@inputKind">@inputKind</option>
                    }
                </select>
            </label>

            <label>
                Menu item appearance
                <select @bind="_menuItemAppearance">
                    @foreach (var appearance in Enum.GetValues<NTMenuItemAppearance>()) {
                        <option value="@appearance">@appearance</option>
                    }
                </select>
            </label>
            </div>

            <div style="display:grid;grid-template-columns:repeat(auto-fit,minmax(150px,1fr));gap:8px;">
            <label><input type="checkbox" @bind="_readOnly" /> Readonly</label>
            <label><input type="checkbox" @bind="_disabled" /> Disabled</label>
            <label><input type="checkbox" @bind="_showRequiredText" /> Required text</label>
            <label><input type="checkbox" @bind="_showLabel" /> Label</label>
            <label><input type="checkbox" @bind="_showPlaceholder" /> Placeholder</label>
            <label><input type="checkbox" @bind="_showSupportingText" /> Supporting text</label>
            <label><input type="checkbox" @bind="_showLeadingIcon" /> Leading icon</label>
            <label><input type="checkbox" @bind="_showTrailingIcon" /> Trailing icon</label>
            <label><input type="checkbox" @bind="_showPrefix" /> Prefix</label>
            <label><input type="checkbox" @bind="_showSuffix" /> Suffix</label>
            <label><input type="checkbox" @bind="_showErrorText" /> Error text</label>
            <label><input type="checkbox" @bind="_bindOnInput" /> Bind on input</label>
            <label><input type="checkbox" @bind="_enableCustomDatePicker" /> Custom date/time picker</label>
            <label><input type="checkbox" @bind="_checkboxIndeterminate" /> Checkbox indeterminate</label>
            <label><input type="checkbox" @bind="CheckboxRequired" /> Checkbox required</label>
            <label><input type="checkbox" @bind="_switchRequired" /> Switch required</label>
            <label><input type="checkbox" @bind="_showSwitchHandleIcon" /> Switch handle icons</label>
            <label><input type="checkbox" @bind="_showSliderStops" /> Slider stops</label>
            <label><input type="checkbox" @bind="_showSliderValueIndicator" /> Slider value</label>
            <label><input type="checkbox" @bind="_showSliderInsetIcon" /> Slider inset icon</label>
            <label><input type="checkbox" @bind="_comboboxSearchable" /> Combobox searchable</label>
            <label><input type="checkbox" @bind="_allowAutocompleteCustomValue" /> Autocomplete custom values</label>
            <label><input type="checkbox" @bind="_textAreaAutoGrow" /> Textarea auto grow</label>
            <label><input type="checkbox" @bind="_showCounter" /> Counter</label>
            <label><input type="checkbox" @bind="_addLengthLimits" /> Length limits</label>
            <label><input type="checkbox" @bind="_addRangeLimits" /> Range limits</label>
            <label><input type="checkbox" @bind="_autoFocus" /> Autofocus</label>
            <label>Textarea min lines <input type="number" min="1" @bind="_textAreaMinVisibleLines" /></label>
            <label>Textarea max lines <input type="number" min="1" @bind="_textAreaMaxVisibleLines" disabled="@(!_textAreaAutoGrow)" /></label>
            </div>

            <fieldset style="display:grid;grid-template-columns:repeat(auto-fit,minmax(180px,1fr));gap:12px;margin:0;padding:12px;border:1px solid var(--tnt-color-outline-variant);">
            <legend>Field overrides</legend>
            <label><input type="checkbox" @bind="_overrideAppearance" /> Override appearance</label>
            <label><input type="checkbox" @bind="_overrideDensity" /> Override density</label>
            <label><input type="checkbox" @bind="_overrideDisabled" /> Override disabled</label>
            <label><input type="checkbox" @bind="_overrideReadOnly" /> Override readonly</label>

            <label>
                Field appearance
                <select @bind="_fieldAppearance">
                    @foreach (var appearance in Enum.GetValues<NTFormAppearance>()) {
                        <option value="@appearance">@appearance</option>
                    }
                </select>
            </label>

            <label>
                Field density
                <select @bind="_fieldDensity">
                    @foreach (var density in Enum.GetValues<NTFormDensity>()) {
                        <option value="@density">@density</option>
                    }
                </select>
            </label>
            </fieldset>

            <fieldset style="display:grid;grid-template-columns:repeat(auto-fit,minmax(180px,1fr));gap:12px;margin:0;padding:12px;border:1px solid var(--tnt-color-outline-variant);">
            <legend>Color overrides</legend>
            <label><input type="checkbox" @bind="_useCustomColors" /> Use custom colors</label>

            <label>
                Text
                <select @bind="_textColor" disabled="@(!_useCustomColors)">
                    @foreach (var color in ColorOptions) {
                        <option value="@color">@color</option>
                    }
                </select>
            </label>

            <label>
                Background
                <select @bind="_backgroundColor" disabled="@(!_useCustomColors)">
                    @foreach (var color in ColorOptions) {
                        <option value="@color">@color</option>
                    }
                </select>
            </label>

            <label>
                Label
                <select @bind="_labelColor" disabled="@(!_useCustomColors)">
                    @foreach (var color in ColorOptions) {
                        <option value="@color">@color</option>
                    }
                </select>
            </label>

            <label>
                Supporting
                <select @bind="_supportingTextColor" disabled="@(!_useCustomColors)">
                    @foreach (var color in ColorOptions) {
                        <option value="@color">@color</option>
                    }
                </select>
            </label>

            <label>
                Prefix/suffix
                <select @bind="_prefixSuffixColor" disabled="@(!_useCustomColors)">
                    @foreach (var color in ColorOptions) {
                        <option value="@color">@color</option>
                    }
                </select>
            </label>

            <label>
                Icons
                <select @bind="_iconColor" disabled="@(!_useCustomColors)">
                    @foreach (var color in ColorOptions) {
                        <option value="@color">@color</option>
                    }
                </select>
            </label>

            <label>
                Placeholder
                <select @bind="_placeholderColor" disabled="@(!_useCustomColors)">
                    @foreach (var color in ColorOptions) {
                        <option value="@color">@color</option>
                    }
                </select>
            </label>

            <label>
                Outline
                <select @bind="_outlineColor" disabled="@(!_useCustomColors)">
                    @foreach (var color in ColorOptions) {
                        <option value="@color">@color</option>
                    }
                </select>
            </label>

            <label>
                Hover outline
                <select @bind="_hoverOutlineColor" disabled="@(!_useCustomColors)">
                    @foreach (var color in ColorOptions) {
                        <option value="@color">@color</option>
                    }
                </select>
            </label>

            <label>
                Focus
                <select @bind="_focusColor" disabled="@(!_useCustomColors)">
                    @foreach (var color in ColorOptions) {
                        <option value="@color">@color</option>
                    }
                </select>
            </label>

            <label>
                Caret
                <select @bind="_caretColor" disabled="@(!_useCustomColors)">
                    @foreach (var color in ColorOptions) {
                        <option value="@color">@color</option>
                    }
                </select>
            </label>

            <label>
                Active indicator
                <select @bind="_activeIndicatorColor" disabled="@(!_useCustomColors)">
                    @foreach (var color in ColorOptions) {
                        <option value="@color">@color</option>
                    }
                </select>
            </label>

            <label>
                Hover indicator
                <select @bind="_hoverActiveIndicatorColor" disabled="@(!_useCustomColors)">
                    @foreach (var color in ColorOptions) {
                        <option value="@color">@color</option>
                    }
                </select>
            </label>

            <label>
                State layer
                <select @bind="_stateLayerColor" disabled="@(!_useCustomColors)">
                    @foreach (var color in ColorOptions) {
                        <option value="@color">@color</option>
                    }
                </select>
            </label>

            <label>
                Error
                <select @bind="_errorColor" disabled="@(!_useCustomColors)">
                    @foreach (var color in ColorOptions) {
                        <option value="@color">@color</option>
                    }
                </select>
            </label>

            <label>
                Error caret
                <select @bind="_errorCaretColor" disabled="@(!_useCustomColors)">
                    @foreach (var color in ColorOptions) {
                        <option value="@color">@color</option>
                    }
                </select>
            </label>

            <label>
                Disabled content
                <select @bind="_disabledContentColor" disabled="@(!_useCustomColors)">
                    @foreach (var color in ColorOptions) {
                        <option value="@color">@color</option>
                    }
                </select>
            </label>

            <label>
                Disabled background
                <select @bind="_disabledContainerColor" disabled="@(!_useCustomColors)">
                    @foreach (var color in ColorOptions) {
                        <option value="@color">@color</option>
                    }
                </select>
            </label>

            <label>
                Disabled outline
                <select @bind="_disabledOutlineColor" disabled="@(!_useCustomColors)">
                    @foreach (var color in ColorOptions) {
                        <option value="@color">@color</option>
                    }
                </select>
            </label>
            </fieldset>
        }
    </div>

    <NTForm Model="_model"
            Appearance="@_appearance"
            Density="@_density"
            Disabled="@_disabled"
            ReadOnly="@_readOnly"
            ShowRequiredSupportingText="@_showRequiredText"
            RequiredSupportingText="Required for setup"
            OnValidSubmit="HandleValidSubmit"
            OnInvalidSubmit="HandleInvalidSubmit">
        <DataAnnotationsValidator />

        <div style="display:grid;gap:16px;">
            <div style="display:grid;grid-template-columns:repeat(auto-fit,minmax(240px,1fr));gap:16px;">
                <NTInputText @bind-Value="_model.Name"
                             Appearance="@FieldAppearanceOverride"
                             ActiveIndicatorColor="@ActiveIndicatorColorOverride"
                             BackgroundColor="@BackgroundColorOverride"
                             CaretColor="@CaretColorOverride"
                             Density="@FieldDensityOverride"
                             DisabledContainerColor="@DisabledContainerColorOverride"
                             DisabledContentColor="@DisabledContentColorOverride"
                             DisabledOutlineColor="@DisabledOutlineColorOverride"
                             Disabled="@FieldDisabledOverride"
                             ErrorCaretColor="@ErrorCaretColorOverride"
                             ErrorColor="@ErrorColorOverride"
                             FocusColor="@FocusColorOverride"
                             HoverActiveIndicatorColor="@HoverActiveIndicatorColorOverride"
                             HoverOutlineColor="@HoverOutlineColorOverride"
                             IconColor="@IconColorOverride"
                             LabelColor="@LabelColorOverride"
                             ReadOnly="@FieldReadOnlyOverride"
                             Label="@Label"
                             OutlineColor="@OutlineColorOverride"
                             Placeholder="@Placeholder"
                             PlaceholderColor="@PlaceholderColorOverride"
                             PrefixSuffixColor="@PrefixSuffixColorOverride"
                             StateLayerColor="@StateLayerColorOverride"
                             SupportingText="@SupportingText"
                             SupportingTextColor="@SupportingTextColorOverride"
                             TextColor="@TextColorOverride"
                             ErrorText="@ErrorText"
                             LeadingIcon="@LeadingIcon"
                             TrailingIcon="@TrailingIcon"
                             PrefixText="@PrefixText"
                             SuffixText="@SuffixText"
                             BindOnInput="@_bindOnInput"
                             AutoFocus="@_autoFocus"
                             ShowCharacterCounter="@_showCounter"
                             AdditionalAttributes="@TextAttributes" />

                <NTInputText @bind-Value="_model.Email"
                             Appearance="@FieldAppearanceOverride"
                             ActiveIndicatorColor="@ActiveIndicatorColorOverride"
                             BackgroundColor="@BackgroundColorOverride"
                             CaretColor="@CaretColorOverride"
                             Density="@FieldDensityOverride"
                             DisabledContainerColor="@DisabledContainerColorOverride"
                             DisabledContentColor="@DisabledContentColorOverride"
                             DisabledOutlineColor="@DisabledOutlineColorOverride"
                             Disabled="@FieldDisabledOverride"
                             ErrorCaretColor="@ErrorCaretColorOverride"
                             ErrorColor="@ErrorColorOverride"
                             FocusColor="@FocusColorOverride"
                             HoverActiveIndicatorColor="@HoverActiveIndicatorColorOverride"
                             HoverOutlineColor="@HoverOutlineColorOverride"
                             IconColor="@IconColorOverride"
                             LabelColor="@LabelColorOverride"
                             ReadOnly="@FieldReadOnlyOverride"
                             Label="@EmailLabel"
                             OutlineColor="@OutlineColorOverride"
                             Placeholder="@Placeholder"
                             PlaceholderColor="@PlaceholderColorOverride"
                             PrefixSuffixColor="@PrefixSuffixColorOverride"
                             StateLayerColor="@StateLayerColorOverride"
                             SupportingText="@SupportingText"
                             SupportingTextColor="@SupportingTextColorOverride"
                             TextColor="@TextColorOverride"
                             ErrorText="@ErrorText"
                             LeadingIcon="@LeadingIcon"
                             TrailingIcon="@TrailingIcon"
                             PrefixText="@EmailPrefixText"
                             SuffixText="@SuffixText"
                             BindOnInput="@_bindOnInput"
                             InputType="@_textInputType"
                             PhoneMask="@_phoneMask"
                             ShowCharacterCounter="@_showCounter"
                             AdditionalAttributes="@TextAttributes" />

                <NTInputText @bind-Value="_model.Phone"
                             Appearance="@FieldAppearanceOverride"
                             ActiveIndicatorColor="@ActiveIndicatorColorOverride"
                             BackgroundColor="@BackgroundColorOverride"
                             CaretColor="@CaretColorOverride"
                             Density="@FieldDensityOverride"
                             DisabledContainerColor="@DisabledContainerColorOverride"
                             DisabledContentColor="@DisabledContentColorOverride"
                             DisabledOutlineColor="@DisabledOutlineColorOverride"
                             Disabled="@FieldDisabledOverride"
                             ErrorCaretColor="@ErrorCaretColorOverride"
                             ErrorColor="@ErrorColorOverride"
                             FocusColor="@FocusColorOverride"
                             HoverActiveIndicatorColor="@HoverActiveIndicatorColorOverride"
                             HoverOutlineColor="@HoverOutlineColorOverride"
                             IconColor="@IconColorOverride"
                             LabelColor="@LabelColorOverride"
                             ReadOnly="@FieldReadOnlyOverride"
                             Label="@PhoneLabel"
                             OutlineColor="@OutlineColorOverride"
                             Placeholder="@PhonePlaceholder"
                             PlaceholderColor="@PlaceholderColorOverride"
                             PrefixSuffixColor="@PrefixSuffixColorOverride"
                             StateLayerColor="@StateLayerColorOverride"
                             SupportingText="@PhoneSupportingText"
                             SupportingTextColor="@SupportingTextColorOverride"
                             TextColor="@TextColorOverride"
                             ErrorText="@ErrorText"
                             LeadingIcon="@PhoneLeadingIcon"
                             TrailingIcon="@TrailingIcon"
                             PrefixText="@PhonePrefixText"
                             SuffixText="@SuffixText"
                             BindOnInput="@_bindOnInput"
                             InputType="TextInputType.Tel"
                             PhoneMask="@_phoneMask"
                             ShowCharacterCounter="@_showCounter"
                             AdditionalAttributes="@PhoneAttributes" />

                <div style="grid-column:1 / -1;">
                    <NTTextArea @bind-Value="_model.Notes"
                                Appearance="@FieldAppearanceOverride"
                                ActiveIndicatorColor="@ActiveIndicatorColorOverride"
                                BackgroundColor="@BackgroundColorOverride"
                                CaretColor="@CaretColorOverride"
                                Density="@FieldDensityOverride"
                                DisabledContainerColor="@DisabledContainerColorOverride"
                                DisabledContentColor="@DisabledContentColorOverride"
                                DisabledOutlineColor="@DisabledOutlineColorOverride"
                                Disabled="@FieldDisabledOverride"
                                ErrorCaretColor="@ErrorCaretColorOverride"
                                ErrorColor="@ErrorColorOverride"
                                FocusColor="@FocusColorOverride"
                                HoverActiveIndicatorColor="@HoverActiveIndicatorColorOverride"
                                HoverOutlineColor="@HoverOutlineColorOverride"
                                IconColor="@IconColorOverride"
                                LabelColor="@LabelColorOverride"
                                ReadOnly="@FieldReadOnlyOverride"
                                Label="@NotesLabel"
                                OutlineColor="@OutlineColorOverride"
                                Placeholder="@Placeholder"
                                PlaceholderColor="@PlaceholderColorOverride"
                                PrefixSuffixColor="@PrefixSuffixColorOverride"
                                StateLayerColor="@StateLayerColorOverride"
                                SupportingText="@NotesSupportingText"
                                SupportingTextColor="@SupportingTextColorOverride"
                                TextColor="@TextColorOverride"
                                ErrorText="@ErrorText"
                                LeadingIcon="@NotesLeadingIcon"
                                TrailingIcon="@TrailingIcon"
                                PrefixText="@PrefixText"
                                SuffixText="@SuffixText"
                                AutoGrow="@_textAreaAutoGrow"
                                MinVisibleLines="@_textAreaMinVisibleLines"
                                MaxVisibleLines="@_textAreaMaxVisibleLines"
                                BindOnInput="@_bindOnInput"
                                ShowCharacterCounter="@_showCounter"
                                AdditionalAttributes="@TextAreaAttributes" />
                </div>

                <div style="grid-column:1 / -1;">
                    <NTFileUpload @bind-Value="_model.Files"
                                  Appearance="@FieldAppearanceOverride"
                                  ActiveIndicatorColor="@ActiveIndicatorColorOverride"
                                  BackgroundColor="@BackgroundColorOverride"
                                  CaretColor="@CaretColorOverride"
                                  Density="@FieldDensityOverride"
                                  DisabledContainerColor="@DisabledContainerColorOverride"
                                  DisabledContentColor="@DisabledContentColorOverride"
                                  DisabledOutlineColor="@DisabledOutlineColorOverride"
                                  Disabled="@FieldDisabledOverride"
                                  ErrorCaretColor="@ErrorCaretColorOverride"
                                  ErrorColor="@ErrorColorOverride"
                                  FocusColor="@FocusColorOverride"
                                  HoverActiveIndicatorColor="@HoverActiveIndicatorColorOverride"
                                  HoverOutlineColor="@HoverOutlineColorOverride"
                                  IconColor="@IconColorOverride"
                                  LabelColor="@LabelColorOverride"
                                  ReadOnly="@FieldReadOnlyOverride"
                                  Label="@FileLabel"
                                  OutlineColor="@OutlineColorOverride"
                                  PlaceholderColor="@PlaceholderColorOverride"
                                  PrefixSuffixColor="@PrefixSuffixColorOverride"
                                  StateLayerColor="@StateLayerColorOverride"
                                  SupportingText="@FileSupportingText"
                                  SupportingTextColor="@SupportingTextColorOverride"
                                  TextColor="@TextColorOverride"
                                  ErrorText="@ErrorText"
                                  LeadingIcon="@FileLeadingIcon"
                                  TrailingIcon="@TrailingIcon"
                                  Accept=".txt,.pdf,image/*,.zip"
                                  Multiple="true"
                                  MaximumFileCount="3"
                                  MaximumFileSize="5242880000"
                                  OnUploadFile="OnDemoUploadFileAsync"
                                  AdditionalAttributes="@FileAttributes" />
                </div>

                <NTInputNumeric TNumber="int"
                                @bind-Value="_model.Quantity"
                                Appearance="@FieldAppearanceOverride"
                                ActiveIndicatorColor="@ActiveIndicatorColorOverride"
                                BackgroundColor="@BackgroundColorOverride"
                                CaretColor="@CaretColorOverride"
                                Density="@FieldDensityOverride"
                                DisabledContainerColor="@DisabledContainerColorOverride"
                                DisabledContentColor="@DisabledContentColorOverride"
                                DisabledOutlineColor="@DisabledOutlineColorOverride"
                                Disabled="@FieldDisabledOverride"
                                ErrorCaretColor="@ErrorCaretColorOverride"
                                ErrorColor="@ErrorColorOverride"
                                FocusColor="@FocusColorOverride"
                                HoverActiveIndicatorColor="@HoverActiveIndicatorColorOverride"
                                HoverOutlineColor="@HoverOutlineColorOverride"
                                IconColor="@IconColorOverride"
                                LabelColor="@LabelColorOverride"
                                ReadOnly="@FieldReadOnlyOverride"
                                Label="@QuantityLabel"
                                OutlineColor="@OutlineColorOverride"
                                Placeholder="@Placeholder"
                                PlaceholderColor="@PlaceholderColorOverride"
                                PrefixSuffixColor="@PrefixSuffixColorOverride"
                                StateLayerColor="@StateLayerColorOverride"
                                SupportingText="@SupportingText"
                                SupportingTextColor="@SupportingTextColorOverride"
                                TextColor="@TextColorOverride"
                                ErrorText="@ErrorText"
                                LeadingIcon="@LeadingIcon"
                                TrailingIcon="@TrailingIcon"
                                PrefixText="@PrefixText"
                                SuffixText="@QuantitySuffixText"
                                BindOnInput="@_bindOnInput"
                                AdditionalAttributes="@NumericAttributes" />

                <NTInputCurrency @bind-Value="_model.Price"
                                 Appearance="@FieldAppearanceOverride"
                                 ActiveIndicatorColor="@ActiveIndicatorColorOverride"
                                 BackgroundColor="@BackgroundColorOverride"
                                 CaretColor="@CaretColorOverride"
                                 Density="@FieldDensityOverride"
                                 DisabledContainerColor="@DisabledContainerColorOverride"
                                 DisabledContentColor="@DisabledContentColorOverride"
                                 DisabledOutlineColor="@DisabledOutlineColorOverride"
                                 Disabled="@FieldDisabledOverride"
                                 ErrorCaretColor="@ErrorCaretColorOverride"
                                 ErrorColor="@ErrorColorOverride"
                                 FocusColor="@FocusColorOverride"
                                 HoverActiveIndicatorColor="@HoverActiveIndicatorColorOverride"
                                 HoverOutlineColor="@HoverOutlineColorOverride"
                                 IconColor="@IconColorOverride"
                                 LabelColor="@LabelColorOverride"
                                 ReadOnly="@FieldReadOnlyOverride"
                                 Label="@PriceLabel"
                                 OutlineColor="@OutlineColorOverride"
                                 Placeholder="@Placeholder"
                                 PlaceholderColor="@PlaceholderColorOverride"
                                 PrefixSuffixColor="@PrefixSuffixColorOverride"
                                 StateLayerColor="@StateLayerColorOverride"
                                 SupportingText="@SupportingText"
                                 SupportingTextColor="@SupportingTextColorOverride"
                                 TextColor="@TextColorOverride"
                                 ErrorText="@ErrorText"
                                 LeadingIcon="@LeadingIcon"
                                 TrailingIcon="@TrailingIcon"
                                 SuffixText="@SuffixText"
                                 BindOnInput="@_bindOnInput"
                                 AdditionalAttributes="@NumericAttributes" />

                <NTInputSlider TNumber="int"
                               @bind-Value="_model.Volume"
                               ActiveTrackColor="@ActiveIndicatorColorOverride"
                               Disabled="@FieldDisabledOverride"
                               DisabledColor="@DisabledContentColorOverride"
                               ErrorColor="@ErrorColorOverride"
                               FocusColor="@FocusColorOverride"
                               HandleColor="@ActiveIndicatorColorOverride"
                               InsetIcon="@VolumeSliderInsetIcon"
                               Label="@VolumeSliderLabel"
                               LabelColor="@LabelColorOverride"
                               Max="100"
                               Min="0"
                               Orientation="@_sliderOrientation"
                               ReadOnly="@FieldReadOnlyOverride"
                               ShowStops="@_showSliderStops"
                               ShowValueIndicator="@_showSliderValueIndicator"
                               Size="@_sliderSize"
                               StateLayerColor="@StateLayerColorOverride"
                               StopCount="11"
                               SupportingText="@VolumeSliderSupportingText"
                               SupportingTextColor="@SupportingTextColorOverride"
                               BindOnInput="@_bindOnInput"
                               ErrorText="@ErrorText"
                               AdditionalAttributes="@VolumeSliderAttributes" />

                <NTInputSlider TNumber="int"
                               @bind-Value="_model.TemperatureOffset"
                               ActiveTrackColor="@ActiveIndicatorColorOverride"
                               Disabled="@FieldDisabledOverride"
                               DisabledColor="@DisabledContentColorOverride"
                               ErrorColor="@ErrorColorOverride"
                               FocusColor="@FocusColorOverride"
                               HandleColor="@ActiveIndicatorColorOverride"
                               Label="@TemperatureSliderLabel"
                               LabelColor="@LabelColorOverride"
                               Max="50"
                               Min="-50"
                               ReadOnly="@FieldReadOnlyOverride"
                               ShowStops="@_showSliderStops"
                               ShowValueIndicator="@_showSliderValueIndicator"
                               Size="@_sliderSize"
                               StateLayerColor="@StateLayerColorOverride"
                               StopCount="11"
                               SupportingText="@TemperatureSliderSupportingText"
                               SupportingTextColor="@SupportingTextColorOverride"
                               Variant="NTSliderVariant.Centered"
                               BindOnInput="@_bindOnInput"
                               ErrorText="@ErrorText"
                               AdditionalAttributes="@TemperatureSliderAttributes" />

                <NTInputRangeSlider TNumber="int"
                                    @bind-Value="_model.BudgetRange"
                                    ActiveTrackColor="@ActiveIndicatorColorOverride"
                                    Disabled="@FieldDisabledOverride"
                                    DisabledColor="@DisabledContentColorOverride"
                                    ErrorColor="@ErrorColorOverride"
                                    FocusColor="@FocusColorOverride"
                                    HandleColor="@ActiveIndicatorColorOverride"
                                    Label="@BudgetRangeLabel"
                                    LabelColor="@LabelColorOverride"
                                    Max="100"
                                    Min="0"
                                    ReadOnly="@FieldReadOnlyOverride"
                                    ShowStops="@_showSliderStops"
                                    ShowValueIndicator="@_showSliderValueIndicator"
                                    Size="@_sliderSize"
                                    StateLayerColor="@StateLayerColorOverride"
                                    StopCount="11"
                                    SupportingText="@BudgetRangeSupportingText"
                                    SupportingTextColor="@SupportingTextColorOverride"
                                    BindOnInput="@_bindOnInput"
                                    ErrorText="@ErrorText"
                                    AdditionalAttributes="@BudgetRangeAttributes" />

                <div style="min-height:280px;">
                    <NTInputSlider TNumber="int"
                                   @bind-Value="_model.Brightness"
                                   ActiveTrackColor="@ActiveIndicatorColorOverride"
                                   Disabled="@FieldDisabledOverride"
                                   DisabledColor="@DisabledContentColorOverride"
                                   ErrorColor="@ErrorColorOverride"
                                   FocusColor="@FocusColorOverride"
                                   HandleColor="@ActiveIndicatorColorOverride"
                                   Label="@BrightnessSliderLabel"
                                   LabelColor="@LabelColorOverride"
                                   Max="100"
                                   Min="0"
                                   Orientation="NTSliderOrientation.Vertical"
                                   ReadOnly="@FieldReadOnlyOverride"
                                   ShowStops="@_showSliderStops"
                                   ShowValueIndicator="@_showSliderValueIndicator"
                                   Size="@_sliderSize"
                                   StateLayerColor="@StateLayerColorOverride"
                                   StopCount="11"
