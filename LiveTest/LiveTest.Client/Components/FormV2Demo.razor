    private static DemoModel CreateModel() => new();

    private void HandleCheckboxIndeterminateChanged(bool indeterminate) => _checkboxIndeterminate = indeterminate;

    private void HandleInvalidSubmit() => _submitMessage = "Invalid submit";

    private void HandleValidSubmit() => _submitMessage = "Valid submit";

    private async Task OnDemoUploadFileAsync(NTFileUploadEventArgs args) {
        if (args.Stream is not null) {
            await args.Stream.CopyToAsync(System.IO.Stream.Null);
        }

        await Task.Delay(3000);
    }

    private void ResetModel() {
        _model = CreateModel();
        _submitMessage = "Not submitted";
    }

    private void ToggleControls() => _showControls = !_showControls;

    private enum DateInputKind {
        Date,
        Month,
        Time,
        DateTime
    }

    private enum DemoPriority {
        Low,
        Medium,
        High
    }

    private sealed class DemoModel {
        [Required]
        [StringLength(24, MinimumLength = 2)]
        public string? Name { get; set; }

        [EmailAddress]
        public string? Email { get; set; }

        [Phone]
        public string? Phone { get; set; }

        [StringLength(280, MinimumLength = 2)]
        public string? Notes { get; set; }

        public IReadOnlyList<IBrowserFile>? Files { get; set; }

        [Range(1, 25)]
        public int? Quantity { get; set; }

        [Range(typeof(decimal), "1", "25")]
        public decimal? Price { get; set; }

        public int Volume { get; set; } = 55;

        public int TemperatureOffset { get; set; } = -20;

        public int Brightness { get; set; } = 70;

        public NTSliderRange<int> BudgetRange { get; set; } = new(25, 75);

        public string Status { get; set; } = string.Empty;

        public bool? Approved { get; set; }

        public DemoPriority? Priority { get; set; }

        public IReadOnlyList<string> Tags { get; set; } = [];

        public string? City { get; set; }

        public bool Accepted { get; set; }

        public string ContactMethod { get; set; } = "email";

        public bool NotificationsEnabled { get; set; }

        public DateTime? Appointment { get; set; }

        public DateOnly? StartDate { get; set; }

        public TimeOnly? StartTime { get; set; }
    }
