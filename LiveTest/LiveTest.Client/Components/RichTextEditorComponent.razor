@using NTComponents

<NTForm Model="Model"
        Appearance="NTFormAppearance.Outlined"
        Density="NTFormDensity.Standard"
        OnValidSubmit="HandleValidSubmit"
        OnInvalidSubmit="HandleInvalidSubmit">
    <DataAnnotationsValidator />

    <div class="rich-text-editor-form">
        <NTRichTextEditor @bind-Value="Model.Value"
                          ElementId="@EditorId"
                          Label="@($"{ModeName} notes")"
                          Placeholder="Type some formatted text"
                          SupportingText="Toolbar actions update markdown while the editing surface stays rendered."
                          LeadingIcon="@MaterialIcon.Notes"
                          TrailingIcon="@MaterialIcon.EditNote"
                          BindOnInput="true"
                          ShowCharacterCounter="true"
                          OnBlurCallback="HandleBlurAsync"
                          maxlength="2400" />

        <div class="rich-text-editor-actions">
            <NTButton Type="ButtonType.Submit"
                      Label="Submit"
                      LeadingIcon="@MaterialIcon.Check"
                      Variant="NTButtonVariant.Filled" />
            <NTButton Type="ButtonType.Button"
                      Label="Reset"
                      LeadingIcon="@MaterialIcon.RestartAlt"
                      Variant="NTButtonVariant.Outlined"
                      OnClickCallback="Reset" />
        </div>

        <output class="rich-text-editor-status" data-testid="@($"{ModeKey}-status")">
            @SubmitMessage
        </output>
        <output class="rich-text-editor-status" data-testid="@($"{ModeKey}-blur-status")">
            @BlurMessage
        </output>

        <details class="rich-text-editor-output" open>
            <summary>Markdown value</summary>
            <pre data-testid="@($"{ModeKey}-markdown")">@(Model.Value ?? string.Empty)</pre>
        </details>
    </div>
</NTForm>
