@using NTComponents

<TnTRow>
    <TnTColumn S="12">
        <h4>Default</h4>
        <TnTButton OnClickCallback="ShowDefaultAsync">
            Show default snackbar
        </TnTButton>
        <TnTButton OnClickCallback="ShowLongMessageAsync">
            Show two-line snackbar
        </TnTButton>
    </TnTColumn>
</TnTRow>

<TnTRow>
    <TnTColumn S="12">
        <h4>Action</h4>
        <TnTButton OnClickCallback="ShowUndoAsync">
            Show undo action
        </TnTButton>
        <TnTButton OnClickCallback="ShowRetryAsync">
            Show retry action
        </TnTButton>
        <TnTButton OnClickCallback="ShowMultiActionAsync">
            Show multi action
        </TnTButton>
        <TnTButton OnClickCallback="ShowFiveActionAsync">
            Show five actions
        </TnTButton>
    </TnTColumn>
</TnTRow>

<TnTRow>
    <TnTColumn S="12">
        <h4>Queueing</h4>
        <TnTButton OnClickCallback="QueueSnackbarsAsync">
            Queue three snackbars
        </TnTButton>
    </TnTColumn>
</TnTRow>

<TnTRow>
    <TnTColumn S="12">
        <h4>Color Overrides</h4>
        <TnTButton OnClickCallback="ShowCustomAsync">
            Show custom colors
        </TnTButton>
    </TnTColumn>
</TnTRow>

@code {
    [Inject]
    private INTSnackbarService _snackbarService { get; set; } = default!;

    private async Task QueueSnackbarsAsync() {
        await _snackbarService.ShowAsync("First queued snackbar");
        await _snackbarService.ShowAsync("Second queued snackbar");
        await _snackbarService.ShowAsync("Third queued snackbar");
    }

    private async Task ShowCustomAsync() {
        await _snackbarService.ShowAsync(
            message: "Connection restored",
            timeout: 8,
            showClose: true,
            backgroundColor: TnTColor.SecondaryContainer,
            textColor: TnTColor.OnSecondaryContainer,
            actionColor: TnTColor.Primary
        );
    }

    private async Task ShowDefaultAsync() {
        await _snackbarService.ShowAsync("Changes saved");
    }

    private async Task ShowLongMessageAsync() {
        await _snackbarService.ShowAsync("Draft saved to your workspace and synchronized with the server.");
    }

    private async Task ShowMultiActionAsync() {
        await _snackbarService.ShowAsync("Draft link ready", [
            new NTSnackbarAction("Copy", async () => {
                await Task.Delay(150);
                return false;
            }),
            new NTSnackbarAction("Open", () => Task.FromResult(true))
        ]);
    }

    private async Task ShowFiveActionAsync() {
        await _snackbarService.ShowAsync("Choose an action", [
            new NTSnackbarAction("One", () => Task.FromResult(false)),
            new NTSnackbarAction("Two", () => Task.FromResult(false)),
            new NTSnackbarAction("Three", () => Task.FromResult(false)),
            new NTSnackbarAction("Four", () => Task.FromResult(false)),
            new NTSnackbarAction("Done", () => Task.FromResult(true))
        ]);
    }

    private async Task ShowRetryAsync() {
        await _snackbarService.ShowAsync("Upload failed", "Retry", async () => {
            await Task.Delay(250);
            await _snackbarService.ShowAsync("Upload started");
        }, showClose: true);
    }

    private async Task ShowUndoAsync() {
        await _snackbarService.ShowAsync("Email archived", "Undo", async () => {
            await Task.Delay(150);
            await _snackbarService.ShowAsync("Archive undone");
        });
    }
}
