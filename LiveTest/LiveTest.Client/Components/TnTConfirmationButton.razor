@using Microsoft.AspNetCore.Components
@using NTComponents
@using NTComponents.Dialog
@inject ITnTDialogService DialogService

<TnTButton OnClickCallback="@OpenConfirmationDialog">
    Confirmation
</TnTButton>

@code {
    private async Task OpenConfirmationDialog() {
        await DialogService.OpenConfirmationDialogAsync(EventCallback.Empty);
    }
}
