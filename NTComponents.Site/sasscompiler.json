{
  "Arguments": "--error-css --style=expanded --no-source-map",
  "GenerateScopedCss": true,
  "ScopedCssFolders": [
    "Layout",
    "Pages"
  ],
  "Compilations": [
    {
      "Source": "wwwroot/css/app.scss",
      "Target": "wwwroot/css/app.css"
    }
  ],
  "Configurations": {
    "Release": {
      "Arguments": "--no-error-css --style=compressed --no-source-map"
    }
  }
}
