@page "/docs/api/{Slug}"
@inject DocumentationCatalog Catalog
@inject NavigationManager Navigation

<PageTitle>@(ApiType?.DisplayName ?? "API") - NTComponents</PageTitle>

@if (ApiType is null)
{
    <section class="docs-page-hero compact">
        <h1>API type not found</h1>
        <p>The requested API reference entry does not exist.</p>
        <TnTButton OnClickCallback="@(_ => Navigation.NavigateTo("/docs/api"))">Back to API reference</TnTButton>
    </section>
}
else
{
    <section class="docs-page-hero compact">
        <NTTag BackgroundColor="TnTColor.PrimaryContainer" TextColor="TnTColor.OnPrimaryContainer">
            @ApiType.Kind
        </NTTag>
        <h1>@ApiType.DisplayName</h1>
        <p>@ApiType.Summary</p>
        <code>@ApiType.Namespace</code>
    </section>

    <ApiReferenceSection Type="ApiType.Type" />
}

@code {
    [Parameter]
    public string? Slug { get; set; }

    private ApiDocumentationEntry? ApiType => Catalog.GetApiTypeBySlug(Slug);
}
