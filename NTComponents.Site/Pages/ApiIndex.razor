@page "/docs/api"
@inject DocumentationCatalog Catalog
@inject NavigationManager Navigation

<PageTitle>API Reference - NTComponents</PageTitle>

<section class="docs-page-hero compact">
    <NTTag BackgroundColor="TnTColor.PrimaryContainer" TextColor="TnTColor.OnPrimaryContainer">
        API Reference
    </NTTag>
    <h1>Generated API reference</h1>
    <p>
        Browse the compile-time documentation model generated from NTComponents XML comments.
    </p>
</section>

@foreach (var group in Catalog.ApiGroups)
{
    <section class="docs-section">
        <h2>@group.Name</h2>
        <div class="api-list">
            @foreach (var apiType in group.Entries)
            {
                <TnTCard Appearance="CardAppearance.Outlined" class="api-list-row">
                    <div>
                        <h3>@apiType.DisplayName</h3>
                        <p>@apiType.Namespace</p>
                    </div>
                    <NTTag BackgroundColor="TnTColor.SecondaryContainer" TextColor="TnTColor.OnSecondaryContainer">
                        @apiType.Kind
                    </NTTag>
                    <TnTButton Appearance="ButtonAppearance.Text" TextColor="TnTColor.Primary" OnClickCallback="@(_ => Navigation.NavigateTo($"/docs/api/{apiType.Slug}"))">
                        Reference
                    </TnTButton>
                </TnTCard>
            }
        </div>
    </section>
}
