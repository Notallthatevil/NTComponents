@page "/docs/components/{Slug}"
@inject DocumentationCatalog Catalog
@inject NavigationManager Navigation

<PageTitle>@(Component?.DisplayName ?? "Component") - NTComponents</PageTitle>

@if (Component is null)
{
    <section class="docs-page-hero compact">
        <h1>Component not found</h1>
        <p>The requested component guide does not exist.</p>
        <TnTButton OnClickCallback="@(_ => Navigation.NavigateTo("/docs/components"))">Back to components</TnTButton>
    </section>
}
else
{
    <section class="docs-page-hero compact">
        <NTTag BackgroundColor="TnTColor.PrimaryContainer" TextColor="TnTColor.OnPrimaryContainer">
            @Component.Category
        </NTTag>
        <h1>@Component.DisplayName</h1>
        <p>@Component.Summary</p>
    </section>

    <section class="docs-section">
        <h2>Examples</h2>
        <div class="docs-example-grid">
            @foreach (var example in Component.Examples)
            {
                <TnTCard Appearance="CardAppearance.Outlined" class="docs-example-card">
                    <h3>@example.Title</h3>
                    <p>@example.Summary</p>
                    <pre><code>@example.Code</code></pre>
                    @if (example.RuntimeOptions.Count > 0)
                    {
                        <div class="docs-option-list">
                            @foreach (var option in example.RuntimeOptions)
                            {
                                <NTTag BackgroundColor="TnTColor.SecondaryContainer" TextColor="TnTColor.OnSecondaryContainer">
                                    @option.Name: @option.Kind
                                </NTTag>
                            }
                        </div>
                    }
                </TnTCard>
            }
        </div>
    </section>

    <section class="docs-section">
        <h2>Runtime playground</h2>
        <ComponentPlayground Component="Component" />
    </section>

    @if (Component.ApiType is not null)
    {
        <ApiReferenceSection Type="Component.ApiType" />
    }
}

@code {
    [Parameter]
    public string? Slug { get; set; }

    private ComponentDocumentationEntry? Component => Catalog.GetComponentBySlug(Slug);
}
