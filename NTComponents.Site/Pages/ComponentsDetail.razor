@page "/docs/components/{Slug}"
@inject DocumentationCatalog DocumentationCatalog

<PageTitle>@(TypePage is null ? "Components | NTComponents" : $"{TypePage.Name} | NTComponents Components")</PageTitle>

@if (TypePage is null) {
    <section class="docs-page">
        <header class="docs-hero">
            <p class="docs-kicker @NTTypography.LabelLarge.ToCssClass()">Components</p>
            <h1 class="@NTTypography.DisplaySmall.ToCssClass()">Component not found</h1>
            <p class="@NTTypography.BodyLarge.ToCssClass()">
                The requested component page was not found in the generated documentation model.
            </p>
            <a class="doc-back-link @NTTypography.LabelLarge.ToCssClass()" href="/docs/components">Back to components index</a>
        </header>
    </section>
}
else {
    <DocumentationTypeDetailView TypePage="TypePage"
                                 DemoComponentType="DemoComponentType"
                                 BackHref="/docs/components"
                                 BackLabel="Back to components index" />
}

@code {
    [Parameter]
    public string Slug { get; set; } = string.Empty;

    private DocumentationTypePage? TypePage { get; set; }
    private Type? DemoComponentType { get; set; }

    protected override void OnParametersSet() {
        TypePage = DocumentationCatalog.TryGetComponentType(Slug, out var typePage) ? typePage : null;
        DemoComponentType = TypePage is null ? null : typeof(NTButton).Assembly.GetType(TypePage.FullName);
    }
}
