@page "/docs/theming"
@inject NavigationManager Navigation

<PageTitle>Theming - NTComponents</PageTitle>

<section class="docs-page-hero compact">
    <NTTag BackgroundColor="TnTColor.PrimaryContainer" TextColor="TnTColor.OnPrimaryContainer">
        Theming
    </NTTag>
    <h1>Theme NTComponents applications</h1>
    <p>
        NTComponents themes are CSS files containing `--tnt-color-*` variables. The site ships six files
        for default, medium contrast, and high contrast light/dark modes.
    </p>
    <TnTButton OnClickCallback="@(_ => Navigation.NavigateTo("/tools/theme-converter"))">
        Open theme converter
    </TnTButton>
</section>

<section class="docs-section">
    <h2>Theme files</h2>
    <div class="docs-card-grid">
        @foreach (var fileName in ThemeFiles)
        {
            <TnTCard Appearance="CardAppearance.Outlined" class="docs-result-card">
                <MaterialIcon Icon="palette" />
                <h3>@fileName</h3>
                <p>Place this file under `wwwroot/Themes` and point `TnTThemeToggle` at the folder.</p>
            </TnTCard>
        }
    </div>
</section>

<section class="docs-section">
    <h2>Generator workflow</h2>
    <TnTCard Appearance="CardAppearance.Filled" class="docs-copy-card">
        <ol>
            <li>Create a palette in Material Theme Builder and export the JSON theme.</li>
            <li>Paste the JSON into the converter.</li>
            <li>Copy the generated CSS into `light.css`, `dark.css`, and available contrast files.</li>
            <li>Render `<TnTThemeToggle ThemesRoot="/Themes" />` in the application shell.</li>
        </ol>
    </TnTCard>
</section>

@code {
    private static readonly string[] ThemeFiles = [
        "light.css",
        "light-mc.css",
        "light-hc.css",
        "dark.css",
        "dark-mc.css",
        "dark-hc.css"
    ];
}
