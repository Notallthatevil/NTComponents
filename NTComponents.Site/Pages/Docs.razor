@page "/docs"
@inject DocumentationCatalog Catalog
@inject NavigationManager Navigation

<PageTitle>Documentation - NTComponents</PageTitle>

<section class="docs-page-hero">
    <NTTag BackgroundColor="TnTColor.PrimaryContainer" TextColor="TnTColor.OnPrimaryContainer">
        Documentation
    </NTTag>
    <h1>Build with NTComponents</h1>
    <p>
        Search curated component guides and generated API documentation from the NTComponents source generator.
    </p>
    <TnTInputText @bind-Value="_query"
                  Label="Search documentation"
                  Placeholder="Try button, grid, theme, dialog"
                  BindOnInput="true" />
</section>

@if (SearchResults.Count > 0)
{
    <section class="docs-section">
        <h2>Search results</h2>
        <div class="docs-card-grid">
            @foreach (var result in SearchResults)
            {
                <TnTCard Appearance="CardAppearance.Outlined" class="docs-result-card">
                    <NTTag BackgroundColor="TnTColor.SecondaryContainer" TextColor="TnTColor.OnSecondaryContainer">
                        @result.Kind
                    </NTTag>
                    <h3>@result.Title</h3>
                    <p>@result.Summary</p>
                    <TnTButton Appearance="ButtonAppearance.Text" TextColor="TnTColor.Primary" OnClickCallback="@(_ => OpenResult(result))">
                        Open
                    </TnTButton>
                </TnTCard>
            }
        </div>
    </section>
}

<section class="docs-section">
    <h2>Start here</h2>
    <div class="docs-card-grid">
        <TnTCard Appearance="CardAppearance.Filled" class="docs-route-card">
            <MaterialIcon Icon="widgets" />
            <h3>Component guides</h3>
            <p>Browse curated component pages with examples, runtime options, and generated API reference.</p>
            <TnTButton Appearance="ButtonAppearance.Text" TextColor="TnTColor.Primary" OnClickCallback="@(_ => Navigation.NavigateTo("/docs/components"))">
                Browse components
            </TnTButton>
        </TnTCard>
        <TnTCard Appearance="CardAppearance.Filled" class="docs-route-card">
            <MaterialIcon Icon="api" />
            <h3>API reference</h3>
            <p>Inspect generated type documentation, members, signatures, inherited properties, and summaries.</p>
            <TnTButton Appearance="ButtonAppearance.Text" TextColor="TnTColor.Primary" OnClickCallback="@(_ => Navigation.NavigateTo("/docs/api"))">
                Open API
            </TnTButton>
        </TnTCard>
        <TnTCard Appearance="CardAppearance.Filled" class="docs-route-card">
            <MaterialIcon Icon="palette" />
            <h3>Theming</h3>
            <p>Generate Material themes, convert tokens, and wire the six NTComponents theme files.</p>
            <TnTButton Appearance="ButtonAppearance.Text" TextColor="TnTColor.Primary" OnClickCallback="@(_ => Navigation.NavigateTo("/docs/theming"))">
                Theme docs
            </TnTButton>
        </TnTCard>
    </div>
</section>

<section class="docs-section">
    <h2>Featured components</h2>
    <div class="docs-card-grid">
        @foreach (var component in Catalog.Components.Where(static component => component.IsFeatured).Take(8))
        {
            <TnTCard Appearance="CardAppearance.Outlined" class="docs-result-card">
                <NTTag BackgroundColor="TnTColor.TertiaryContainer" TextColor="TnTColor.OnTertiaryContainer">
                    @component.Category
                </NTTag>
                <h3>@component.DisplayName</h3>
                <p>@component.Summary</p>
                <TnTButton Appearance="ButtonAppearance.Text" TextColor="TnTColor.Primary" OnClickCallback="@(_ => Navigation.NavigateTo($"/docs/components/{component.Slug}"))">
                    Open guide
                </TnTButton>
            </TnTCard>
        }
    </div>
</section>

@code {
    private string? _query;

    private IReadOnlyList<DocumentationSearchResult> SearchResults => Catalog.Search(_query, 8);

    private void OpenResult(DocumentationSearchResult result)
    {
        var route = result.Kind == DocumentationSearchResultKind.Component
            ? $"/docs/components/{result.Slug}"
            : $"/docs/api/{result.Slug}";
        Navigation.NavigateTo(route);
    }
}
