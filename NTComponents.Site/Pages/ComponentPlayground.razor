@using System.Globalization
@using System.Linq.Expressions
@using System.Reflection
@using Microsoft.AspNetCore.Components.Rendering

<div class="docs-playground">
    <div class="docs-playground-header">
        <div>
            <h3>@Component.DisplayName playground</h3>
            <p>@GetPlaygroundSummary()</p>
        </div>
        <TnTInputSwitch @bind-Value="_showRawRazor" Label="Raw Razor" />
    </div>

    <div class="docs-playground-split">
        <div class="@($"docs-playground-preview{(_showRawRazor ? " docs-playground-raw-preview" : string.Empty)}")">
            @if (_showRawRazor)
            {
                <pre class="docs-raw-razor"><code>@GetRawRazor()</code></pre>
            }
            else
            {
                @if (CanUseDynamicPreview)
                {
                    <div class="docs-dynamic-preview">
                        <DynamicComponent Type="_componentType!" Parameters="BuildPreviewParameters()" />
                    </div>
                }
                else
                {
                    @switch (Component.TypeName)
                    {
                        case "TnTAccordion":
                        case "TnTAccordionChild":
                            <TnTAccordion LimitToOneExpanded="@(GetBoolParameter("LimitToOneExpanded", true))">
                                <TnTAccordionChild Label="@GetDisplayText()" OpenByDefault="true">
                                    <p>Use accordion children to disclose related content without leaving the page.</p>
                                </TnTAccordionChild>
                                <TnTAccordionChild Label="Details">
                                    <p>The parent controls colors, expansion behavior, and child registration.</p>
                                </TnTAccordionChild>
                            </TnTAccordion>
                            break;
                        case "TnTBadge":
                            <div class="docs-badge-demo">
                                <TnTBadge BackgroundColor="@(GetEnumParameter("BackgroundColor", TnTColor.Error))"
                                          TextColor="@(GetEnumParameter("TextColor", TnTColor.OnError))"
                                          TextAlignment="@(GetEnumParameter("TextAlignment", TextAlign.Center))">
                                    @GetDisplayText()
                                </TnTBadge>
                            </div>
                            break;
                        case "NTButtonGroup":
                            <NTButtonGroup TObjectType="string"
                                           @bind-SelectedKey="_selectedChoice"
                                           Appearance="@(GetEnumParameter("Appearance", ButtonAppearance.Filled))"
                                           ButtonSize="@(GetEnumParameter("ButtonSize", Size.Small))"
                                           Disabled="@(GetBoolParameter("Disabled"))"
                                           AriaLabel="@GetStringParameter("AriaLabel", "Playground mode")">
                                <NTButtonGroupItem Key="@("docs")" Label="Docs" IsDefaultSelected="true" />
                                <NTButtonGroupItem Key="@("api")" Label="API" />
                                <NTButtonGroupItem Key="@("theme")" Label="Theme" />
                            </NTButtonGroup>
                            break;
                        case "TnTCarousel":
                        case "TnTCarouselItem":
                            <TnTCarousel Appearance="@(GetEnumParameter("Appearance", CarouselAppearance.Centered))"
                                         EnableSnapping="@(GetBoolParameter("EnableSnapping", true))"
                                         AutoPlayInterval="@(GetNumberParameter("AutoPlayInterval", 5000))">
                                <TnTCarouselItem>
                                    <div class="docs-carousel-demo">Overview</div>
                                </TnTCarouselItem>
                                <TnTCarouselItem>
                                    <div class="docs-carousel-demo alternate">Examples</div>
                                </TnTCarouselItem>
                            </TnTCarousel>
                            break;
                        case "TnTDivider":
                            <div class="docs-divider-demo">
                                <span>Before</span>
                                <TnTDivider Direction="@(GetEnumParameter("Direction", LayoutDirection.Horizontal))"
                                            Color="@(GetNullableEnumParameter<TnTColor>("Color", TnTColor.OutlineVariant))" />
                                <span>After</span>
                            </div>
                            break;
                        case "TnTInputCheckbox":
                            <TnTInputCheckbox @bind-Value="_selected"
                                              Label="@GetStringParameter("Label", GetDisplayText())"
                                              Disabled="@(GetBoolParameter("Disabled"))" />
                            break;
                        case "TnTInputRadio":
                        case "TnTInputRadioGroup":
                            <TnTInputRadioGroup TInputType="string" @bind-Value="_selectedChoice" Label="@GetStringParameter("Label", GetDisplayText())">
                                <TnTInputRadio TInputType="string" Value="@("docs")" Label="Docs" />
                                <TnTInputRadio TInputType="string" Value="@("api")" Label="API" />
                            </TnTInputRadioGroup>
                            break;
                        case "TnTInputSelect":
                        case "NTInputSelect":
                            <TnTInputSelect TInputType="string"
                                            @bind-Value="_selectedChoice"
                                            Label="@GetStringParameter("Label", GetDisplayText())"
                                            Disabled="@(GetBoolParameter("Disabled"))">
                                <option value="docs">Docs</option>
                                <option value="api">API</option>
                                <option value="theme">Theme</option>
                            </TnTInputSelect>
                            break;
                        case "TnTInputSwitch":
                            <TnTInputSwitch @bind-Value="_selected"
                                            Label="@GetStringParameter("Label", GetDisplayText())"
                                            Disabled="@(GetBoolParameter("Disabled"))" />
                            break;
                        case "TnTInputText":
                            <TnTInputText @bind-Value="_textValue"
                                          Label="@GetStringParameter("Label", GetDisplayText())"
                                          Disabled="@(GetBoolParameter("Disabled"))"
                                          BindOnInput="true" />
                            break;
                        case "TnTInputTextArea":
                            <TnTInputTextArea @bind-Value="_textValue"
                                              Label="@GetStringParameter("Label", GetDisplayText())"
                                              Disabled="@(GetBoolParameter("Disabled"))"
                                              SizeByContent="@(GetBoolParameter("SizeByContent", true))" />
                            break;
                        case "TnTLayout":
                        case "TnTHeader":
                        case "TnTBody":
                        case "TnTFooter":
                        case "TnTSideNav":
                        case "TnTSideNavLink":
                        case "TnTSideNavMenuGroup":
                        case "TnTSideNavToggle":
                        case "TnTContainer":
                        case "TnTRow":
                        case "TnTColumn":
                            <TnTLayout class="docs-layout-demo">
                                <TnTSideNav class="docs-layout-demo-nav">
                                    <TnTSideNavLink href="/docs" Icon="@MaterialIcon.Article">Docs</TnTSideNavLink>
                                    <TnTSideNavLink href="/docs/components" Icon="@MaterialIcon.Widgets">Components</TnTSideNavLink>
                                </TnTSideNav>
                                <TnTHeader class="docs-layout-demo-header">
                                    <TnTSideNavToggle />
                                    <span>@GetDisplayText()</span>
                                </TnTHeader>
                                <TnTBody class="docs-layout-demo-body">
                                    <TnTContainer>
                                        <TnTRow>
                                            <TnTColumn>
                                                Layout content
                                            </TnTColumn>
                                        </TnTRow>
                                    </TnTContainer>
                                </TnTBody>
                            </TnTLayout>
                            break;
                        case "TnTProgressIndicator":
                            <TnTProgressIndicator Appearance="@(GetEnumParameter("Appearance", ProgressAppearance.Linear))"
                                                  Max="@(GetNumberParameter("Max", 100))"
                                                  ProgressColor="@(GetEnumParameter("ProgressColor", TnTColor.Primary))"
                                                  Show="@(GetBoolParameter("Show", true))"
                                                  Size="@(GetEnumParameter("Size", Size.Small))"
                                                  Value="@(GetNumberParameter("Value", 68))">
                                @GetDisplayText()
                            </TnTProgressIndicator>
                            break;
                        case "TnTSkeleton":
                            <div class="docs-skeleton-stack">
                                <TnTSkeleton Appearance="@(GetEnumParameter("Appearance", SkeletonAppearance.Square))"
                                             BackgroundColor="@(GetEnumParameter("BackgroundColor", TnTColor.PrimaryContainer))"
                                             AnimatedColor="@(GetNullableEnumParameter<TnTColor>("AnimatedColor", TnTColor.OnPrimaryContainer))"
                                             FillHeight="@(GetBoolParameter("FillHeight"))" />
                                <TnTSkeleton Appearance="SkeletonAppearance.Square"
                                             BackgroundColor="@(GetEnumParameter("BackgroundColor", TnTColor.PrimaryContainer))"
                                             AnimatedColor="@(GetNullableEnumParameter<TnTColor>("AnimatedColor", TnTColor.OnPrimaryContainer))" />
                                <TnTSkeleton Appearance="SkeletonAppearance.Square"
                                             BackgroundColor="@(GetEnumParameter("BackgroundColor", TnTColor.PrimaryContainer))"
                                             AnimatedColor="@(GetNullableEnumParameter<TnTColor>("AnimatedColor", TnTColor.OnPrimaryContainer))" />
                            </div>
                            break;
                        case "TnTTabView":
                        case "TnTTabChild":
                            <TnTTabView Appearance="@(GetEnumParameter("Appearance", TabViewAppearance.Primary))">
                                <TnTTabChild Label="Usage">Use tabs for related panels.</TnTTabChild>
                                <TnTTabChild Label="API">Keep API details close to examples.</TnTTabChild>
                            </TnTTabView>
                            break;
                        case "TnTTooltip":
                            <TnTButton>
                                Hover for help
                                <TnTTooltip BackgroundColor="@(GetEnumParameter("BackgroundColor", TnTColor.SurfaceVariant))"
                                            BorderColor="@(GetEnumParameter("BorderColor", TnTColor.Outline))"
                                            ShowDelay="@(GetNumberParameter("ShowDelay", 500))"
                                            TextColor="@(GetEnumParameter("TextColor", TnTColor.OnSurfaceVariant))"
                                            HideDelay="@(GetNumberParameter("HideDelay", 200))">
                                    @GetDisplayText()
                                </TnTTooltip>
                            </TnTButton>
                            break;
                        default:
                            <div class="docs-preview-placeholder">
                                <NTTag BackgroundColor="TnTColor.TertiaryContainer" TextColor="TnTColor.OnTertiaryContainer">
                                    @Component.Category
                                </NTTag>
                                <h4>@Component.DisplayName</h4>
                                <p>
                                    This component has a generated playground shell. The parameter editor covers every
                                    public Blazor parameter and feeds the raw Razor output.
                                </p>
                                <dl>
                                    <div>
                                        <dt>Parameters</dt>
                                        <dd>@_parameterStates.Count</dd>
                                    </div>
                                    <div>
                                        <dt>API properties</dt>
                                        <dd>@(Component.ApiType?.Properties.Count ?? 0)</dd>
                                    </div>
                                </dl>
                            </div>
                            break;
                    }
                }
            }
        </div>

        @RenderParameterEditor()
    </div>
</div>

@code {
    [Parameter, EditorRequired]
    public ComponentDocumentationEntry Component { get; set; } = default!;

    private static readonly HashSet<string> _dynamicPreviewComponents = new(StringComparer.Ordinal) {
        "MaterialIcon",
        "NTTag",
        "TnTAnimation",
        "TnTButton",
        "TnTCard",
        "TnTChip",
        "TnTFabButton",
        "TnTImageButton",
        "TnTMeasurements",
        "TnTThemeToggle",
    };

    private static readonly HashSet<string> _skippedPreviewParameters = new(StringComparer.Ordinal) {
        "AdditionalAttributes",
        "AutoFocus",
        "ElementId",
        "ElementLang",
        "ElementName",
        "ElementTitle",
    };

    private readonly List<PlaygroundParameterState> _parameterStates = [];
    private Type? _componentType;
    private string? _loadedTypeName;
    private string _textValue = "NTComponents documentation";
    private string _selectedChoice = "docs";
    private bool _selected = true;
    private bool _showRawRazor;

    private bool CanUseDynamicPreview =>
        _componentType is not null &&
        !_componentType.ContainsGenericParameters &&
        _dynamicPreviewComponents.Contains(Component.TypeName);

    protected override void OnParametersSet() {
        if (string.Equals(_loadedTypeName, Component.TypeName, StringComparison.Ordinal)) {
            return;
        }

        _loadedTypeName = Component.TypeName;
        _componentType = ComponentParameterInspector.ResolveComponentType(Component.TypeName);
        _parameterStates.Clear();
        _parameterStates.AddRange(ComponentParameterInspector.GetParameters(Component).Select(CreateState));
    }

    private RenderFragment RenderParameterEditor() =>
        builder => {
            var sequence = 0;
            builder.OpenElement(sequence++, "div");
            builder.AddAttribute(sequence++, "class", "docs-control-grid docs-parameter-grid");

            builder.OpenElement(sequence++, "div");
            builder.AddAttribute(sequence++, "class", "docs-parameter-summary");
            builder.OpenElement(sequence++, "strong");
            builder.AddContent(sequence++, "Parameters");
            builder.CloseElement();
            builder.OpenComponent<NTTag>(sequence++);
            builder.AddAttribute(sequence++, nameof(NTTag.BackgroundColor), TnTColor.SecondaryContainer);
            builder.AddAttribute(sequence++, nameof(NTTag.TextColor), TnTColor.OnSecondaryContainer);
            builder.AddAttribute(sequence++, nameof(NTTag.ChildContent), (RenderFragment)(tagBuilder => tagBuilder.AddContent(0, _parameterStates.Count.ToString(CultureInfo.InvariantCulture))));
            builder.CloseComponent();
            builder.CloseElement();

            foreach (var state in _parameterStates) {
                builder.OpenElement(sequence++, "div");
                builder.AddAttribute(sequence++, "class", "docs-parameter-control");
                builder.AddContent(sequence++, RenderParameterControl(state));
                builder.CloseElement();
            }

            builder.CloseElement();
        };

    private RenderFragment RenderParameterControl(PlaygroundParameterState state) =>
        builder => {
            var sequence = 0;
            builder.OpenElement(sequence++, "div");
            builder.AddAttribute(sequence++, "class", "docs-parameter-label");
            builder.OpenElement(sequence++, "div");
            builder.OpenElement(sequence++, "strong");
            builder.AddContent(sequence++, state.Parameter.Name);
            builder.CloseElement();
            builder.OpenElement(sequence++, "code");
            builder.AddContent(sequence++, state.Parameter.TypeName);
            builder.CloseElement();
            builder.CloseElement();
            if (state.Parameter.IsRequired) {
                builder.OpenElement(sequence++, "span");
                builder.AddAttribute(sequence++, "class", "docs-parameter-pill");
                builder.AddContent(sequence++, "Required");
                builder.CloseElement();
            }
            if (state.Parameter.IsInherited) {
                builder.OpenElement(sequence++, "span");
                builder.AddAttribute(sequence++, "class", "docs-parameter-pill muted");
                builder.AddContent(sequence++, "Inherited");
                builder.CloseElement();
            }
            builder.CloseElement();

            if (!string.IsNullOrWhiteSpace(state.Parameter.Summary)) {
                builder.OpenElement(sequence++, "p");
                builder.AddAttribute(sequence++, "class", "docs-parameter-help");
                builder.AddContent(sequence++, state.Parameter.Summary);
                builder.CloseElement();
            }

            switch (state.Parameter.EditorKind) {
                case ComponentParameterEditorKind.Boolean:
                    builder.OpenComponent<TnTInputSwitch>(sequence++);
                    builder.AddAttribute(sequence++, nameof(TnTInputSwitch.Value), state.BoolValue);
                    builder.AddAttribute(sequence++, nameof(TnTInputSwitch.ValueChanged), EventCallback.Factory.Create<bool>(this, value => state.BoolValue = value));
                    builder.AddAttribute(sequence++, nameof(TnTInputSwitch.ValueExpression), (Expression<Func<bool>>)(() => state.BoolValue));
                    builder.AddAttribute(sequence++, nameof(TnTInputSwitch.Label), "Value");
                    builder.CloseComponent();
                    break;
                case ComponentParameterEditorKind.Select:
                case ComponentParameterEditorKind.Color:
                    builder.OpenComponent<TnTInputSelect<string>>(sequence++);
                    builder.AddAttribute(sequence++, nameof(TnTInputSelect<string>.Value), state.RawValue);
                    builder.AddAttribute(sequence++, nameof(TnTInputSelect<string>.ValueChanged), EventCallback.Factory.Create<string?>(this, value => state.RawValue = value ?? string.Empty));
                    builder.AddAttribute(sequence++, nameof(TnTInputSelect<string>.ValueExpression), (Expression<Func<string?>>)(() => state.RawValue));
                    builder.AddAttribute(sequence++, nameof(TnTInputSelect<string>.Label), "Value");
                    builder.AddAttribute(sequence++, nameof(TnTInputSelect<string>.ChildContent), (RenderFragment)(optionsBuilder => {
                        var optionSequence = 0;
                        if (Nullable.GetUnderlyingType(state.Parameter.ParameterType) is not null) {
                            optionsBuilder.OpenElement(optionSequence++, "option");
                            optionsBuilder.AddAttribute(optionSequence++, "value", string.Empty);
                            optionsBuilder.AddContent(optionSequence++, "Default");
                            optionsBuilder.CloseElement();
                        }
                        foreach (var value in state.Parameter.Values) {
                            optionsBuilder.OpenElement(optionSequence++, "option");
                            optionsBuilder.AddAttribute(optionSequence++, "value", value);
                            optionsBuilder.AddContent(optionSequence++, value);
                            optionsBuilder.CloseElement();
                        }
                    }));
                    builder.CloseComponent();
                    break;
                case ComponentParameterEditorKind.MultilineText:
                case ComponentParameterEditorKind.RenderFragment:
                    builder.OpenComponent<TnTInputTextArea>(sequence++);
                    builder.AddAttribute(sequence++, nameof(TnTInputTextArea.Value), state.RawValue);
                    builder.AddAttribute(sequence++, nameof(TnTInputTextArea.ValueChanged), EventCallback.Factory.Create<string?>(this, value => state.RawValue = value ?? string.Empty));
                    builder.AddAttribute(sequence++, nameof(TnTInputTextArea.ValueExpression), (Expression<Func<string?>>)(() => state.RawValue));
                    builder.AddAttribute(sequence++, nameof(TnTInputTextArea.Label), GetEditorLabel(state));
                    builder.AddAttribute(sequence++, nameof(TnTInputTextArea.SizeByContent), true);
                    builder.CloseComponent();
                    break;
                default:
                    builder.OpenComponent<TnTInputText>(sequence++);
                    builder.AddAttribute(sequence++, nameof(TnTInputText.Value), state.RawValue);
                    builder.AddAttribute(sequence++, nameof(TnTInputText.ValueChanged), EventCallback.Factory.Create<string?>(this, value => state.RawValue = value ?? string.Empty));
                    builder.AddAttribute(sequence++, nameof(TnTInputText.ValueExpression), (Expression<Func<string?>>)(() => state.RawValue));
                    builder.AddAttribute(sequence++, nameof(TnTInputText.Label), GetEditorLabel(state));
                    builder.AddAttribute(sequence++, nameof(TnTInputText.BindOnInput), true);
                    builder.CloseComponent();
                    break;
            }
        };

    private PlaygroundParameterState CreateState(ComponentParameterDocumentation parameter) {
        var state = new PlaygroundParameterState(parameter);
        state.BoolValue = GetInitialBoolValue(parameter);
        state.RawValue = GetInitialRawValue(parameter, state.BoolValue);
        return state;
    }

    private Dictionary<string, object?> BuildPreviewParameters() {
        var parameters = new Dictionary<string, object?>(StringComparer.Ordinal);
        foreach (var state in _parameterStates) {
            if (!CanBindPreviewParameter(state)) {
                continue;
            }

            if (TryGetPreviewValue(state, out var value)) {
                parameters[state.Parameter.Name] = value;
            }
        }

        return parameters;
    }

    private static bool CanBindPreviewParameter(PlaygroundParameterState state) {
        if (_skippedPreviewParameters.Contains(state.Parameter.Name)) {
            return false;
        }

        return state.Parameter.EditorKind is not ComponentParameterEditorKind.EventCallback
            and not ComponentParameterEditorKind.Expression;
    }

    private static bool TryGetPreviewValue(PlaygroundParameterState state, out object? value) {
        value = null;
        var parameterType = state.Parameter.ParameterType;
        var underlyingType = Nullable.GetUnderlyingType(parameterType) ?? parameterType;

        switch (state.Parameter.EditorKind) {
            case ComponentParameterEditorKind.Boolean:
                value = state.BoolValue;
                return true;
            case ComponentParameterEditorKind.Number:
                return TryConvertNumber(state.RawValue, underlyingType, out value);
            case ComponentParameterEditorKind.Select:
            case ComponentParameterEditorKind.Color:
                if (string.IsNullOrWhiteSpace(state.RawValue) || !underlyingType.IsEnum) {
                    return false;
                }

                value = Enum.Parse(underlyingType, state.RawValue);
                return true;
            case ComponentParameterEditorKind.Icon:
                return TryCreateIcon(state.RawValue, out value);
            case ComponentParameterEditorKind.RenderFragment:
                value = (RenderFragment)(builder => builder.AddContent(0, state.RawValue));
                return true;
            default:
                value = state.RawValue;
                return true;
        }
    }

    private static bool TryConvertNumber(string rawValue, Type targetType, out object? value) {
        value = null;
        if (string.IsNullOrWhiteSpace(rawValue)) {
            return false;
        }

        if (targetType == typeof(int) && int.TryParse(rawValue, NumberStyles.Integer, CultureInfo.InvariantCulture, out var intValue)) {
            value = intValue;
            return true;
        }

        if (targetType == typeof(long) && long.TryParse(rawValue, NumberStyles.Integer, CultureInfo.InvariantCulture, out var longValue)) {
            value = longValue;
            return true;
        }

        if (targetType == typeof(short) && short.TryParse(rawValue, NumberStyles.Integer, CultureInfo.InvariantCulture, out var shortValue)) {
            value = shortValue;
            return true;
        }

        if (targetType == typeof(float) && float.TryParse(rawValue, NumberStyles.Float, CultureInfo.InvariantCulture, out var floatValue)) {
            value = floatValue;
            return true;
        }

        if (targetType == typeof(double) && double.TryParse(rawValue, NumberStyles.Float, CultureInfo.InvariantCulture, out var doubleValue)) {
            value = doubleValue;
            return true;
        }

        if (targetType == typeof(decimal) && decimal.TryParse(rawValue, NumberStyles.Float, CultureInfo.InvariantCulture, out var decimalValue)) {
            value = decimalValue;
            return true;
        }

        return false;
    }

    private static bool TryCreateIcon(string rawValue, out object? value) {
        value = null;
        if (string.IsNullOrWhiteSpace(rawValue)) {
            return false;
        }

        var iconName = rawValue.StartsWith("MaterialIcon.", StringComparison.Ordinal)
            ? rawValue["MaterialIcon.".Length..]
            : rawValue;
        var iconProperty = typeof(MaterialIcon).GetProperty(iconName, BindingFlags.IgnoreCase | BindingFlags.Public | BindingFlags.Static);
        value = iconProperty?.GetValue(null) ?? MaterialIcon.Save;
        return true;
    }

    private string GetPlaygroundSummary() =>
        Component.Examples.Count > 0
            ? Component.Examples[0].Summary
            : "Generated playground with a raw Razor snippet and API-backed reference data.";

    private string GetRawRazor() {
        var attributes = _parameterStates
            .Where(static state => !string.Equals(state.Parameter.Name, "ChildContent", StringComparison.Ordinal))
            .Select(GetRawAttribute)
            .Where(static value => !string.IsNullOrWhiteSpace(value))
            .ToArray();

        var body = GetStringParameter("ChildContent", string.Empty);
        var genericAttribute = GetGenericAttribute();
        if (!string.IsNullOrWhiteSpace(genericAttribute)) {
            attributes = [genericAttribute, .. attributes];
        }

        if (string.IsNullOrWhiteSpace(body)) {
            return attributes.Length == 0
                ? $"<{Component.TypeName} />"
                : $"<{Component.TypeName}\n    {string.Join("\n    ", attributes)} />";
        }

        return attributes.Length == 0
            ? $"<{Component.TypeName}>\n    {body}\n</{Component.TypeName}>"
            : $"<{Component.TypeName}\n    {string.Join("\n    ", attributes)}>\n    {body}\n</{Component.TypeName}>";
    }

    private string? GetRawAttribute(PlaygroundParameterState state) {
        var name = state.Parameter.Name;

        return state.Parameter.EditorKind switch {
            ComponentParameterEditorKind.Boolean => $"{name}=\"{FormatBool(state.BoolValue)}\"",
            ComponentParameterEditorKind.Number => string.IsNullOrWhiteSpace(state.RawValue) ? null : $"{name}=\"{state.RawValue}\"",
            ComponentParameterEditorKind.Select => string.IsNullOrWhiteSpace(state.RawValue) ? null : $"{name}=\"{GetTypePrefix(state.Parameter.TypeName)}.{state.RawValue}\"",
            ComponentParameterEditorKind.Color => string.IsNullOrWhiteSpace(state.RawValue) ? null : $"{name}=\"TnTColor.{state.RawValue}\"",
            ComponentParameterEditorKind.Icon => string.IsNullOrWhiteSpace(state.RawValue) ? null : $"{name}=\"@{state.RawValue}\"",
            ComponentParameterEditorKind.EventCallback => string.IsNullOrWhiteSpace(state.RawValue) ? null : $"{name}=\"{state.RawValue}\"",
            ComponentParameterEditorKind.RenderFragment => string.IsNullOrWhiteSpace(state.RawValue) ? null : $"{name}=\"@<span>{Escape(state.RawValue)}</span>\"",
            ComponentParameterEditorKind.Expression => string.IsNullOrWhiteSpace(state.RawValue) ? null : $"{name}=\"@{state.RawValue}\"",
            _ => string.IsNullOrWhiteSpace(state.RawValue) ? null : $"{name}=\"{Escape(state.RawValue)}\"",
        };
    }

    private string? GetGenericAttribute() =>
        Component.TypeName switch {
            "TnTInputSelect" or "NTInputSelect" or "TnTInputRadioGroup" or "TnTInputRadio" or "TnTTypeahead" => "TInputType=\"string\"",
            "NTButtonGroup" => "TObjectType=\"string\"",
            _ => null,
        };

    private string GetDisplayText() =>
        GetStringParameter("ChildContent",
            GetStringParameter("Label",
                GetStringParameter("Text",
                    Component.DisplayName)));

    private string GetStringParameter(string name, string fallback) {
        var state = GetState(name);
        return state is null || string.IsNullOrWhiteSpace(state.RawValue) ? fallback : state.RawValue;
    }

    private bool GetBoolParameter(string name, bool fallback = false) {
        var state = GetState(name);
        return state?.BoolValue ?? fallback;
    }

    private double GetNumberParameter(string name, double fallback) {
        var state = GetState(name);
        return state is not null && double.TryParse(state.RawValue, NumberStyles.Float, CultureInfo.InvariantCulture, out var value) ? value : fallback;
    }

    private int GetNumberParameter(string name, int fallback) {
        var state = GetState(name);
        return state is not null && int.TryParse(state.RawValue, NumberStyles.Integer, CultureInfo.InvariantCulture, out var value) ? value : fallback;
    }

    private TEnum GetEnumParameter<TEnum>(string name, TEnum fallback)
        where TEnum : struct, Enum {
        var state = GetState(name);
        return state is not null && Enum.TryParse<TEnum>(state.RawValue, out var value) ? value : fallback;
    }

    private TEnum? GetNullableEnumParameter<TEnum>(string name, TEnum? fallback)
        where TEnum : struct, Enum {
        var state = GetState(name);
        if (state is not null && string.IsNullOrWhiteSpace(state.RawValue)) {
            return null;
        }

        return state is not null && Enum.TryParse<TEnum>(state.RawValue, out var value) ? value : fallback;
    }

    private PlaygroundParameterState? GetState(string name) =>
        _parameterStates.FirstOrDefault(state => string.Equals(state.Parameter.Name, name, StringComparison.Ordinal));

    private string GetEditorLabel(PlaygroundParameterState state) =>
        state.Parameter.EditorKind switch {
            ComponentParameterEditorKind.EventCallback => "Callback expression",
            ComponentParameterEditorKind.Expression => "Razor expression",
            ComponentParameterEditorKind.Icon => "Icon expression",
            ComponentParameterEditorKind.RenderFragment => "Markup",
            _ => "Value",
        };

    private string GetInitialRawValue(ComponentParameterDocumentation parameter, bool boolValue) =>
        parameter.EditorKind switch {
            ComponentParameterEditorKind.Boolean => FormatBool(boolValue),
            ComponentParameterEditorKind.Number => GetInitialNumberValue(parameter),
            ComponentParameterEditorKind.Select or ComponentParameterEditorKind.Color => GetInitialSelectValue(parameter),
            ComponentParameterEditorKind.Icon => parameter.IsRequired || string.Equals(parameter.Name, "Icon", StringComparison.Ordinal) ? "MaterialIcon.Save" : string.Empty,
            ComponentParameterEditorKind.RenderFragment => parameter.Name == "ChildContent" ? Component.DisplayName : "Helpful context",
            ComponentParameterEditorKind.EventCallback => string.Empty,
            ComponentParameterEditorKind.Expression => string.Empty,
            _ => GetInitialStringValue(parameter),
        };

    private string GetInitialStringValue(ComponentParameterDocumentation parameter) =>
        parameter.Name switch {
            "Label" or "Text" or "Title" or "AriaLabel" => Component.DisplayName,
            "Icon" => "widgets",
            "Placeholder" => $"Enter {Component.DisplayName}",
            "SupportingText" or "SubLabel" => "Supporting detail",
            _ => string.Empty,
        };

    private static bool GetInitialBoolValue(ComponentParameterDocumentation parameter) =>
        parameter.Name is "AllowDragging"
            or "AllowOpenByDefault"
            or "AllowPlaceholderSelection"
            or "EnableRipple"
            or "EnableSnapping"
            or "OpenByDefault"
            or "PushNavigationToBottom"
            or "RefocusAfterSelect"
            or "ResetValueOnEscape"
            or "ResetValueOnSelect"
            or "ShouldHavePlaceholderSelected"
            or "Show"
            or "ShowInputLength"
            or "VerticalOnSmallScreens";

    private static string GetInitialNumberValue(ComponentParameterDocumentation parameter) =>
        parameter.Name switch {
            "Max" => "100",
            "Value" => "68",
            "ShowDelay" => "500",
            "HideDelay" => "200",
            "DebounceMilliseconds" => "300",
            "AutoPlayInterval" => "5000",
            "Timeout" => "5",
            _ => "0",
        };

    private static string GetInitialSelectValue(ComponentParameterDocumentation parameter) {
        if (parameter.Values.Count == 0) {
            return string.Empty;
        }

        var preferred = parameter.Name switch {
            "Appearance" => FirstAvailable(parameter, "Filled", "Outlined", "Primary", "Linear", "Square", "Default"),
            "ButtonSize" or "Size" => FirstAvailable(parameter, "Small", "Medium"),
            "Direction" or "LayoutDirection" => FirstAvailable(parameter, "Horizontal", "Vertical"),
            "Position" => FirstAvailable(parameter, "BottomCenter", "CenterTop"),
            "BackgroundColor" => FirstAvailable(parameter, "Primary", "Surface", "SurfaceContainer"),
            "TextColor" => FirstAvailable(parameter, "OnPrimary", "OnSurface"),
            _ => null,
        };

        return preferred ?? parameter.Values[0];
    }

    private static string? FirstAvailable(ComponentParameterDocumentation parameter, params string[] names) =>
        names.FirstOrDefault(name => parameter.Values.Contains(name, StringComparer.Ordinal));

    private static string GetTypePrefix(string typeName) {
        var nullableIndex = typeName.IndexOf('<', StringComparison.Ordinal);
        return nullableIndex > 0 && typeName.StartsWith("Nullable", StringComparison.Ordinal)
            ? typeName[(nullableIndex + 1)..^1]
            : typeName;
    }

    private static string FormatBool(bool value) => value.ToString(CultureInfo.InvariantCulture).ToLowerInvariant();

    private static string Escape(string value) =>
        value
            .Replace("&", "&amp;", StringComparison.Ordinal)
            .Replace("\"", "&quot;", StringComparison.Ordinal)
            .Replace("<", "&lt;", StringComparison.Ordinal)
            .Replace(">", "&gt;", StringComparison.Ordinal);

    private sealed class PlaygroundParameterState(ComponentParameterDocumentation parameter) {
        public ComponentParameterDocumentation Parameter { get; } = parameter;
        public string RawValue { get; set; } = string.Empty;
        public bool BoolValue { get; set; }
    }
}
