@namespace NTComponents.Site.Components
@using Microsoft.AspNetCore.Components
@using Microsoft.AspNetCore.Components.Rendering
@using NTComponents
@using NTComponents.Site.Documentation
@using NTComponents.Virtualization
@using System.Globalization
@using System.Linq.Expressions
@using System.Text

<div class="docs-sandbox">
    <span data-docs-demo-component="@Component.Type.Name" hidden></span>
    <div class="docs-sandbox-toolbar">
        <NTButton Label="Preview" Variant="@(_showMarkup ? NTButtonVariant.Outlined : NTButtonVariant.Filled)" OnClickCallback="_ => ShowPreview()" />
        <NTButton Label="Razor" Variant="@(_showMarkup ? NTButtonVariant.Filled : NTButtonVariant.Outlined)" OnClickCallback="_ => ShowMarkup()" />
    </div>

    @if (Sandbox.UnsupportedReason is not null) {
        <div class="docs-callout">@Sandbox.UnsupportedReason</div>
    }
    else if (_showMarkup) {
        <div class="docs-code-group">
            <span class="docs-preview-label">Generated markup</span>
            <pre class="docs-code"><code>@BuildMarkup()</code></pre>
        </div>
    }
    else {
        <div class="docs-sandbox-grid">
            <div class="docs-sandbox-preview">
                <div class="docs-generated-example">
                    @if (DocumentationCuratedDemo.Supports(Component.Type.Name)) {
                        <DocumentationCuratedDemo Component="Component" ValueProvider="GetRuntimeValue" />
                    }
                    else if (Component.Type.Name == "NTHeadDependencies") {
                        <div class="docs-callout">Place <code>NTHeadDependencies</code> in the document head. It supplies the shared NTComponents styles and browser loader and is intentionally not duplicated inside this page preview.</div>
                        <NTPageScript Src="./js/docs.js" />
                        <span data-docs-demo-component="NTPageScript" hidden></span>
                    }
                    else {
                    <ErrorBoundary @ref="_errorBoundary">
                        <ChildContent>
                            @if (_editContext is not null) {
                                <EditForm EditContext="_editContext">
                                    <DynamicComponent Type="@Sandbox.ComponentType" Parameters="@BuildComponentParameters()" />
                                </EditForm>
                            }
                            else {
                                <DynamicComponent Type="@Sandbox.ComponentType" Parameters="@BuildComponentParameters()" />
                            }
                        </ChildContent>
                        <ErrorContent>
                            <div class="docs-callout">This component requires additional sample data before it can render in the automatic sandbox.</div>
                        </ErrorContent>
                    </ErrorBoundary>
                    @BuildSupplementalDependents()
                    }
                </div>
            </div>

            <div class="docs-sandbox-controls">
                @if (DocumentationCuratedDemo.Supports(Component.Type.Name)) {
                    <p class="docs-muted">This example uses a curated composition so its trigger, host, service, or viewport behavior can be exercised as a complete working scenario.</p>
                }
                @foreach (var group in Sandbox.Parameters.Where(parameter => parameter.IsControlVisible).GroupBy(parameter => parameter.ControlGroup)) {
                    <section class="docs-control-group" data-docs-control-group="@group.Key">
                        <h3>@GetControlGroupLabel(group.Key)</h3>
                        @foreach (var parameter in group) {
                            <div class="docs-control-row" data-docs-control-name="@parameter.Property.Name">
                                @if (!parameter.IsSupported) {
                                    <div>
                                        <strong>@parameter.Property.Name</strong>
                                        <p class="docs-muted">@parameter.UnsupportedReason</p>
                                        <code>@parameter.Property.TypeDisplayName</code>
                                    </div>
                                }
                                else {
                                    @switch (parameter.Kind) {
                                        case SandboxParameterKind.Boolean:
                                            <NTInputSwitch Label="@parameter.Property.Name"
                                                           ElementId="@BuildControlElementId(parameter)"
                                                           Value="@GetBool(parameter)"
                                                           ValueChanged="value => SetValue(parameter, value)"
                                                           ValueExpression="@(() => _form.BooleanValue)"
                                                           SubmitValue="false" />
                                            break;
                                        case SandboxParameterKind.Number:
                                            <NTInputNumeric TNumber="decimal"
                                                            Label="@parameter.Property.Name"
                                                            ElementId="@BuildControlElementId(parameter)"
                                                            Value="@GetNumber(parameter)"
                                                            ValueChanged="value => SetValue(parameter, value ?? 0m)"
                                                            ValueExpression="@(() => _form.NumberValue)"
                                                            SubmitValue="false" />
                                            break;
                                        case SandboxParameterKind.Enum:
                                            <NTSelect TValue="string"
                                                      Label="@parameter.Property.Name"
                                                      ElementId="@BuildControlElementId(parameter)"
                                                      Value="@GetEnumString(parameter)"
                                                      ValueChanged="value => SetEnumValue(parameter, value)"
                                                      ValueExpression="@(() => _form.EnumValue)"
                                                      SubmitValue="false">
                                                @foreach (var option in parameter.Options.OfType<SandboxEnumOption>()) {
                                                    <option value="@option.Label">@option.Label</option>
                                                }
                                            </NTSelect>
                                            break;
                                        case SandboxParameterKind.Icon:
                                            <NTSelect TValue="string"
                                                      Label="@parameter.Property.Name"
                                                      ElementId="@BuildControlElementId(parameter)"
                                                      Value="@GetIconString(parameter)"
                                                      ValueChanged="value => SetIconValue(parameter, value)"
                                                      ValueExpression="@(() => _form.IconValue)"
                                                      SubmitValue="false">
                                                @foreach (var option in parameter.Options.OfType<SandboxIconOption>()) {
                                                    <option value="@option.Label">@option.Label</option>
                                                }
                                            </NTSelect>
                                            break;
                                        case SandboxParameterKind.ChildContent:
                                        case SandboxParameterKind.Text:
                                            <NTInputText Label="@parameter.Property.Name"
                                                         ElementId="@BuildControlElementId(parameter)"
                                                         Value="@GetString(parameter)"
                                                         ValueChanged="value => SetValue(parameter, value ?? string.Empty)"
                                                         ValueExpression="@(() => _form.TextValue)"
                                                         SubmitValue="false" />
                                            break;
                                    }
                                }
                            </div>
                        }
                    </section>
                }
            </div>
        </div>
    }
</div>

@code {
    private readonly Dictionary<string, object?> _values = new(StringComparer.Ordinal);
    private readonly HashSet<string> _modifiedParameterNames = new(StringComparer.Ordinal);
    private readonly SandboxFormModel _form = new();
    private ErrorBoundary? _errorBoundary;
    private EditContext? _editContext;
    private object? _valueHolder;
    private string? _componentKey;
    private bool _showMarkup;

    [Parameter, EditorRequired]
    public ComponentDocumentationEntry Component { get; set; } = default!;

    private SandboxDocumentation Sandbox => Component.Sandbox;

    protected override void OnParametersSet() {
        if (!string.Equals(_componentKey, Component.Type.FullName, StringComparison.Ordinal)) {
            _componentKey = Component.Type.FullName;
            _values.Clear();
            _modifiedParameterNames.Clear();
            PrepareInputContext();
        }

        foreach (var parameter in Sandbox.Parameters.Where(parameter => parameter.IsSupported)) {
            _values.TryAdd(parameter.Property.Name, parameter.DefaultValue);
        }

        _errorBoundary?.Recover();
    }

    private IDictionary<string, object> BuildComponentParameters() {
        var parameters = new Dictionary<string, object>(StringComparer.Ordinal);
        if (Sandbox.ComponentType is null) {
            return parameters;
        }

        foreach (var parameter in Sandbox.Parameters.Where(parameter => parameter.IsSupported && ShouldIncludeParameter(parameter))) {
            var property = Sandbox.ComponentType.GetProperty(parameter.Property.Name);
            if (property is null) {
                continue;
            }

            var convertedValue = parameter.Kind == SandboxParameterKind.Sample
                ? BuildSampleValue(parameter)
                : ConvertValue(parameter, property.PropertyType);
            if (convertedValue is null && !ShouldPassNullParameter(parameter)) {
                continue;
            }

            parameters[parameter.Property.Name] = convertedValue!;
        }

        AddInputParameters(parameters);
        AddPresentationDefaults(parameters);

        return parameters;
    }

    private object? ConvertValue(SandboxParameterDocumentation parameter, Type targetType) {
        var value = GetValue(parameter);
        if (value is null) {
            return null;
        }

        if (parameter.Kind == SandboxParameterKind.ChildContent) {
            return targetType == typeof(RenderFragment) ? BuildChildContent(parameter) : BuildContextualChildContent(targetType);
        }

        if (parameter.Kind == SandboxParameterKind.Icon && value is SandboxIconOption iconOption) {
            return iconOption.Icon;
        }

        if (parameter.Kind == SandboxParameterKind.Enum && value is SandboxEnumOption enumOption) {
            return enumOption.Value;
        }

        var nullableTargetType = Nullable.GetUnderlyingType(targetType) ?? targetType;
        if (nullableTargetType.IsEnum && value.GetType() == nullableTargetType) {
            return value;
        }

        if (nullableTargetType == typeof(string)) {
            return Convert.ToString(value, CultureInfo.InvariantCulture);
        }

        if (nullableTargetType == typeof(bool)) {
            return Convert.ToBoolean(value, CultureInfo.InvariantCulture);
        }

        if (IsNumeric(nullableTargetType)) {
            return Convert.ChangeType(value, nullableTargetType, CultureInfo.InvariantCulture);
        }

        if (nullableTargetType == typeof(DateTime) || nullableTargetType == typeof(DateOnly) || nullableTargetType == typeof(TimeOnly) || nullableTargetType == typeof(DateTimeOffset)) {
            if (value.GetType() == nullableTargetType) {
                return value;
            }

            var text = Convert.ToString(value, CultureInfo.InvariantCulture);
            return nullableTargetType == typeof(DateTime) ? DateTime.Parse(text!, CultureInfo.InvariantCulture) :
                nullableTargetType == typeof(DateOnly) ? DateOnly.Parse(text!, CultureInfo.InvariantCulture) :
                nullableTargetType == typeof(TimeOnly) ? TimeOnly.Parse(text!, CultureInfo.InvariantCulture) :
                DateTimeOffset.Parse(text!, CultureInfo.InvariantCulture);
        }

        return value;
    }

    private void PrepareInputContext() {
        _editContext = null;
        _valueHolder = null;
        var expressionProperty = Sandbox.ComponentType?.GetProperty("ValueExpression");
        if (expressionProperty?.PropertyType.IsGenericType != true) {
            return;
        }

        var functionType = expressionProperty.PropertyType.GetGenericArguments()[0];
        var valueType = functionType.GetGenericArguments()[0];
        _valueHolder = Activator.CreateInstance(typeof(SandboxValue<>).MakeGenericType(valueType));
        _editContext = new EditContext(_valueHolder!);
    }

    private void AddInputParameters(IDictionary<string, object> parameters) {
        if (_valueHolder is null || Sandbox.ComponentType is null) {
            return;
        }

        var valueProperty = Sandbox.ComponentType.GetProperty("Value");
        var expressionProperty = Sandbox.ComponentType.GetProperty("ValueExpression");
        if (valueProperty is null || expressionProperty is null) {
            return;
        }

        var value = BuildInputValue(valueProperty.PropertyType);
        _valueHolder.GetType().GetProperty(nameof(SandboxValue<object>.Value))!.SetValue(_valueHolder, value);
        parameters.TryAdd(valueProperty.Name, value!);
        parameters.TryAdd(expressionProperty.Name, BuildValueExpression(valueProperty.PropertyType));
    }

    private object BuildValueExpression(Type valueType) =>
        GetType().GetMethod(nameof(BuildValueExpressionCore), System.Reflection.BindingFlags.Instance | System.Reflection.BindingFlags.NonPublic)!
            .MakeGenericMethod(valueType)
            .Invoke(this, null)!;

    private Expression<Func<TValue>> BuildValueExpressionCore<TValue>() {
        var holder = (SandboxValue<TValue>)_valueHolder!;
        return () => holder.Value!;
    }

    private object? BuildInputValue(Type valueType) {
        if (valueType == typeof(string)) {
            return Component.Type.Name is "NTInputRadioGroup" or "NTInputSelect" or "NTSelect" ? "one" : DocumentationDemoProfiles.BuildInputValue(Component.Type.Name);
        }

        if (valueType == typeof(bool)) {
            return true;
        }

        if (valueType == typeof(decimal) || valueType == typeof(decimal?)) {
            return 25m;
        }

        if (valueType == typeof(DateTime)) {
            return DateTime.Today.AddHours(9);
        }

        if (valueType == typeof(IReadOnlyList<string>)) {
            return new[] { "one" };
        }

        if (valueType == typeof(NTSliderRange<decimal>)) {
            return new NTSliderRange<decimal>(25m, 75m);
        }

        return valueType.IsValueType ? Activator.CreateInstance(valueType) : null;
    }

    private void AddPresentationDefaults(IDictionary<string, object> parameters) {
        if (Sandbox.ComponentType is null) {
            return;
        }

        if (Sandbox.ComponentType.GetProperty("Label") is not null) {
            var label = Component.Type.Parameters.FirstOrDefault(parameter => string.Equals(parameter.Name, "Label", StringComparison.Ordinal));
            parameters.TryAdd("Label", label is null ? $"{Component.DisplayName} example" : DocumentationDemoProfiles.BuildStringDefault(Component.Type.Name, label, null));
        }

        if (Component.Type.Name == "NTButtonGroup") {
            parameters.TryAdd("SelectedKey", "one");
        }

        if (Component.Type.Name == "NTCarousel") {
            parameters.TryAdd(nameof(NTCarousel.AriaLabel), "Example carousel");
        }

        if (Component.Type.Name == "NTForm") {
            parameters.TryAdd("Model", _form);
            parameters.TryAdd("ChildContent", (RenderFragment<EditContext>)(_ => content => content.AddContent(0, "Example form content")));
        }
        else if (Sandbox.ComponentType.GetProperty("ChildContent")?.PropertyType == typeof(RenderFragment)) {
            parameters.TryAdd("ChildContent", Component.Type.Name == "NTLayout" ? BuildLayoutContent() : (RenderFragment)(content => content.AddContent(0, "Example content")));
        }
    }

    private object? BuildSampleValue(SandboxParameterDocumentation parameter) =>
        (Component.Type.Name, parameter.Property.Name) switch {
            ("NTCombobox", "Items") => new[] { new NTComboboxOption<string>("one", "One"), new NTComboboxOption<string>("two", "Two") },
            ("NTDataGrid", "Items") => new[] { new DocsSampleItem { Name = "Alpha", Value = 1 }, new DocsSampleItem { Name = "Beta", Value = 2 } }.AsQueryable(),
            ("NTPropertyColumn", "Property") => (Expression<Func<DocsSampleItem, string>>)(item => item.Name),
            ("NTScheduler", "Events") => new List<DocsSampleEvent> {
                new() { Title = "Planning", EventStart = DateTimeOffset.Now.Date.AddHours(9), EventEnd = DateTimeOffset.Now.Date.AddHours(10) }
            },
            ("NTTypeahead", "ItemsLookupFunc") => (Func<string, CancellationToken, Task<IEnumerable<string>>>)LookupItemsAsync,
            ("NTVirtualize", "ItemsProvider") => (NTVirtualizeItemsProvider<string>)(request => new ValueTask<TnTItemsProviderResult<string>>(new TnTItemsProviderResult<string>(["First item", "Second item"], 2))),
            _ => null
        };

    private static Task<IEnumerable<string>> LookupItemsAsync(string query, CancellationToken cancellationToken) {
        var items = new[] { "Alpha", "Beta", "Gamma" }.Where(item => item.Contains(query, StringComparison.OrdinalIgnoreCase));
        return Task.FromResult<IEnumerable<string>>(items);
    }

    private object BuildContextualChildContent(Type renderFragmentType) =>
        GetType().GetMethod(nameof(BuildContextualChildContentCore), System.Reflection.BindingFlags.Static | System.Reflection.BindingFlags.NonPublic)!
            .MakeGenericMethod(renderFragmentType.GetGenericArguments()[0])
            .Invoke(null, null)!;

    private static RenderFragment<TValue> BuildContextualChildContentCore<TValue>() => value => builder => builder.AddContent(0, value?.ToString() ?? "Example");

    private string BuildMarkup() {
        if (DocumentationCuratedDemo.Supports(Component.Type.Name)) {
            return DocumentationCuratedDemo.GetGeneratedRazorMarkup(Component.Type.Name, FormatCuratedParameter);
        }

        if (Sandbox.ComponentType is null) {
            return string.Empty;
        }

        var tagName = Sandbox.ComponentType.Name.Split('`')[0];
        var attributes = new List<string>();
        var childContentBlocks = new List<string>();
        foreach (var parameter in Sandbox.Parameters.Where(parameter => parameter.IsSupported && ShouldIncludeParameter(parameter))) {
            if (parameter.Kind == SandboxParameterKind.ChildContent) {
                var childContentMarkup = BuildChildContentMarkup(parameter);
                if (!string.IsNullOrWhiteSpace(childContentMarkup)) {
                    childContentBlocks.Add(childContentMarkup);
                }

                continue;
            }

            var formattedValue = FormatMarkupValue(parameter);
            if (parameter.Kind == SandboxParameterKind.Icon && string.IsNullOrWhiteSpace(formattedValue)) {
                continue;
            }

            attributes.Add(parameter.Kind == SandboxParameterKind.Sample
                ? $"{parameter.Property.Name}=\"{parameter.SampleMarkup}\""
                : FormatMarkupAttribute(parameter, formattedValue));
        }

        AddPresentationMarkupDefaults(attributes);

        if (childContentBlocks.Count == 0 && Sandbox.ComponentType.GetProperty("ChildContent")?.PropertyType == typeof(RenderFragment)) {
            childContentBlocks.Add(Component.Type.Name == "NTLayout"
                ? "<NTHeader>Example header</NTHeader>\r\n<NTBody>Example body content</NTBody>\r\n<NTFooter>Example footer</NTFooter>"
                : DocumentationDemoProfiles.BuildChildContent(Component.Type.Name));
        }

        var markup = FormatElementMarkup(tagName, attributes, string.Join("\r\n", childContentBlocks));
        markup += Component.Type.Name switch {
            "NTFileUpload" => "\r\n\r\n<NTFileUploadItem Name=\"example.txt\" Status=\"Ready\" Percent=\"100\" ShouldShowPercent=\"true\" />",
            "NTHeadDependencies" => "\r\n\r\n<NTPageScript Src=\"./js/docs.js\" />",
            _ => string.Empty
        };

        var code = BuildGeneratedCodeBlock();
        return string.IsNullOrWhiteSpace(code) ? markup : $"{markup}\r\n\r\n@code {{\r\n{IndentMarkup(code, 1)}\r\n}}";
    }

    private void AddPresentationMarkupDefaults(ICollection<string> attributes) {
        if (Sandbox.ComponentType?.GetProperty("Label") is not null && !attributes.Any(attribute => attribute.StartsWith("Label=", StringComparison.Ordinal))) {
            var label = Component.Type.Parameters.FirstOrDefault(parameter => string.Equals(parameter.Name, "Label", StringComparison.Ordinal));
            var labelValue = label is null ? $"{Component.DisplayName} example" : DocumentationDemoProfiles.BuildStringDefault(Component.Type.Name, label, null);
            attributes.Add($"Label=\"{labelValue}\"");
        }

        if (_valueHolder is not null) {
            attributes.Add("@bind-Value=\"_sampleValue\"");
        }

        if (Component.Type.Name == "NTButtonGroup") {
            attributes.Add("SelectedKey=\"one\"");
        }

        else if (Component.Type.Name == "NTForm") {
            attributes.Add("Model=\"@_sampleModel\"");
        }
    }

    private string BuildGeneratedCodeBlock() {
        var declarations = new List<string>();
        var valueProperty = _valueHolder is null ? null : Sandbox.ComponentType?.GetProperty("Value");
        if (valueProperty is not null) {
            declarations.Add($"private {GetCSharpTypeName(valueProperty.PropertyType)} _sampleValue = {BuildInputInitializer(valueProperty.PropertyType)};");
        }

        switch (Component.Type.Name) {
            case "NTCombobox":
                declarations.Add("private static readonly IReadOnlyList<NTComboboxOption<string>> SampleOptions = [new(\"one\", \"One\"), new(\"two\", \"Two\")];");
                break;
            case "NTDataGrid":
                declarations.Add("private static readonly SampleItem[] SampleItems = [new(\"Alpha\", 1), new(\"Beta\", 2)];");
                declarations.Add("private sealed record SampleItem(string Name, int Value);");
                break;
            case "NTScheduler":
                declarations.Add("private static readonly ICollection<NTComponents.Scheduler.TnTEvent> SampleEvents = [new() { Title = \"Planning\", EventStart = DateTimeOffset.Now.Date.AddHours(9), EventEnd = DateTimeOffset.Now.Date.AddHours(10) }];");
                break;
            case "NTTypeahead":
                declarations.Add("private static Task<IEnumerable<string>> LookupItemsAsync(string query, CancellationToken cancellationToken) => Task.FromResult<IEnumerable<string>>([\"Alpha\", \"Beta\", \"Gamma\"]);");
                break;
            case "NTForm":
                declarations.Add("private readonly object _sampleModel = new();");
                break;
            case "NTWizard":
                declarations.Add("private readonly object _wizardModel = new();");
                break;
        }

        return string.Join("\r\n", declarations);
    }

    private string BuildInputInitializer(Type valueType) {
        if (valueType == typeof(string)) {
            return $"\"{DocumentationDemoProfiles.BuildInputValue(Component.Type.Name)}\"";
        }

        if (valueType == typeof(bool)) {
            return "true";
        }

        if (valueType == typeof(decimal) || valueType == typeof(decimal?)) {
            return "25m";
        }

        if (valueType == typeof(DateTime)) {
            return "DateTime.Today.AddHours(9)";
        }

        if (valueType == typeof(IReadOnlyList<string>)) {
            return "[\"one\"]";
        }

        if (valueType == typeof(NTSliderRange<decimal>)) {
            return "new(25m, 75m)";
        }

        return "default!";
    }

    private static string GetCSharpTypeName(Type type) {
        var nullableType = Nullable.GetUnderlyingType(type);
        if (nullableType is not null) {
            return $"{GetCSharpTypeName(nullableType)}?";
        }

        if (type == typeof(string)) {
            return "string";
        }

        if (type == typeof(bool)) {
            return "bool";
        }

        if (type == typeof(decimal)) {
            return "decimal";
        }

        if (type == typeof(int)) {
            return "int";
        }

        if (!type.IsGenericType) {
            return type.FullName?.Replace('+', '.') ?? type.Name;
        }

        var genericName = type.GetGenericTypeDefinition().FullName!;
        genericName = genericName[..genericName.IndexOf('`')].Replace('+', '.');
        return $"{genericName}<{string.Join(", ", type.GetGenericArguments().Select(GetCSharpTypeName))}>";
    }

    private static string FormatElementMarkup(string tagName, IReadOnlyList<string> attributes, string childContent) {
        var builder = new StringBuilder();
        builder.Append('<').Append(tagName);

        foreach (var attribute in attributes) {
            builder.AppendLine();
            builder.Append("    ").Append(attribute);
        }

        if (string.IsNullOrWhiteSpace(childContent)) {
            builder.Append(" />");
            return builder.ToString();
        }

        builder.AppendLine(">");
        builder.AppendLine(IndentMarkup(childContent, 1));
        builder.Append("</").Append(tagName).Append('>');
        return builder.ToString();
    }

    private static string IndentMarkup(string markup, int level) {
        var indent = new string(' ', level * 4);
        var lines = markup.Replace("\r\n", "\n").Trim('\r', '\n').Split('\n');
        return string.Join("\r\n", lines.Select(line => $"{indent}{line}"));
    }

    private static bool ShouldIncludeParameter(SandboxParameterDocumentation parameter) => parameter.IsSupported;

    private bool ShouldPassNullParameter(SandboxParameterDocumentation parameter) =>
        parameter.Kind == SandboxParameterKind.Enum &&
        parameter.IsNullable &&
        _modifiedParameterNames.Contains(parameter.Property.Name);

    private string BuildControlElementId(SandboxParameterDocumentation parameter) =>
        $"docs-sandbox-{Component.Slug}-{DocumentationCatalog.CreateSlug(parameter.Property.Name)}";

    private RenderFragment BuildChildContent(SandboxParameterDocumentation parameter) =>
        Component.Type.Name switch {
            "NTAccordion" => BuildAccordionItems(),
            "NTAutocomplete" => BuildAutocompleteOptions(),
            "NTButtonGroup" => BuildButtonGroupItems(),
            "NTCarousel" => BuildCarouselItems(),
            "NTDataGrid" => BuildDataGridColumns(),
            "NTFabMenu" => BuildFabMenuItems(),
            "NTInputRadioGroup" => BuildRadioItems(),
            "NTInputSelect" => BuildInputSelectItems(),
            "NTMenu" => BuildMenuItems(),
            "NTNavigationRail" => BuildNavigationRailItems(),
            "NTSelect" => BuildNativeOptions(),
            "NTSplitButton" => BuildMenuItems(),
            "NTTabView" => BuildTabs(),
            "NTLayout" => BuildLayoutContent(),
            "NTWizard" => BuildWizardSteps(),
            _ => BuildTextChildContent(parameter)
        };

    private RenderFragment BuildTextChildContent(SandboxParameterDocumentation parameter) {
        var text = BuildRenderFragmentText(parameter);
        return builder => builder.AddContent(0, text);
    }

    private static RenderFragment BuildAccordionItems() => builder => {
        builder.OpenComponent<NTAccordionItem>(0);
        builder.AddAttribute(1, nameof(NTAccordionItem.Label), "Getting started");
        builder.AddAttribute(2, nameof(NTAccordionItem.SupportingText), "Native disclosure item");
        builder.AddAttribute(3, nameof(NTAccordionItem.Open), true);
        builder.AddAttribute(4, nameof(NTAccordionItem.ChildContent), (RenderFragment)(content => {
            content.AddContent(0, "Accordion content is generated from the source documentation model.");
        }));
        builder.CloseComponent();
        AddDemoMarker(builder, 5, nameof(NTAccordionItem));

        builder.OpenComponent<NTAccordionItem>(10);
        builder.AddAttribute(11, nameof(NTAccordionItem.Label), "Details");
        builder.AddAttribute(12, nameof(NTAccordionItem.ChildContent), (RenderFragment)(content => {
            content.AddContent(0, "Use accordion items for related sections that can expand and collapse.");
        }));
        builder.CloseComponent();
    };

    private static RenderFragment BuildAutocompleteOptions() => builder => {
        builder.OpenComponent<NTAutocompleteOptionGroup>(0);
        builder.AddAttribute(1, nameof(NTAutocompleteOptionGroup.Label), "Examples");
        builder.CloseComponent();
        AddDemoMarker(builder, 2, nameof(NTAutocompleteOptionGroup));
        builder.OpenComponent<NTAutocompleteOption>(10);
        builder.AddAttribute(11, nameof(NTAutocompleteOption.Value), "First option");
        builder.CloseComponent();
        AddDemoMarker(builder, 12, nameof(NTAutocompleteOption));
        builder.OpenComponent<NTAutocompleteOption>(20);
        builder.AddAttribute(21, nameof(NTAutocompleteOption.Value), "Second option");
        builder.CloseComponent();
    };

    private static RenderFragment BuildButtonGroupItems() => builder => {
        builder.OpenComponent<NTButtonGroupItem<string>>(0);
        builder.AddAttribute(1, nameof(NTButtonGroupItem<string>.Key), "one");
        builder.AddAttribute(2, nameof(NTButtonGroupItem<string>.Label), "One");
        builder.CloseComponent();
        AddDemoMarker(builder, 3, "NTButtonGroupItem");
        builder.OpenComponent<NTButtonGroupItem<string>>(10);
        builder.AddAttribute(11, nameof(NTButtonGroupItem<string>.Key), "two");
        builder.AddAttribute(12, nameof(NTButtonGroupItem<string>.Label), "Two");
        builder.CloseComponent();
    };

    private static RenderFragment BuildCarouselItems() => builder => {
        builder.OpenComponent<NTCarouselItem>(0);
        builder.AddAttribute(1, nameof(NTCarouselItem.AriaLabel), "First slide");
        builder.AddAttribute(2, nameof(NTCarouselItem.ChildContent), (RenderFragment)(content => content.AddContent(0, "First slide")));
        builder.CloseComponent();
        AddDemoMarker(builder, 3, nameof(NTCarouselItem));
