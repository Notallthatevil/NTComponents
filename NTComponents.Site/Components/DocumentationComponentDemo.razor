@using System.Globalization
@using System.Reflection
@using System.Text

<section class="doc-section doc-group-panel doc-component-demo" id="demo">
    <div class="doc-section-heading">
        <h2 class="@NTTypography.TitleLarge.ToCssClass()">Sandbox</h2>
        <p class="@NTTypography.BodyMedium.ToCssClass()">
            Configure the component parameters and switch to Razor to copy the current markup.
        </p>
    </div>

    <NTMultiPaneView PaneCount="2"
                     MinPaneWidth="NTMultiPaneViewMinPaneWidth.Large"
                     EnforceEvenSizing="true"
                     class="demo-panes"
                     aria-label="@($"{TypePage.Name} interactive sandbox")">
        <div class="preview pane">
            <div class="toolbar" role="toolbar" aria-label="Sandbox view">
                <NTButton Label="Preview"
                          ButtonSize="Size.Small"
                          Variant="@GetViewButtonVariant(SandboxView.Preview)"
                          IsToggleButton="true"
                          Selected="@(_activeView == SandboxView.Preview)"
                          OnClickCallback="@(_ => SetActiveView(SandboxView.Preview))" />
                <NTButton Label="Razor"
                          ButtonSize="Size.Small"
                          Variant="@GetViewButtonVariant(SandboxView.Razor)"
                          IsToggleButton="true"
                          Selected="@(_activeView == SandboxView.Razor)"
                          OnClickCallback="@(_ => SetActiveView(SandboxView.Razor))" />
            </div>

            <div class="panel-heading">
                <div>
                    <p class="kicker @NTTypography.LabelLarge.ToCssClass()">@(_activeView == SandboxView.Preview ? "Live preview" : "Generated Razor")</p>
                    <h3 class="@NTTypography.TitleMedium.ToCssClass()">@TypePage.Name</h3>
                </div>
                <span class="parameter-count @NTTypography.LabelLarge.ToCssClass()">@GetParameterCountLabel()</span>
            </div>

            @if (_activeView == SandboxView.Preview) {
                <div class="stage">
                    <ErrorBoundary @ref="_previewBoundary">
                        <ChildContent>
                            <DynamicComponent Type="ComponentType" Parameters="GetComponentParameters()" />
                        </ChildContent>
                        <ErrorContent Context="exception">
                            <div class="error" role="alert">
                                <p class="@NTTypography.LabelLarge.ToCssClass()">Current parameters are invalid.</p>
                                <p class="@NTTypography.BodySmall.ToCssClass()">@exception.Message</p>
                            </div>
                        </ErrorContent>
                    </ErrorBoundary>
                </div>

                @if (_eventCallbackCounts.Count > 0) {
                    <div class="events" aria-label="Event callback counts">
                        @foreach (var eventCount in _eventCallbackCounts.OrderBy(item => item.Key, StringComparer.Ordinal)) {
                            <span class="@NTTypography.BodySmall.ToCssClass()">
                                <strong>@eventCount.Value</strong>
                                @eventCount.Key
                            </span>
                        }
                    </div>
                }
            }
            else {
                <div class="razor-view">
                    <div class="razor-actions">
                        <NTButton Label="@(_snippetCopied ? "Copied" : "Copy")"
                                  ButtonSize="Size.Small"
                                  Variant="NTButtonVariant.Outlined"
                                  OnClickCallback="@CopySnippetAsync" />
                    </div>
                    <pre><code>@GetRazorSnippet()</code></pre>
                </div>
            }
        </div>

        <div class="controls pane">
            <div class="panel-heading">
                <div>
                    <p class="kicker @NTTypography.LabelLarge.ToCssClass()">Parameters</p>
                    <h3 class="@NTTypography.TitleMedium.ToCssClass()">Configurable inputs</h3>
                </div>
            </div>

            @if (_parameters.Count == 0) {
                <div class="empty-state">
                    <p class="@NTTypography.BodyMedium.ToCssClass()">No public parameters are declared on this component.</p>
                </div>
            }
            else {
                @foreach (var parameter in GetOrderedParameters()) {
                    <div class="field">
                        <div class="field-heading">
                            <label class="@NTTypography.LabelLarge.ToCssClass()" for="@GetFieldId(parameter)">@parameter.Documentation.Name</label>
                            <div class="field-meta">
                                @if (parameter.IsRequired) {
                                    <span class="badge @NTTypography.LabelMedium.ToCssClass()">Required</span>
                                }
                                @if (parameter.Documentation.IsFromBaseType) {
                                    <span class="badge neutral @NTTypography.LabelMedium.ToCssClass()">Inherited</span>
                                }
                                <span class="@NTTypography.BodySmall.ToCssClass()">@GetParameterTypeLabel(parameter)</span>
                            </div>

                            @if (!string.IsNullOrWhiteSpace(parameter.Documentation.Content.SummaryParagraphs.FirstOrDefault())) {
                                <small class="@NTTypography.BodySmall.ToCssClass()">@((MarkupString)parameter.Documentation.Content.SummaryParagraphs.First())</small>
                            }
                        </div>

                        @switch (parameter.Kind) {
                            case DemoInputKind.Bool:
                                <div class="checkbox-control switch-control">
                                    <input id="@GetFieldId(parameter)"
                                           type="checkbox"
                                           checked="@GetBoolChecked(parameter)"
                                           @onchange="args => SetBoolCheckboxValue(parameter, args)" />
                                    <label class="@NTTypography.BodyMedium.ToCssClass()" for="@GetFieldId(parameter)">
                                        <span class="switch-track" aria-hidden="true">
                                            <span class="switch-thumb"></span>
                                        </span>
                                        <span>@GetBoolLabel(parameter)</span>
                                    </label>

                                    @if (!parameter.IsRequired) {
                                        <button type="button"
                                                class="@NTTypography.LabelLarge.ToCssClass()"
                                                disabled="@(!_setParameters.Contains(parameter.Documentation.Name))"
                                                @onclick="() => ClearParameterValue(parameter)">
                                            Default
                                        </button>
                                    }
                                </div>
                                break;

                            case DemoInputKind.Enum:
                                <select id="@GetFieldId(parameter)" value="@GetEnumValue(parameter)" @onchange="args => SetEnumValue(parameter, args)">
                                    @if (!parameter.IsRequired) {
                                        <option value="">Default</option>
                                    }
                                    @foreach (var value in Enum.GetNames(parameter.UnderlyingType)) {
                                        <option value="@value">@value</option>
                                    }
                                </select>
                                break;

                            case DemoInputKind.Icon:
                                <select id="@GetFieldId(parameter)" value="@GetIconValue(parameter)" @onchange="args => SetIconValue(parameter, args)">
                                    <option value="">Default</option>
                                    @foreach (var icon in _iconOptions.Keys) {
                                        <option value="@icon">@icon</option>
                                    }
                                </select>
                                break;

                            case DemoInputKind.EventCallback:
                                <div class="checkbox-control switch-control">
                                    <input id="@GetFieldId(parameter)"
                                           type="checkbox"
                                           checked="@GetEventCallbackAttached(parameter)"
                                           @onchange="args => SetEventCallbackChecked(parameter, args)" />
                                    <label class="@NTTypography.BodyMedium.ToCssClass()" for="@GetFieldId(parameter)">
                                        <span class="switch-track" aria-hidden="true">
                                            <span class="switch-thumb"></span>
                                        </span>
                                        <span>@(GetEventCallbackAttached(parameter) ? "Attached" : "Not attached")</span>
                                    </label>
                                </div>
                                break;

                            case DemoInputKind.RenderFragment:
                                <textarea id="@GetFieldId(parameter)" value="@GetTextValue(parameter)" @onchange="args => SetRenderFragmentValue(parameter, args)" rows="3"></textarea>
                                break;

                            case DemoInputKind.String:
                                <input id="@GetFieldId(parameter)" value="@GetTextValue(parameter)" @onchange="args => SetStringValue(parameter, args)" />
                                break;

                            case DemoInputKind.Number:
                                <input id="@GetFieldId(parameter)" type="number" value="@GetTextValue(parameter)" @onchange="args => SetNumberValue(parameter, args)" />
                                break;

                            default:
                                <input id="@GetFieldId(parameter)" value="@GetUnsupportedValue(parameter)" disabled />
                                break;
                        }
                    </div>
                }
            }
        </div>
    </NTMultiPaneView>
</section>

@code {
    private static readonly IReadOnlyDictionary<string, TnTIcon> _iconOptions = new Dictionary<string, TnTIcon>(StringComparer.Ordinal) {
        ["Add"] = MaterialIcon.Add,
        ["Check"] = MaterialIcon.Check,
        ["Close"] = MaterialIcon.Close,
        ["Edit"] = MaterialIcon.Edit,
        ["Favorite"] = MaterialIcon.Favorite,
        ["Menu"] = MaterialIcon.Menu,
        ["Search"] = MaterialIcon.Search
    };

    private readonly Dictionary<string, int> _eventCallbackCounts = new(StringComparer.Ordinal);
    private readonly Dictionary<string, string> _fieldValues = new(StringComparer.Ordinal);
    private readonly Dictionary<string, object?> _parameterValues = new(StringComparer.Ordinal);
    private readonly HashSet<string> _setParameters = new(StringComparer.Ordinal);
    private SandboxView _activeView = SandboxView.Preview;
    private IReadOnlyList<ComponentDemoParameter> _parameters = Array.Empty<ComponentDemoParameter>();
    private ErrorBoundary? _previewBoundary;
    private string? _loadedTypeFullName;
    private bool _snippetCopied;

    [Inject]
    private IJSRuntime JSRuntime { get; set; } = default!;

    [Parameter, EditorRequired]
    public Type ComponentType { get; set; } = default!;

    [Parameter, EditorRequired]
    public DocumentationTypePage TypePage { get; set; } = default!;

    protected override void OnParametersSet() {
        if (string.Equals(_loadedTypeFullName, TypePage.FullName, StringComparison.Ordinal)) {
            return;
        }

        _loadedTypeFullName = TypePage.FullName;
        _activeView = SandboxView.Preview;
        _fieldValues.Clear();
        _parameterValues.Clear();
        _setParameters.Clear();
        _eventCallbackCounts.Clear();
        _snippetCopied = false;

        var runtimeParameters = GetRuntimeParameterProperties();

        _parameters = TypePage.Parameters
            .Where(parameter => runtimeParameters.ContainsKey(parameter.Name))
            .Select(parameter => CreateParameter(parameter, runtimeParameters[parameter.Name]))
            .ToArray();

        foreach (var parameter in _parameters.Where(parameter => parameter.IsRequired)) {
            SeedRequiredParameter(parameter);
        }
    }

    private IReadOnlyDictionary<string, PropertyInfo> GetRuntimeParameterProperties() {
        return ComponentType
            .GetProperties(BindingFlags.Instance | BindingFlags.Public)
            .Where(property => Attribute.IsDefined(property, typeof(ParameterAttribute), inherit: true))
            .GroupBy(property => property.Name, StringComparer.Ordinal)
            .ToDictionary(group => group.Key, group => group.First(), StringComparer.Ordinal);
    }

    private ComponentDemoParameter CreateParameter(DocumentationMemberPage documentation, PropertyInfo property) {
        var nullableType = Nullable.GetUnderlyingType(property.PropertyType);
        var underlyingType = nullableType ?? property.PropertyType;
        var isNullable = nullableType is not null || !property.PropertyType.IsValueType;

        return new ComponentDemoParameter(
            documentation,
            property,
            property.PropertyType,
            underlyingType,
            isNullable,
            Attribute.IsDefined(property, typeof(EditorRequiredAttribute), inherit: true),
            GetInputKind(property.PropertyType, underlyingType));
    }

    private IDictionary<string, object> GetComponentParameters() {
        return _setParameters
            .Where(_parameterValues.ContainsKey)
            .ToDictionary(name => name, name => _parameterValues[name]!, StringComparer.Ordinal);
    }

    private IEnumerable<ComponentDemoParameter> GetOrderedParameters() {
        return _parameters
            .OrderByDescending(parameter => parameter.IsRequired)
            .ThenBy(parameter => parameter.Documentation.IsFromBaseType)
            .ThenBy(parameter => parameter.Kind == DemoInputKind.Unsupported)
            .ThenBy(parameter => parameter.Kind == DemoInputKind.Bool ? 0 : parameter.Kind == DemoInputKind.Enum ? 1 : 2)
            .ThenBy(parameter => parameter.Documentation.Name, StringComparer.Ordinal);
    }

    private static DemoInputKind GetInputKind(Type parameterType, Type underlyingType) {
        if (underlyingType == typeof(bool)) {
            return DemoInputKind.Bool;
        }

        if (underlyingType.IsEnum) {
            return DemoInputKind.Enum;
        }

        if (parameterType == typeof(string)) {
            return DemoInputKind.String;
        }

        if (parameterType == typeof(RenderFragment)) {
            return DemoInputKind.RenderFragment;
        }

        if (typeof(TnTIcon).IsAssignableFrom(underlyingType)) {
            return DemoInputKind.Icon;
        }

        if (parameterType == typeof(EventCallback) || parameterType.IsGenericType && parameterType.GetGenericTypeDefinition() == typeof(EventCallback<>)) {
            return DemoInputKind.EventCallback;
        }

        if (IsNumericType(underlyingType)) {
            return DemoInputKind.Number;
        }

        return DemoInputKind.Unsupported;
    }

    private static bool IsNumericType(Type type) {
        return type == typeof(byte)
            || type == typeof(decimal)
            || type == typeof(double)
            || type == typeof(float)
            || type == typeof(int)
            || type == typeof(long)
            || type == typeof(short);
    }

    private void SeedRequiredParameter(ComponentDemoParameter parameter) {
        switch (parameter.Kind) {
            case DemoInputKind.String:
                SetParameterValue(parameter, $"Demo {TypePage.Name}");
                break;

            case DemoInputKind.RenderFragment:
                SetRenderFragmentText(parameter, $"Demo content for {TypePage.Name}");
                break;

            case DemoInputKind.Bool:
                SetParameterValue(parameter, false);
                break;

            case DemoInputKind.Enum:
                SetParameterValue(parameter, Enum.GetValues(parameter.UnderlyingType).GetValue(0));
                break;

            case DemoInputKind.Icon:
                _fieldValues[parameter.Documentation.Name] = "Add";
                SetParameterValue(parameter, MaterialIcon.Add);
                break;
        }
    }

    private bool GetBoolChecked(ComponentDemoParameter parameter) {
        return _setParameters.Contains(parameter.Documentation.Name)
            && _parameterValues.TryGetValue(parameter.Documentation.Name, out var value)
            && value is bool boolValue
            && boolValue;
    }

    private string GetBoolLabel(ComponentDemoParameter parameter) {
        if (!_setParameters.Contains(parameter.Documentation.Name)) {
            return "Default";
        }

        return GetBoolChecked(parameter) ? "True" : "False";
    }

    private string GetEnumValue(ComponentDemoParameter parameter) {
        return _setParameters.Contains(parameter.Documentation.Name)
            ? Convert.ToString(_parameterValues[parameter.Documentation.Name], CultureInfo.InvariantCulture) ?? string.Empty
            : string.Empty;
    }

    private bool GetEventCallbackAttached(ComponentDemoParameter parameter) {
        return _setParameters.Contains(parameter.Documentation.Name);
    }

    private string GetIconValue(ComponentDemoParameter parameter) {
        return _fieldValues.GetValueOrDefault(parameter.Documentation.Name, string.Empty);
    }

    private string GetTextValue(ComponentDemoParameter parameter) {
        return _fieldValues.GetValueOrDefault(parameter.Documentation.Name, string.Empty);
    }

    private static string GetUnsupportedValue(ComponentDemoParameter parameter) {
        return $"Unsupported: {parameter.Documentation.TypeDisplayName ?? parameter.ParameterType.Name}";
    }

    private string GetFieldId(ComponentDemoParameter parameter) {
        return $"demo-{TypePage.Name}-{parameter.Documentation.Name}";
    }

    private string GetParameterCountLabel() {
        return _parameters.Count == 1 ? "1 parameter" : $"{_parameters.Count} parameters";
    }

    private static string GetParameterTypeLabel(ComponentDemoParameter parameter) {
        return parameter.Documentation.TypeDisplayName ?? parameter.ParameterType.Name;
    }

    private NTButtonVariant GetViewButtonVariant(SandboxView view) {
        return _activeView == view ? NTButtonVariant.Filled : NTButtonVariant.Outlined;
    }

    private void SetActiveView(SandboxView view) {
        _activeView = view;
        _snippetCopied = false;
    }

    private void SetBoolCheckboxValue(ComponentDemoParameter parameter, ChangeEventArgs args) {
        SetParameterValue(parameter, args.Value is true);
    }

    private void SetEnumValue(ComponentDemoParameter parameter, ChangeEventArgs args) {
        var value = Convert.ToString(args.Value, CultureInfo.InvariantCulture);
        if (string.IsNullOrWhiteSpace(value)) {
            ClearParameterValue(parameter);
            return;
        }

        SetParameterValue(parameter, Enum.Parse(parameter.UnderlyingType, value));
    }

    private void SetEventCallbackChecked(ComponentDemoParameter parameter, ChangeEventArgs args) {
        if (args.Value is not true) {
            ClearParameterValue(parameter);
            return;
        }

        SetParameterValue(parameter, CreateEventCallback(parameter));
    }

    private void SetIconValue(ComponentDemoParameter parameter, ChangeEventArgs args) {
        var value = Convert.ToString(args.Value, CultureInfo.InvariantCulture) ?? string.Empty;
        if (string.IsNullOrWhiteSpace(value) || !_iconOptions.TryGetValue(value, out var icon)) {
            ClearParameterValue(parameter);
            return;
        }

        _fieldValues[parameter.Documentation.Name] = value;
        SetParameterValue(parameter, icon);
    }

    private void SetNumberValue(ComponentDemoParameter parameter, ChangeEventArgs args) {
        var value = Convert.ToString(args.Value, CultureInfo.InvariantCulture) ?? string.Empty;
        if (string.IsNullOrWhiteSpace(value)) {
            ClearParameterValue(parameter);
            return;
        }

        _fieldValues[parameter.Documentation.Name] = value;
        SetParameterValue(parameter, Convert.ChangeType(value, parameter.UnderlyingType, CultureInfo.InvariantCulture));
    }

    private void SetRenderFragmentValue(ComponentDemoParameter parameter, ChangeEventArgs args) {
        var value = Convert.ToString(args.Value, CultureInfo.InvariantCulture) ?? string.Empty;
        if (string.IsNullOrWhiteSpace(value) && !parameter.IsRequired) {
            ClearParameterValue(parameter);
            return;
        }

        SetRenderFragmentText(parameter, string.IsNullOrWhiteSpace(value) ? $"Demo content for {TypePage.Name}" : value);
    }

    private void SetStringValue(ComponentDemoParameter parameter, ChangeEventArgs args) {
        var value = Convert.ToString(args.Value, CultureInfo.InvariantCulture) ?? string.Empty;
        if (string.IsNullOrWhiteSpace(value) && !parameter.IsRequired) {
            ClearParameterValue(parameter);
            return;
        }

        SetParameterValue(parameter, string.IsNullOrWhiteSpace(value) ? $"Demo {TypePage.Name}" : value);
    }

    private void SetRenderFragmentText(ComponentDemoParameter parameter, string value) {
        RenderFragment fragment = builder => builder.AddContent(0, value);
        _fieldValues[parameter.Documentation.Name] = value;
        SetParameterValue(parameter, fragment);
    }

    private void SetParameterValue(ComponentDemoParameter parameter, object? value) {
        _previewBoundary?.Recover();
        _snippetCopied = false;
        _setParameters.Add(parameter.Documentation.Name);
        _parameterValues[parameter.Documentation.Name] = value;
        if (parameter.Kind != DemoInputKind.Icon || !_fieldValues.ContainsKey(parameter.Documentation.Name)) {
            _fieldValues[parameter.Documentation.Name] = Convert.ToString(value, CultureInfo.InvariantCulture) ?? string.Empty;
        }
    }

    private void ClearParameterValue(ComponentDemoParameter parameter) {
        _previewBoundary?.Recover();
        _snippetCopied = false;
        _setParameters.Remove(parameter.Documentation.Name);
        _parameterValues.Remove(parameter.Documentation.Name);
        _fieldValues.Remove(parameter.Documentation.Name);

        if (parameter.IsRequired) {
            SeedRequiredParameter(parameter);
        }
    }

    private object CreateEventCallback(ComponentDemoParameter parameter) {
        if (parameter.ParameterType == typeof(EventCallback<MouseEventArgs>)) {
            return EventCallback.Factory.Create<MouseEventArgs>(this, _ => TrackEventCallback(parameter.Documentation.Name));
        }

        if (parameter.ParameterType == typeof(EventCallback<bool>)) {
            return EventCallback.Factory.Create<bool>(this, _ => TrackEventCallback(parameter.Documentation.Name));
        }

        return EventCallback.Factory.Create(this, () => TrackEventCallback(parameter.Documentation.Name));
    }

    private void TrackEventCallback(string name) {
        _eventCallbackCounts[name] = _eventCallbackCounts.GetValueOrDefault(name) + 1;
    }

    private string GetRazorSnippet() {
        var attributes = GetSnippetAttributes().ToArray();
        var childContent = GetRenderFragmentMarkup("ChildContent");
        var childFragments = _parameters
            .Where(parameter => parameter.Kind == DemoInputKind.RenderFragment
                && _setParameters.Contains(parameter.Documentation.Name)
                && !string.Equals(parameter.Documentation.Name, "ChildContent", StringComparison.Ordinal))
            .ToArray();

        if (childContent is null && childFragments.Length == 0) {
            return attributes.Length == 0
                ? $"<{TypePage.Name} />"
                : $"<{TypePage.Name}\n    {string.Join("\n    ", attributes)} />";
        }

        var builder = new StringBuilder();
        builder.Append('<').Append(TypePage.Name);
        if (attributes.Length > 0) {
            builder.AppendLine();
            builder.Append("    ").AppendJoin("\n    ", attributes);
        }

        builder.AppendLine(">");
        foreach (var fragment in childFragments) {
            builder.Append("    <").Append(fragment.Documentation.Name).Append('>');
            builder.Append(EscapeMarkup(GetTextValue(fragment)));
            builder.Append("</").Append(fragment.Documentation.Name).AppendLine(">");
        }

        if (childContent is not null) {
            builder.Append("    ").AppendLine(EscapeMarkup(childContent));
        }

        builder.Append("</").Append(TypePage.Name).Append('>');
        return builder.ToString();
    }

    private IEnumerable<string> GetSnippetAttributes() {
        foreach (var parameter in GetOrderedParameters()) {
            if (!_setParameters.Contains(parameter.Documentation.Name) || parameter.Kind == DemoInputKind.RenderFragment) {
                continue;
            }

            var value = FormatRazorAttribute(parameter);
            if (!string.IsNullOrWhiteSpace(value)) {
                yield return $"{parameter.Documentation.Name}=\"{value}\"";
            }
        }
    }

    private string? GetRenderFragmentMarkup(string name) {
        return _setParameters.Contains(name)
            ? _fieldValues.GetValueOrDefault(name)
            : null;
    }

    private string FormatRazorAttribute(ComponentDemoParameter parameter) {
        if (!_parameterValues.TryGetValue(parameter.Documentation.Name, out var value) || value is null) {
            return string.Empty;
        }

        return parameter.Kind switch {
            DemoInputKind.Bool => value is true ? "true" : "false",
            DemoInputKind.Enum => $"@{GetFriendlyTypeName(parameter.UnderlyingType)}.{value}",
            DemoInputKind.EventCallback => $"@Handle{parameter.Documentation.Name}",
            DemoInputKind.Icon => $"@MaterialIcon.{GetIconValue(parameter)}",
            DemoInputKind.Number => Convert.ToString(value, CultureInfo.InvariantCulture) ?? string.Empty,
            DemoInputKind.String => EscapeAttribute(Convert.ToString(value, CultureInfo.InvariantCulture) ?? string.Empty),
            _ => string.Empty
        };
    }

    private static string GetFriendlyTypeName(Type type) {
        var nullableType = Nullable.GetUnderlyingType(type);
        if (nullableType is not null) {
            return GetFriendlyTypeName(nullableType);
        }

        return type.Name;
    }

    private static string EscapeAttribute(string value) {
        return value.Replace("&", "&amp;", StringComparison.Ordinal)
            .Replace("\"", "&quot;", StringComparison.Ordinal);
    }

    private static string EscapeMarkup(string value) {
        return value.Replace("&", "&amp;", StringComparison.Ordinal)
            .Replace("<", "&lt;", StringComparison.Ordinal)
            .Replace(">", "&gt;", StringComparison.Ordinal);
    }

    private async Task CopySnippetAsync(MouseEventArgs _) {
        await JSRuntime.InvokeVoidAsync("ntDocs.copyText", GetRazorSnippet());
        _snippetCopied = true;
    }

    private sealed record ComponentDemoParameter(
        DocumentationMemberPage Documentation,
        PropertyInfo Property,
        Type ParameterType,
        Type UnderlyingType,
        bool IsNullable,
        bool IsRequired,
        DemoInputKind Kind);

    private enum DemoInputKind {
        Unsupported,
        Bool,
        Enum,
        EventCallback,
        Icon,
        Number,
        RenderFragment,
        String
    }

    private enum SandboxView {
        Preview,
        Razor
    }
}
