@using NTComponents.Virtualization
@using NTComponents.Snackbar
@using NTComponents.Toast
@inject INTSnackbarService SnackbarService
@inject INTToastService ToastService

<div class="docs-curated-demo">
    @switch (Component.Type.Name) {
        case "NTDialog":
        <div class="stack">
            <NTButton Label="Open example dialog" OnClickCallback="OpenDialogAsync" />
            <NTDialog @ref="_dialog"
                      Id="@TextValue("Id", "docs-example-dialog")"
                      Title="@TextValue("Title", "Review changes")"
                      SupportingText="@TextValue("SupportingText", "Confirm the changes before continuing.")"
                      CloseButtonAriaLabel="@TextValue("CloseButtonAriaLabel", "Close dialog")"
                      ButtonSpacing="@Value("ButtonSpacing", NTDialogButtonSpacing.End)"
                      CloseOnBackdrop="@Value("CloseOnBackdrop", false)"
                      CloseOnEscape="@Value("CloseOnEscape", true)"
                      Elevation="@Value("Elevation", NTElevation.Medium)"
                      Open="@Value("Open", false)"
                      ShowCloseButton="@Value("ShowCloseButton", true)">
                <ChildContent>
                    <p>Dialogs keep focused content and actions together.</p>
                </ChildContent>
                <Buttons>
                    <button type="button" class="nt-dialog-button" command="request-close" commandfor="@TextValue("Id", "docs-example-dialog")" value="cancel">Cancel</button>
                    <button type="button" class="nt-dialog-button" command="request-close" commandfor="@TextValue("Id", "docs-example-dialog")" value="confirm">Confirm</button>
                </Buttons>
            </NTDialog>
        </div>
            break;
        case "NTMenu":
        <div class="menu">
            <NTButton ElementId="docs-menu-trigger"
                      Label="Open example menu"
                      LeadingIcon="MaterialIcon.Menu"
                      style="@MenuAnchorStyle"
                      popovertarget="docs-example-menu"
                      popovertargetaction="toggle" />
            <NTMenu ElementId="docs-example-menu"
                    AnchorName="@TextValue("AnchorName", "--docs-menu-anchor")"
                    AnchorSelector="@TextValue("AnchorSelector", "#docs-menu-trigger")"
                    Appearance="@Value("Appearance", NTMenuAppearance.Standard)"
                    AriaLabel="@TextValue("AriaLabel", "Menu example")"
                    CloseOnContentClick="@Value("CloseOnContentClick", true)"
                    ContainerColor="@(ColorValue("ContainerColor"))"
                    Disabled="@Value("Disabled", false)"
                    Elevation="@Value("Elevation", NTElevation.Medium)"
                    IsSubMenu="@Value("IsSubMenu", false)"
                    Popover="@TextValue("Popover", "auto")"
                    Role="@TextValue("Role", "menu")"
                    SelectedContainerColor="@(ColorValue("SelectedContainerColor"))"
                    SelectedTextColor="@(ColorValue("SelectedTextColor"))"
                    TextColor="@(ColorValue("TextColor"))">
                <NTMenuLabelItem Label="Actions" />
                <NTMenuButtonItem Label="Edit" Icon="MaterialIcon.Edit" />
                <NTMenuDividerItem />
                <NTMenuAnchorItem Label="View details" Icon="MaterialIcon.Info" Href="#example" />
            </NTMenu>
        </div>
            break;
        case "NTSnackbar":
        <div class="stack">
            <NTButton Label="Show example snackbar" OnClickCallback="ShowSnackbarAsync" />
            <NTSnackbar Position="@Value("Position", NTSnackbarPosition.BottomCenter)" />
        </div>
            break;
        case "NTToast":
        <div class="stack">
            <NTButton Label="Show example toast" OnClickCallback="ShowToastAsync" />
            <NTToast Position="@Value("Position", NTToastPosition.BottomRightCorner)" />
        </div>
            break;
        case "NTTooltip":
        <button type="button" class="tooltip-target">
            Hover or focus for help
            <NTTooltip BackgroundColor="@(ColorValue("BackgroundColor"))"
                       BorderColor="@(ColorValue("BorderColor"))"
                       ShowDelay="@Value("ShowDelay", 500)"
                       HideDelay="@Value("HideDelay", 200)"
                       TextColor="@(ColorValue("TextColor"))"
                       Variant="@Value("Variant", NTTooltipVariant.Plain)">This is a live tooltip.</NTTooltip>
        </button>
            break;
        case "NTVirtualize":
        <div class="virtualize">
            <NTVirtualize TItem="string"
                          @key='Value("ItemSize", 50f)'
                          ItemsProvider="LoadItemsAsync"
                          ItemSize="@Value("ItemSize", 50f)"
                          MaxItemCount="@Value("MaxItemCount", 100)"
                          OverscanCount="@Value("OverscanCount", 3)"
                          PlaceholderPreloadWindowCount="@Value("PlaceholderPreloadWindowCount", 1)"
                          BackgroundPreloadWindowCount="@Value("BackgroundPreloadWindowCount", 0)"
                          RevalidateCachedItems="@Value("RevalidateCachedItems", false)"
                          ScrollRestorationKey="@(ValueProvider("ScrollRestorationKey") as string)"
                          MaxCachedItemCount="@Value("MaxCachedItemCount", 1_000)"
                          SpacerElement="@TextValue("SpacerElement", "div")">
                <ItemTemplate Context="item">
                    <div class="virtualize-item">@item</div>
                </ItemTemplate>
                <EmptyTemplate>
                    <p>No items are available.</p>
                </EmptyTemplate>
            </NTVirtualize>
        </div>
            break;
    }
</div>
