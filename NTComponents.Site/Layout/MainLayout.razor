@inherits LayoutComponentBase
<TnTLayout class="docs-shell">
    <NavMenu />

    <TnTHeader class="docs-header" BackgroundColor="TnTColor.Surface" TextColor="TnTColor.OnSurface">
        <div class="docs-brand">
            <TnTSideNavToggle ElementTitle="Toggle navigation" />
            <MaterialIcon Icon="auto_awesome_mosaic" />
            <a href="">NTComponents</a>
        </div>
        <div class="docs-header-actions">
            <TnTThemeToggle />
            <TnTButton Appearance="ButtonAppearance.Outlined"
                       BackgroundColor="TnTColor.Surface"
                       TextColor="TnTColor.OnSurface"
                       TintColor="TnTColor.Primary"
                       OnClickCallback="NavigateToGettingStarted">
                Get started
            </TnTButton>
        </div>
    </TnTHeader>

    <TnTBody class="docs-main" BackgroundColor="TnTColor.Background" TextColor="TnTColor.OnBackground">
        @Body
    </TnTBody>
</TnTLayout>

@code {
    [Inject]
    private NavigationManager Navigation { get; set; } = default!;

    private void NavigateToGettingStarted(MouseEventArgs _) => Navigation.NavigateTo("/docs");
}
