@inherits LayoutComponentBase
@inject DocumentationCatalog Catalog

<NTLayout>
    <NTNavigationRail AriaLabel="Documentation navigation" OpenByDefault="true" Header="@HeaderContent">
        <NTNavigationRailItem Label="Home" Href="/" Match="NavLinkMatch.All" Icon="MaterialIcon.Home" />
        <NTNavigationRailGroup Label="Components" Icon="MaterialIcon.Category" Expanded="true">
            <NTNavigationRailItem Label="All components" Href="/components" Match="NavLinkMatch.All" Icon="MaterialIcon.Category" />
            @foreach (var group in Catalog.ComponentGroups) {
                var components = group.ToArray();
                if (components.Length == 1) {
                    var component = components[0];
                    <NTNavigationRailItem Label="@component.Type.Name" Href="@($"/components/{component.Slug}")" Icon="MaterialIcon.Article" />
                }
                else {
                    <NTNavigationRailGroup Label="@group.Key" Icon="MaterialIcon.Folder">
                        @foreach (var component in components) {
                            <NTNavigationRailItem Label="@component.Type.Name" Href="@($"/components/{component.Slug}")" Icon="MaterialIcon.Article" />
                        }
                    </NTNavigationRailGroup>
                }
            }
        </NTNavigationRailGroup>
        <NTNavigationRailGroup Label="Enums" Icon="MaterialIcon.DataObject">
            <NTNavigationRailItem Label="All enums" Href="/reference/enums" Match="NavLinkMatch.All" Icon="MaterialIcon.DataObject" />
            @foreach (var group in Catalog.EnumGroups) {
                var references = group.ToArray();
                if (references.Length == 1) {
                    var reference = references[0];
                    <NTNavigationRailItem Label="@reference.Type.Name" Href="@($"/reference/enums/{reference.Slug}")" Icon="MaterialIcon.Article" />
                }
                else {
                    <NTNavigationRailGroup Label="@group.Key" Icon="MaterialIcon.Folder">
                        @foreach (var reference in references) {
                            <NTNavigationRailItem Label="@reference.Type.Name" Href="@($"/reference/enums/{reference.Slug}")" Icon="MaterialIcon.Article" />
                        }
                    </NTNavigationRailGroup>
                }
            }
        </NTNavigationRailGroup>
        <NTNavigationRailGroup Label="Constants" Icon="MaterialIcon.Tag">
            <NTNavigationRailItem Label="All constants" Href="/reference/constants" Match="NavLinkMatch.All" Icon="MaterialIcon.Tag" />
            @foreach (var group in Catalog.ConstantGroups) {
                var references = group.ToArray();
                if (references.Length == 1) {
                    var reference = references[0];
                    <NTNavigationRailItem Label="@reference.Type.Name" Href="@($"/reference/constants/{reference.Slug}")" Icon="MaterialIcon.Article" />
                }
                else {
                    <NTNavigationRailGroup Label="@group.Key" Icon="MaterialIcon.Folder">
                        @foreach (var reference in references) {
                            <NTNavigationRailItem Label="@reference.Type.Name" Href="@($"/reference/constants/{reference.Slug}")" Icon="MaterialIcon.Article" />
                        }
                    </NTNavigationRailGroup>
                }
            }
        </NTNavigationRailGroup>
    </NTNavigationRail>

    <NTHeader>
        <div class="docs-topbar">
            <a class="docs-brand" href="/" aria-label="NTComponents home">
                <img src="logo.png" width="128" height="128" alt="" />
                <span>NTComponents</span>
            </a>
            <span class="docs-topbar-subtitle">Material 3 Blazor documentation</span>
            <a class="docs-github-link" href="https://github.com/Notallthatevil/NTComponents" target="_blank" rel="noopener noreferrer" aria-label="GitHub repository" title="GitHub repository">
                <svg viewBox="0 0 16 16" aria-hidden="true" focusable="false">
                    <path fill="currentColor" d="M8 0C3.58 0 0 3.64 0 8.13c0 3.59 2.29 6.64 5.47 7.71.4.08.55-.18.55-.39 0-.19-.01-.82-.01-1.49-2.23.49-2.7-.55-2.7-.55-.36-.95-.88-1.2-.88-1.2-.72-.5.05-.49.05-.49.8.06 1.22.83 1.22.83.71 1.23 1.87.88 2.33.67.07-.52.28-.88.51-1.08-1.78-.21-3.64-.91-3.64-4.02 0-.89.31-1.62.82-2.19-.08-.2-.36-1.04.08-2.16 0 0 .67-.22 2.2.84a7.3 7.3 0 0 1 2-.27c.68 0 1.36.09 2 .27 1.53-1.06 2.2-.84 2.2-.84.44 1.12.16 1.96.08 2.16.51.57.82 1.3.82 2.19 0 3.12-1.87 3.81-3.65 4.01.29.25.54.73.54 1.48 0 1.07-.01 1.93-.01 2.2 0 .21.15.47.55.39A8.01 8.01 0 0 0 16 8.13C16 3.64 12.42 0 8 0" />
                </svg>
            </a>
        </div>
    </NTHeader>
    <NTBody>
        <div class="docs-content">
            @Body
        </div>
    </NTBody>
</NTLayout>

@code {
    private static RenderFragment HeaderContent => builder => {
        builder.OpenElement(0, "div");
        builder.AddAttribute(1, "class", "docs-rail-brand");
        builder.AddContent(2, "NT");
        builder.CloseElement();
    };
}
